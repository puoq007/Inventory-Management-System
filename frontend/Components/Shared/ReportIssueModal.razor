@inject LanguageService Lang

<div class="fixed inset-0 bg-slate-900/80 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center" @onclick="OnCancel">
    <div class="relative w-full max-w-md bg-slate-800 rounded-2xl shadow-2xl p-6 border border-slate-700" @onclick:stopPropagation="true">

        <h3 class="text-xl font-bold text-mattel-red mb-4 flex items-center">
            <svg class="w-6 h-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            @Lang.T("แจ้งปัญหา จิ๊ก", "Report Issue for Jig ") @JigId
        </h3>
        
        <div class="mb-4">
            <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("ปัญหาที่พบ", "Issue Type")</label>
            <select value="@ReportType" @onchange='(e) => ReportTypeChanged.InvokeAsync(e.Value?.ToString() ?? "")' class="w-full bg-slate-900 text-slate-200 border-slate-700 rounded-lg shadow-sm focus:border-mattel-red focus:ring-mattel-red p-2 border">
                <option value="">-- @Lang.T("เลือกปัญหา", "Select Issue") --</option>
                <option value="Broken">🔨 @Lang.T("ชำรุด / เสีย", "Broken")</option>
                <option value="NeedsCleaning">🧹 @Lang.T("ต้องทำความสะอาด", "Needs Cleaning")</option>
                <option value="Lost">❓ @Lang.T("สูญหาย", "Lost")</option>
                <option value="Other">⚠️ @Lang.T("อื่นๆ", "Other")</option>
            </select>
        </div>

        <div class="mb-6">
            <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("หมายเหตุ / สาเหตุ", "Remark / Reason")</label>
            <textarea value="@ReportRemark" @onchange='(e) => ReportRemarkChanged.InvokeAsync(e.Value?.ToString() ?? "")' rows="3" class="w-full bg-slate-900 text-slate-200 border-slate-700 rounded-lg shadow-sm focus:border-mattel-red focus:ring-mattel-red p-2 border outline-none" placeholder="@Lang.T("อธิบายปัญหาที่พบสั้นๆ...", "Briefly describe the issue...")"></textarea>
        </div>

        <div class="flex justify-end gap-3">
            <button @onclick="OnCancel" class="px-4 py-2 bg-slate-900 text-slate-300 border border-slate-700 font-medium rounded-lg hover:bg-slate-700 transition-colors">@Lang.T("ยกเลิก", "Cancel")</button>
            <button @onclick="OnSubmit" disabled="@(string.IsNullOrEmpty(ReportType))" class="px-4 py-2 bg-mattel-red text-white font-medium rounded-lg transition-opacity disabled:opacity-50 disabled:cursor-not-allowed flex items-center hover:bg-mattel-hover">
                @if (IsSubmitting)
                {
                    <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                    @Lang.T("กำลังบันทึก...", "Saving...")
                }
                else
                {
                    @Lang.T("ยืนยันแจ้งปัญหา", "Confirm Report")
                }
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string JigId { get; set; } = "";
    [Parameter] public string ReportType { get; set; } = "";
    [Parameter] public EventCallback<string> ReportTypeChanged { get; set; }
    [Parameter] public string ReportRemark { get; set; } = "";
    [Parameter] public EventCallback<string> ReportRemarkChanged { get; set; }
    [Parameter] public bool IsSubmitting { get; set; }
    
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }
}
