@using shared.Models
@inject frontend.Services.LanguageService Lang

<div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm h-full w-full z-50 flex items-center justify-center p-4">
    <div class="relative w-full max-w-xl bg-slate-800 rounded-2xl shadow-xl flex flex-col max-h-[90vh] overflow-hidden">
        <div class="p-6 border-b border-slate-700 shrink-0 bg-slate-800 z-10">
            <h3 class="text-2xl font-bold text-slate-100">@Lang.T(IsEditMode ? "แก้ไขข้อมูลจิ๊ก" : "ลงทะเบียนจิ๊กใหม่", IsEditMode ? "Edit Jig" : "Register New Jig")</h3>
        </div>
        
        <div class="p-6 overflow-y-auto overflow-x-hidden flex-1 min-h-0 w-full custom-scrollbar" style="max-height: calc(90vh - 140px);">
            @if (!string.IsNullOrEmpty(ModalError))
            { <div class="mb-4 p-4 bg-red-900/30 text-red-400 rounded-xl">@ModalError</div> }

            <EditForm Model="EditingJig" OnValidSubmit="SaveJig">
                <div class="flex flex-col gap-4">
                    
                    <!-- Primary Info -->
                    <div class="pb-3 border-b border-slate-700">
                        <h3 class="text-sm font-bold text-slate-200 mb-2">@Lang.T("ข้อมูลหลัก", "Primary Info")</h3>
                        <div class="grid grid-cols-1 gap-3">
                            <div>
                                <label class="block text-xs font-semibold mb-1">@Lang.T("รหัส JIG", "Jig ID") <span class="text-red-500">*</span></label>
                                <input type="text" @bind="EditingJig.Id" required disabled="@IsEditMode" class="w-full px-3 py-1.5 border border-slate-700 rounded-lg focus:ring-1 focus:ring-mattel-red text-sm bg-slate-900 text-slate-200 disabled:opacity-50 cursor-not-allowed" placeholder="e.g. JIG-0001" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-blue-400 mb-1">@Lang.T("ตัวอย่าง Smart Code", "Smart Code Preview")</label>
                                <div class="w-full px-3 py-1.5 bg-slate-900 border border-slate-700 rounded-lg text-blue-400 text-xs min-h-[32px] flex items-center break-words">
                                    @SmartCodePreview
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Specifications -->
                    <div class="pb-3 border-b border-slate-700">
                        <h3 class="text-sm font-bold text-slate-200 mb-2">@Lang.T("ข้อมูลจำเพาะ (Specifications)", "Specifications")</h3>
                        <div class="grid grid-cols-2 gap-x-4 gap-y-2">
                            <div><label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("รหัสเครื่องมือ (Tool No.)", "Tool No.")</label><input type="text" @bind="EditingJig.ToolNo" @bind:event="oninput" class="w-full px-2 py-1 border border-slate-700 rounded focus:border-mattel-red text-sm bg-slate-900 text-slate-200" /></div>
                            <div>
                                <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("ลำดับการพิมพ์ (Step Print)", "Step Print")</label>
                                <div class="flex flex-col gap-2">
                                    <select class="w-full px-2 py-1 border border-slate-700 rounded focus:border-mattel-red text-sm bg-slate-800 text-slate-200" @onchange="OnAddStep">
                                        <option value="">-- Add Step --</option>
                                        @foreach (var opt in StepPrintOptions) { <option value="@opt">@opt</option> }
                                    </select>
                                    <div class="flex flex-wrap gap-2 mt-2">
                                        @foreach (var step in SelectedSteps)
                                        {
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-sm font-semibold bg-blue-50 text-blue-700 border border-blue-200 shadow-xl">
                                                @step
                                                <button type="button" @onclick="() => OnRemoveStep.InvokeAsync(step)" class="ml-2 text-blue-400 hover:text-blue-600 transition-colors">✕</button>
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div>
                                <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("ประเภทชิ้นส่วน (Part Type)", "Part Type")</label>
                                <select @bind="EditingJig.PartType" class="w-full px-2 py-1 border border-slate-700 rounded focus:border-mattel-red text-sm bg-slate-800 text-slate-200">
                                    <option value="">-- Select --</option>
                                    @foreach (var opt in PartTypeOptions) { <option value="@opt">@opt</option> }
                                </select>
                            </div>
                            <div>
                                <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("วันที่ (Date)", "Date")</label>
                                <input type="date" value="@(SelectedDate?.ToString("yyyy-MM-dd"))" @onchange="OnDateChanged" class="w-full px-2 py-1 border border-slate-700 rounded focus:border-mattel-red text-sm h-[30px] bg-slate-900 text-slate-200" />
                            </div>
                            <div><label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("ฟีด (Feed)", "Feed")</label><input type="text" @bind="EditingJig.Feed" @bind:event="oninput" class="w-full px-2 py-1 border border-slate-700 rounded focus:border-mattel-red text-sm bg-slate-900 text-slate-200" /></div>
                            <div><label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("สแกน (Scan)", "Scan")</label><input type="text" @bind="EditingJig.Scan" @bind:event="oninput" class="w-full px-2 py-1 border border-slate-700 rounded focus:border-mattel-red text-sm bg-slate-900 text-slate-200" /></div>
                            <div><label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("จำนวน / การพิมพ์ (Q'ty / Print)", "Q'ty / Print")</label><input type="text" @bind="EditingJig.QtyPrint" @bind:event="oninput" class="w-full px-2 py-1 border border-slate-700 rounded focus:border-mattel-red text-sm bg-slate-900 text-slate-200" /></div>
                            <div>
                                <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("ความสูง JIG (Height Jig)", "Height Jig")</label>
                                <select @bind="EditingJig.HeightJig" class="w-full px-2 py-1 border border-slate-700 rounded focus:border-mattel-red text-sm bg-slate-800 text-slate-200">
                                    <option value="">-- Select --</option>
                                    @foreach (var opt in HeightJigOptions) { <option value="@opt">@{ if(opt == "HMR Plywood" || opt == "MDF Plywood") { @opt } else { @(opt + " mm") } }</option> }
                                </select>
                            </div>
                            <div>
                                <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("ประเภท JIG (Jig Type)", "Jig Type")</label>
                                <select @bind="EditingJig.JigType" class="w-full px-2 py-1 border border-slate-700 rounded focus:border-mattel-red text-sm bg-slate-800 text-slate-200">
                                    <option value="">-- Select --</option>
                                    @foreach (var opt in JigTypeOptions) { <option value="@opt">@opt</option> }
                                </select>
                            </div>
                            <div>
                                <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("กระบวนการ (Process)", "Process")</label>
                                <select @bind="EditingJig.Process" class="w-full px-2 py-1 border border-slate-700 rounded focus:border-mattel-red text-sm bg-slate-800 text-slate-200">
                                    <option value="">-- Select --</option>
                                    @foreach (var opt in ProcessOptions) { <option value="@opt">@opt</option> }
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Other References -->
                    <div>
                        <h3 class="text-sm font-bold text-slate-200 mb-2">@Lang.T("ข้อมูลอ้างอิงอื่นๆ", "Other References")</h3>
                        
                        <!-- Part Numbers -->
                        <div class="mb-3">
                            <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("รหัสชิ้นส่วนที่รองรับ (กด Enter เพื่อเพิ่ม)", "Compatible Part Numbers (Press Enter)")</label>
                            <input type="text" value="@NewPartInput" @onchange="OnPartInputChanged" @onkeydown="OnPartKeyDown" onkeypress="return event.keyCode != 13;" placeholder="e.g. P-1234" class="w-full px-2 py-1.5 border border-slate-700 rounded focus:border-mattel-red text-sm bg-slate-900 text-slate-200" autocomplete="off" />
                            @if (CompatiblePartsModel.Any())
                            {
                                <div class="flex flex-wrap gap-2 mt-2">
                                    @foreach (var part in CompatiblePartsModel)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-sm font-semibold bg-slate-900 text-slate-300 border border-slate-700 shadow-xl">
                                            @part.PartNumber
                                            <button type="button" @onclick="() => OnRemovePartNumber.InvokeAsync(part.PartNumber)" class="ml-2 text-slate-400 hover:text-red-500 transition-colors">✕</button>
                                        </span>
                                    }
                                </div>
                            }
                        </div>

                        <div class="grid grid-cols-2 gap-x-4 gap-y-2">
                            <div>
                                <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("ตำแหน่งปัจจุบัน", "Locator")</label>
                                <select @bind="EditingJig.LocatorId" class="w-full px-2 py-1.5 border border-slate-700 rounded focus:border-mattel-red text-sm bg-slate-800 text-slate-200">
                                    <option value="">-- @Lang.T("ไม่มีตำแหน่ง", "No Location") --</option>
                                    @foreach (var loc in AllLocators)
                                    {
                                        <option value="@loc.Id">@loc.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-span-1"><label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("เวอร์ชัน (Rev.)", "Rev.")</label><input type="text" @bind="EditingJig.Rev" class="w-full px-2 py-1.5 border border-slate-700 rounded focus:border-mattel-red text-sm bg-slate-900 text-slate-200" /></div>
                        </div>

                        <div class="mt-3 pt-3 border-t border-slate-700">
                            <label class="block text-[10px] font-semibold text-slate-400 mb-1.5 uppercase">@Lang.T("รูปภาพจิ๊ก", "Jig Photo")</label>
                            <div class="flex items-start gap-4">
                                @if (!string.IsNullOrEmpty(ImagePreview))
                                {
                                    <div class="relative group">
                                        <img src="@ImagePreview" alt="Preview" class="w-24 h-24 rounded-xl object-cover border-2 border-slate-700 shadow-xl" />
                                        <button type="button" @onclick="RemoveImage" class="absolute -top-2 -right-2 w-6 h-6 bg-red-900/300 text-white rounded-full text-xs font-bold hover:bg-red-600 shadow-md flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">✕</button>
                                    </div>
                                }
                                else if (!string.IsNullOrEmpty(EditingJig.ImageUrl))
                                {
                                    <div class="relative group">
                                        <img src="@GetImageSrc(EditingJig.ImageUrl)" alt="Current" class="w-24 h-24 rounded-xl object-cover border-2 border-slate-700 shadow-xl" />
                                        <button type="button" @onclick="RemoveImage" class="absolute -top-2 -right-2 w-6 h-6 bg-red-900/300 text-white rounded-full text-xs font-bold hover:bg-red-600 shadow-md flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">✕</button>
                                    </div>
                                }
                                <label class="flex-1 cursor-pointer">
                                    <div class="flex flex-col items-center justify-center py-4 px-3 border-2 border-dashed border-slate-700 rounded-xl hover:border-blue-400 hover:bg-blue-50/50 transition-all">
                                        <svg class="w-8 h-8 text-slate-400 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                                        <span class="text-xs font-medium text-slate-400">@Lang.T("คลิกเพื่อเลือกรูป", "Click to select image")</span>
                                        <span class="text-[10px] text-slate-400 mt-0.5">JPG, PNG, WebP (max 5MB)</span>
                                    </div>
                                    <InputFile class="hidden" OnChange="OnImageSelected" accept=".jpg,.jpeg,.png,.webp" />
                                </label>
                            </div>
                            @if (IsUploadingImage)
                            {
                                <div class="mt-2 text-xs text-blue-600 font-medium flex items-center gap-1">
                                    <span class="inline-block animate-spin h-3 w-3 border-2 border-blue-600 rounded-full border-t-transparent"></span>
                                    @Lang.T("กำลังอัปโหลดรูป...", "Uploading image...")
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <button id="hiddenSubmitBtn" type="submit" class="hidden"></button>
            </EditForm>
        </div>
        
        <div class="p-6 flex justify-end gap-3 bg-slate-900 border-t border-slate-700 rounded-b-2xl shrink-0 w-full z-10">
            <button @onclick="CloseModal" class="px-5 py-2.5 bg-slate-800 border rounded-xl hover:bg-slate-900">@Lang.T("ยกเลิก", "Cancel")</button>
            <button disabled="@IsSubmitting" onclick="document.getElementById('hiddenSubmitBtn').click()" class="px-6 py-2.5 bg-mattel-red text-white rounded-xl hover:bg-mattel-hover">
                @(IsSubmitting ? Lang.T("กำลังบันทึก...", "Saving...") : Lang.T("บันทึกข้อมูล", "Save Jig"))
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public Jig EditingJig { get; set; } = new();
    [Parameter] public bool IsEditMode { get; set; }
    [Parameter] public string ModalError { get; set; } = "";
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public string SmartCodePreview { get; set; } = "";
    [Parameter] public List<string> StepPrintOptions { get; set; } = new();
    [Parameter] public List<string> PartTypeOptions { get; set; } = new();
    [Parameter] public List<string> HeightJigOptions { get; set; } = new();
    [Parameter] public List<string> JigTypeOptions { get; set; } = new();
    [Parameter] public List<string> ProcessOptions { get; set; } = new();
    [Parameter] public List<string> SelectedSteps { get; set; } = new();
    [Parameter] public DateTime? SelectedDate { get; set; }
    [Parameter] public List<PartMaster> CompatiblePartsModel { get; set; } = new();
    [Parameter] public string NewPartInput { get; set; } = "";
    [Parameter] public List<Locator> AllLocators { get; set; } = new();
    [Parameter] public string ImagePreview { get; set; } = "";
    [Parameter] public bool IsUploadingImage { get; set; }

    [Parameter] public EventCallback SaveJig { get; set; }
    [Parameter] public EventCallback CloseModal { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> OnAddStep { get; set; }
    [Parameter] public EventCallback<string> OnRemoveStep { get; set; }
    [Parameter] public EventCallback<string> OnPartInputChangedEvent { get; set; }
    [Parameter] public EventCallback<KeyboardEventArgs> OnPartKeyDown { get; set; }
    [Parameter] public EventCallback<string> OnRemovePartNumber { get; set; }
    [Parameter] public EventCallback<InputFileChangeEventArgs> OnImageSelected { get; set; }
    [Parameter] public EventCallback RemoveImage { get; set; }
    [Parameter] public EventCallback<DateTime?> SelectedDateChanged { get; set; }
    
    private void OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var d))
        {
            SelectedDateChanged.InvokeAsync(d);
        }
        else
        {
            SelectedDateChanged.InvokeAsync(null);
        }
    }

    private void OnPartInputChanged(ChangeEventArgs e)
    {
        OnPartInputChangedEvent.InvokeAsync(e.Value?.ToString() ?? "");
    }

    private string GetImageSrc(string imageUrl)
    {
        if (string.IsNullOrEmpty(imageUrl)) return "";
        if (imageUrl.StartsWith("/")) return $"http://localhost:5105{imageUrl}";
        return imageUrl;
    }
}
