@using shared.Models
@inject LanguageService Lang

<div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center p-4" @onclick="OnCancel">
    <div class="relative w-full max-w-md bg-slate-800 rounded-2xl shadow-xl p-6 border border-slate-700 text-left" @onclick:stopPropagation="true">

        <h3 class="text-2xl font-bold text-slate-100 mb-6">@Lang.T(IsEditMode ? "แก้ไขข้อมูลผู้ใช้งาน" : "เพิ่มผู้ใช้งานใหม่", IsEditMode ? "Edit User" : "Add New User")</h3>

        <div class="space-y-4 mb-6">
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("รหัสพนักงาน", "Employee ID")</label>
                <input type="text" @bind="EditingUser.EmployeeId" disabled="@IsEditMode" class="block w-full border border-slate-700 rounded-lg px-4 py-2 focus:ring-mattel-red focus:border-mattel-red sm:text-sm bg-slate-900 text-slate-200 disabled:bg-slate-800 disabled:text-slate-500" placeholder="@Lang.T("เช่น 9005", "e.g. 9005")" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("ชื่อ-นามสกุล", "Full Name")</label>
                <input type="text" @bind="EditingUser.Name" class="block w-full border border-slate-700 rounded-lg px-4 py-2 focus:ring-mattel-red focus:border-mattel-red sm:text-sm bg-slate-900 text-slate-200" placeholder="@Lang.T("เช่น สมชาย รักเรียน", "e.g. John Doe")" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("ตำแหน่ง / สิทธิ์", "Role")</label>
                <select @bind="EditingUser.Role" class="block w-full border border-slate-700 rounded-lg px-4 py-2 focus:ring-mattel-red focus:border-mattel-red sm:text-sm bg-slate-900 text-slate-200">
                    <option value="Admin">@Lang.T("ผู้ดูแลระบบ (Admin)", "Admin")</option>
                    <option value="Engineer">@Lang.T("วิศวกร (Engineer)", "Engineer")</option>
                    <option value="ProdLead">@Lang.T("หัวหน้าฝ่ายผลิต (ProdLead)", "Production Lead")</option>
                    <option value="Operator">@Lang.T("พนักงานปฏิบัติการ (Operator)", "Operator")</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("รหัสผ่าน", "Password")</label>
                <input type="text" @bind="EditingUser.Password" class="block w-full border border-slate-700 rounded-lg px-4 py-2 focus:ring-mattel-red focus:border-mattel-red sm:text-sm bg-slate-900 text-slate-200" placeholder="@Lang.T("พิมพ์รหัสผ่านที่นี่", "Any default password")" />
            </div>
            
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="text-red-500 text-sm font-medium mt-2">@ErrorMessage</div>
            }
        </div>

        <div class="flex justify-end space-x-3 pt-4 border-t border-slate-700">
            <button @onclick="OnCancel" class="px-4 py-2 bg-slate-800 text-slate-300 border border-slate-700 font-medium rounded-lg hover:bg-slate-900 transition-colors text-sm">@Lang.T("ยกเลิก", "Cancel")</button>
            <button @onclick="OnSave" class="px-4 py-2 bg-mattel-red text-white font-medium rounded-lg hover:bg-mattel-hover transition-colors text-sm">@Lang.T("บันทึกการเปลี่ยนแปลง", "Save Changes")</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public bool IsEditMode { get; set; }
    [Parameter] public UserAccount EditingUser { get; set; } = new();
    [Parameter] public string ErrorMessage { get; set; } = "";
    
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }

    protected override void OnInitialized()
    {
        Lang.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Lang.OnChange -= StateHasChanged;
    }
}
