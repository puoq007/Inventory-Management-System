@page "/history"
@inject frontend.Services.AuthService Auth
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject LanguageService Lang
@implements IDisposable
@using shared.Models
@using System.Text
@using System.Net.Http.Json

<PageTitle>Transaction History - Inventory</PageTitle>

<div class="mb-6 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 mb-2">@Lang.T("ประวัติการใช้งาน", "History")</h1>
        <p class="text-slate-500">@Lang.T("ดูรายการเบิกและคืนจิกย้อนหลัง", "View recent jig check-outs and returns")</p>
    </div>
    @if (!string.IsNullOrEmpty(_role))
    {
        <div class="flex items-center space-x-4">
            <button @onclick="ExportCsv" class="px-4 py-2 border border-slate-300 rounded-xl text-sm font-medium text-slate-700 bg-white hover:bg-slate-50 transition-colors flex items-center">
                <svg class="w-4 h-4 mr-2 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                @Lang.T("ส่งออก CSV", "Export CSV")
            </button>
            <div class="text-sm font-medium text-slate-500 bg-slate-100 px-3 py-1.5 rounded-full">
                Role: <span class="text-slate-800">@_role</span>
            </div>
        </div>
    }
</div>

@if (_isLoading)
{
    <div class="flex items-center justify-center py-12">
        <div class="text-slate-500 font-medium tracking-wide">@Lang.T("กำลังโหลดข้อมูลประวัติ...", "Loading history...")</div>
    </div>
}
else if (!_hasTransactions)
{
    <div class="flex flex-col items-center justify-center py-16 text-slate-500 bg-white rounded-2xl shadow-sm border border-slate-100">
        <svg class="w-16 h-16 mb-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div class="text-lg font-medium">@Lang.T("ยังไม่พบรายการ", "No Transactions Yet")</div>
        <p class="text-sm mt-1 text-slate-400">@Lang.T("เบิกหรือคืนจิกที่หน้าสถานะปัจจุบัน เพื่อดูรายการย้อนหลังที่นี่", "Borrow or return a jig on the Current Status page to see history here.")</p>
        <a href="/current-status" class="mt-6 px-4 py-2 bg-slate-100 text-slate-700 font-medium rounded-lg hover:bg-slate-200 transition-colors">
            @Lang.T("ไปที่หน้าสถานะปัจจุบัน", "Go to Current Status")
        </a>
    </div>
}
else
{
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 mb-8">
        <div class="flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <label for="search" class="block text-sm font-medium text-slate-700 mb-1">@Lang.T("ค้นหาผู้ใช้งาน, การดำเนินการ หรือ รหัสจิก", "Search User, Action, or Jig ID")</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                    <input type="text" id="search" @bind="_searchQuery" @bind:event="oninput" @onkeyup="FilterData"
                           class="block w-full pl-10 pr-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="@Lang.T("ตัวอย่าง: สมชาย, เบิกออก, J003", "e.g. John Doe, Borrowed, J003")" />
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">@Lang.T("วันเวลา", "Date & Time")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">@Lang.T("รหัสจิก", "Jig ID")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">@Lang.T("การดำเนินการ", "Action")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">@Lang.T("ผู้ใช้งาน", "User")</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-200">
                    @foreach (var txn in _displayTransactions ?? Enumerable.Empty<TransactionRow>())
                    {
                        var jig = _allJigs.FirstOrDefault(j => string.Equals(j.Id, txn.JigId, StringComparison.OrdinalIgnoreCase));
                        var spec = jig != null ? _allSpecs.FirstOrDefault(s => s.Id == jig.SpecId) : null;
                        var specName = spec?.Name ?? "Unknown";

                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                <div class="font-medium text-slate-700">@txn.Timestamp.ToString("MMM dd, yyyy")</div>
                                <div class="text-xs text-slate-400">@txn.Timestamp.ToString("HH:mm:ss")</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="font-mono text-sm font-semibold text-slate-900 border border-slate-200 bg-slate-100 px-2 py-1 rounded mr-2">@txn.JigId</span>
                                <span class="text-xs text-slate-500">(@specName)</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if (txn.Action == "CheckOut")
                                {
                                    <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800 border border-blue-200">
                                        @Lang.T("เบิกออก", "Borrowed")
                                    </span>
                                }
                                else if (txn.Action == "CheckIn")
                                {
                                    <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-emerald-100 text-emerald-800 border border-emerald-200">
                                        @Lang.T("คืนเข้าตู้", "Returned")
                                    </span>
                                }
                                else if (txn.Action == "ForceCheckIn")
                                {
                                    <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-indigo-100 text-indigo-800 border border-indigo-200">
                                        @Lang.T("บังคับคืน", "Force Returned")
                                    </span>
                                }
                                else if (txn.Action == "ReportIssue")
                                {
                                    <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-amber-100 text-amber-800 border border-amber-200">
                                        @Lang.T("แจ้งพบปัญหา", "Reported Issue")
                                    </span>
                                }
                                else if (txn.Action == "Scrapped")
                                {
                                    <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800 border border-red-200">
                                        @Lang.T("จำหน่ายออก", "Scrapped")
                                    </span>
                                }
                                else
                                {
                                    <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-slate-100 text-slate-800 border border-slate-200">
                                        @txn.Action
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900 font-medium">
                                <div class="flex items-center">
                                    <div class="w-6 h-6 rounded bg-indigo-100 text-indigo-700 flex items-center justify-center text-xs font-bold mr-2">
                                        @(string.IsNullOrEmpty(txn.User) ? "?" : txn.User.Substring(0, 1).ToUpper())
                                    </div>
                                    @txn.User
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private string _role = "";
    private bool _isLoading = true;
    private string _searchQuery = "";
    private IEnumerable<TransactionRow>? _displayTransactions;
    private bool _hasTransactions = false;
    private List<PhysicalJig> _allJigs = new();
    private List<JigSpec> _allSpecs = new();
    private List<TransactionRow> _allTransactions = new();

    protected override void OnInitialized()
    {
        Lang.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Lang.OnChange -= StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var auth = await Auth.GetAuthAsync();
            _role = auth.Role ?? "";

            if (string.IsNullOrEmpty(_role) || _role == "Guest")
            {
                // Guests shouldn't see history
                NavManager.NavigateTo("/");
                return;
            }

            await LoadData();
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        try
        {
            var txnsTask = Http.GetFromJsonAsync<List<TransactionRow>>("api/transactions");
            var jigsTask = Http.GetFromJsonAsync<List<PhysicalJig>>("api/physicaljigs");
            var specsTask = Http.GetFromJsonAsync<List<JigSpec>>("api/jigspecs");

            await Task.WhenAll(txnsTask, jigsTask, specsTask);

            _allTransactions = await txnsTask ?? new List<TransactionRow>();
            _allJigs = await jigsTask ?? new List<PhysicalJig>();
            _allSpecs = await specsTask ?? new List<JigSpec>();

            FilterData();
        }
        catch (Exception)
        {
            // Handle error minimally
        }
    }

    private void FilterData()
    {
        _hasTransactions = _allTransactions.Any();
        
        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _displayTransactions = _allTransactions.Take(200).ToList();
            return;
        }

        var lowerQuery = _searchQuery.ToLowerInvariant();
        _displayTransactions = _allTransactions.Where(t => 
            t.JigId.ToLowerInvariant().Contains(lowerQuery) ||
            t.Action.ToLowerInvariant().Contains(lowerQuery) ||
            t.User.ToLowerInvariant().Contains(lowerQuery)
        ).ToList();
    }

    private async Task ExportCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Timestamp,JigId,SpecName,Action,User");

        foreach (var txn in _allTransactions)
        {
            var jig = _allJigs.FirstOrDefault(j => string.Equals(j.Id, txn.JigId, StringComparison.OrdinalIgnoreCase));
            var spec = jig != null ? _allSpecs.FirstOrDefault(s => s.Id == jig.SpecId) : null;
            var specName = spec?.Name ?? "Unknown";

            var timeStr = txn.Timestamp.ToString("yyyy-MM-dd HH:mm:ss");
            sb.AppendLine($"{timeStr},{txn.JigId},{specName},{txn.Action},{txn.User}");
        }

        var csvContent = sb.ToString();
        var fileName = $"history_export_{DateTime.Now.ToString("yyyyMMdd_HHmmss")}.csv";
        
        await JSRuntime.InvokeVoidAsync("downloadTextFile", fileName, csvContent);
    }
}
