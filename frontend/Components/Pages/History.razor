@page "/history"
@inject frontend.Services.AuthService Auth
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject LanguageService Lang
@implements IDisposable
@using shared.Models
@using System.Text
@using System.Net.Http.Json
@using frontend.Components.Shared

<PageTitle>@Lang.T("ประวัติการใช้งาน | คลัง", "History | Inventory")</PageTitle>

<div class="mb-6 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-100 mb-2">@Lang.T("ประวัติการใช้งาน", "History")</h1>
        <p class="text-slate-400">@Lang.T("ดูรายการเบิกและคืนจิกย้อนหลัง", "View recent jig check-outs and returns")</p>
    </div>
    @if (!string.IsNullOrEmpty(_role))
    {
        <div class="flex flex-wrap items-end gap-3">
            <div>
                <label class="block text-xs font-semibold text-slate-400 mb-1">@Lang.T("วันเริ่มต้น", "From Date")</label>
                <div class="relative cursor-pointer" @onclick='() => OpenDatePicker("dateFrom")'>
                    <div class="flex items-center gap-2 bg-slate-900 border border-slate-700 rounded-xl px-3 py-2.5 text-sm text-slate-200 min-w-[150px] select-none hover:border-mattel-red transition-all">
                        <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        <span class="@(_exportDateFrom == null ? "text-slate-500" : "text-slate-200")">
                            @(_exportDateFrom == null ? Lang.T("วว/ดด/ปปปป", "DD/MM/YYYY") : FormatDateDisplay(_exportDateFrom.Value))
                        </span>
                    </div>
                    <input id="dateFrom" type="date" @bind="_exportDateFrom"
                           class="absolute inset-0 opacity-0 cursor-pointer w-full h-full" />
                </div>
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 mb-1">@Lang.T("วันสิ้นสุด", "To Date")</label>
                <div class="relative cursor-pointer" @onclick='() => OpenDatePicker("dateTo")'>
                    <div class="flex items-center gap-2 bg-slate-900 border border-slate-700 rounded-xl px-3 py-2.5 text-sm text-slate-200 min-w-[150px] select-none hover:border-mattel-red transition-all">
                        <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        <span class="@(_exportDateTo == null ? "text-slate-500" : "text-slate-200")">
                            @(_exportDateTo == null ? Lang.T("วว/ดด/ปปปป", "DD/MM/YYYY") : FormatDateDisplay(_exportDateTo.Value))
                        </span>
                    </div>
                    <input id="dateTo" type="date" @bind="_exportDateTo"
                           class="absolute inset-0 opacity-0 cursor-pointer w-full h-full" />
                </div>
            </div>
            <button @onclick="ExportPdf" class="px-4 py-2.5 border border-slate-700 rounded-xl text-sm font-medium text-slate-300 bg-slate-800 hover:bg-slate-700 transition-colors flex items-center gap-2">
                <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                @Lang.T("ส่งออก PDF", "Export PDF")
            </button>
        </div>
    }
</div>

@if (_isLoading)
{
    <div class="flex items-center justify-center py-12">
        <div class="text-slate-400 font-medium tracking-wide">@Lang.T("กำลังโหลดข้อมูลประวัติ...", "Loading history...")</div>
    </div>
}
else if (!_hasTransactions)
{
    <div class="flex flex-col items-center justify-center py-16 text-slate-400 bg-slate-800 rounded-2xl shadow-xl border border-slate-700">
        <svg class="w-16 h-16 mb-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div class="text-lg font-medium text-slate-100">@Lang.T("ยังไม่พบรายการ", "No Transactions Yet")</div>
        <p class="text-sm mt-1 text-slate-500">@Lang.T("เบิกหรือคืนจิกที่หน้าสถานะปัจจุบัน เพื่อดูรายการย้อนหลังที่นี่", "Borrow or return a jig on the Current Status page to see history here.")</p>
        <a href="/current-status" class="mt-6 px-4 py-2 bg-slate-900 text-slate-300 font-medium rounded-lg hover:bg-slate-700 transition-colors border border-slate-700">
            @Lang.T("ไปที่หน้าสถานะปัจจุบัน", "Go to Current Status")
        </a>
    </div>
}
else
{
    <div class="bg-slate-800 p-6 rounded-2xl shadow-xl border border-slate-700 mb-8">
        <div class="flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <label for="search" class="block text-sm font-medium text-slate-200 mb-1">@Lang.T("ค้นหาผู้ใช้งาน, การดำเนินการ หรือ รหัสจิก", "Search User, Action, or Jig ID")</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                    <input type="text" id="search" @bind="_searchQuery" @bind:event="oninput" @onkeyup="FilterData"
                           class="block w-full pl-10 pr-3 py-2 bg-slate-900 border border-slate-700 text-slate-200 rounded-lg focus:ring-mattel-red focus:border-mattel-red sm:text-sm outline-none" placeholder="@Lang.T("ตัวอย่าง: สมชาย, เบิกออก, J003", "e.g. John Doe, Borrowed, J003")" />
                </div>
            </div>
            <div class="flex items-end gap-3 shrink-0">
                <PageSizeSelector @bind-PageSize="_pageSize" OnChanged="FilterData" />
            </div>
        </div>
    </div>

    <div class="bg-slate-800 rounded-2xl shadow-xl border border-slate-700 max-w-full relative">
        <div class="block w-full overflow-x-auto min-h-[300px]">
            <table class="min-w-full divide-y divide-slate-700">
                <thead class="bg-slate-900">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">@Lang.T("วันเวลา", "Date & Time")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">@Lang.T("รหัสจิก", "Jig ID")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider relative cursor-pointer group select-none whitespace-nowrap min-w-[200px]" @onclick="ToggleActionFilter">
                            <div class="flex items-center gap-2 transition-colors @(_actionFilter != "All" ? "text-slate-100" : "text-slate-400 hover:text-slate-200")">
                                <span class="tracking-widest">@Lang.T("การดำเนินการ", "Action")@(_actionFilter != "All" ? $": {Lang.T(GetActionThai(_actionFilter), _actionFilter)}" : "")</span>
                                <div class='flex items-center justify-center w-5 h-5 rounded-full transition-all @(_showActionFilter ? "bg-slate-700 rotate-180" : "group-hover:bg-slate-800")'>
                                    <svg class='w-3.5 h-3.5 @(_actionFilter != "All" ? "text-mattel-red" : "text-slate-500")' fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                                @if (_actionFilter != "All") { <span class="flex h-2 w-2 rounded-full bg-mattel-red animate-pulse shadow-[0_0_8px_rgba(238,0,36,0.5)]"></span> }
                            </div>
                            @if (_showActionFilter)
                            {
                                <div class="absolute left-6 top-full z-20 mt-2 w-56 bg-slate-800 rounded-2xl shadow-xl border border-slate-700 overflow-hidden" @onclick:stopPropagation>
                                    <div class="flex items-center justify-between px-4 py-2.5 bg-slate-900/50 border-b border-slate-700">
                                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Filter Action</span>
                                        @if (_actionFilter != "All") { <button @onclick='() => SetActionFilter("All")' class="text-[10px] font-bold text-mattel-red">RESET</button> }
                                    </div>
                                    <div class="py-1.5 max-h-64 overflow-y-auto">
                                        @foreach (var opt in (new[] { "All", "CheckOut", "Transfer", "CheckIn", "CheckInToCleaning", "ReturnToStore", "ReportIssue", "Scrapped" }))
                                        {
                                            <button @onclick="() => SetActionFilter(opt)" class='flex items-center justify-between w-full px-4 py-2 text-xs text-left transition-all @(_actionFilter == opt ? "bg-slate-700 text-mattel-red font-bold" : "text-slate-300 hover:bg-slate-700")'>
                                                <span>@(opt == "All" ? Lang.T("ทั้งหมด", "All Actions") : Lang.T(GetActionThai(opt), opt))</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider relative cursor-pointer group select-none whitespace-nowrap min-w-[200px]" @onclick="ToggleRoleFilter">
                            <div class="flex items-center gap-2 transition-colors @(_roleFilter != "All" ? "text-slate-100" : "text-slate-400 hover:text-slate-200")">
                                <span class="tracking-widest">@Lang.T("ผู้ใช้งาน", "User")@(_roleFilter != "All" ? $": {_roleFilter}" : "")</span>
                                <div class='flex items-center justify-center w-5 h-5 rounded-full transition-all @(_showRoleFilter ? "bg-slate-700 rotate-180" : "group-hover:bg-slate-800")'>
                                    <svg class='w-3.5 h-3.5 @(_roleFilter != "All" ? "text-mattel-red" : "text-slate-500")' fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                                @if (_roleFilter != "All") { <span class="flex h-2 w-2 rounded-full bg-mattel-red animate-pulse shadow-[0_0_8px_rgba(238,0,36,0.5)]"></span> }
                            </div>
                            @if (_showRoleFilter)
                            {
                                <div class="absolute left-6 top-full z-20 mt-2 w-56 bg-slate-800 rounded-2xl shadow-xl border border-slate-700 overflow-hidden" @onclick:stopPropagation>
                                    <div class="flex items-center justify-between px-4 py-2.5 bg-slate-900/50 border-b border-slate-700">
                                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Filter Role</span>
                                        @if (_roleFilter != "All") { <button @onclick='() => SetRoleFilter("All")' class="text-[10px] font-bold text-mattel-red">RESET</button> }
                                    </div>
                                    <div class="py-1.5 max-h-64 overflow-y-auto">
                                        <button @onclick='() => SetRoleFilter("All")' class='flex items-center w-full px-4 py-2 text-xs text-left transition-all @(_roleFilter == "All" ? "bg-slate-700 text-mattel-red font-bold" : "text-slate-300 hover:bg-slate-700")'>
                                            @Lang.T("ทุกตำแหน่ง", "All Roles")
                                        </button>
                                        @foreach (var r in new[] { "Admin", "Engineer", "ProdLead", "Operator", "Unknown" })
                                        {
                                            <button @onclick="() => SetRoleFilter(r)" class='flex items-center w-full px-4 py-2 text-xs text-left transition-all @(_roleFilter == r ? "bg-slate-700 text-mattel-red font-bold" : "text-slate-300 hover:bg-slate-700")'>
                                                @r
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </th>
                    </tr>
                </thead>
                <tbody class="bg-slate-800 divide-y divide-slate-700">
                    @foreach (var txn in _displayTransactions ?? Enumerable.Empty<TransactionRow>())
                    {
                        var jig = _allJigs.FirstOrDefault(j => j.Uid == txn.JigUid);
                        var jigIdDisplay = jig?.Id ?? txn.JigUid;
                        var specName = jig?.SmartCodeName ?? "Unknown";

                        <tr class="hover:bg-slate-700 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-400">
                                <div class="font-medium text-slate-200">@GetFormattedDate(txn.Timestamp)</div>
                                <div class="text-xs text-slate-500">@txn.Timestamp.ToString("HH:mm:ss")</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="font-mono text-sm font-semibold text-slate-100 border border-slate-700 bg-slate-900 px-2 py-1 rounded mr-2">@jigIdDisplay</span>
                                <span class="text-xs text-slate-400">(@specName)</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-semibold rounded-full border @(txn.Action == "CheckOut" ? "bg-blue-900/40 text-blue-400 border-blue-900/40" :
                                                                          txn.Action == "CheckIn" ? "bg-emerald-900/40 text-emerald-400 border-emerald-900/40" :
                                                                          txn.Action == "CheckInToCleaning" ? "bg-amber-900/40 text-amber-400 border-amber-900/40" :
                                                                          txn.Action == "ReturnToStore" ? "bg-emerald-900/40 text-emerald-400 border-emerald-900/40" :
                                                                          txn.Action == "ReportIssue" ? "bg-red-900/40 text-red-400 border-red-900/40" :
                                                                          txn.Action == "Transfer" ? "bg-purple-900/40 text-purple-400 border-purple-900/40" :
                                                                          "bg-slate-800 text-slate-300 border-slate-700")">
                                    @Lang.T(GetActionThai(txn.Action), txn.Action)
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-100 font-medium">
                                <div class="flex items-center">
                                    <div class="w-6 h-6 rounded bg-indigo-900/50 text-indigo-400 flex items-center justify-center text-xs font-bold mr-2">
                                        @(string.IsNullOrEmpty(txn.User) ? "?" : txn.User.Substring(0, 1).ToUpper())
                                    </div>
                                    @txn.User
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <Pagination TotalItems="@_totalItems" @bind-CurrentPage="_currentPage" PageSize="@_pageSize" OnChanged="FilterData" />
    </div>
}

@code {
    private string _role = "";
    private bool _isLoading = true;
    private string _searchQuery = "";
    private IEnumerable<TransactionRow>? _displayTransactions;
    private int _currentPage = 1;
    private int _pageSize = 10;
    private int _totalItems = 0;
    private bool _hasTransactions = false;
    private List<TransactionRow> _allTransactions = new();
    private List<Jig> _allJigs = new();
    private List<UserAccount> _allUsers = new();

    private string _actionFilter = "All";
    private string _roleFilter = "All";
    private bool _showActionFilter = false;
    private bool _showRoleFilter = false;

    private DateTime? _exportDateFrom = null;
    private DateTime? _exportDateTo = null;

    private void ToggleActionFilter() { _showActionFilter = !_showActionFilter; _showRoleFilter = false; }
    private void ToggleRoleFilter() { _showRoleFilter = !_showRoleFilter; _showActionFilter = false; }
    
    private void SetActionFilter(string val) { _actionFilter = val; _showActionFilter = false; FilterData(); }
    private void SetRoleFilter(string val) { _roleFilter = val; _showRoleFilter = false; FilterData(); }

    private async Task OpenDatePicker(string id)
    {
        await JSRuntime.InvokeVoidAsync("eval", $"document.getElementById('{id}').showPicker()");
    }

    private string FormatDateDisplay(DateTime dt)
    {
        if (Lang.Current == "TH")
        {
            string[] thaiMonths = { "", "ม.ค.", "ก.พ.", "มี.ค.", "เม.ย.", "พ.ค.", "มิ.ย.", "ก.ค.", "ส.ค.", "ก.ย.", "ต.ค.", "พ.ย.", "ธ.ค." };
            return $"{dt.Day:D2} {thaiMonths[dt.Month]} {dt.Year + 543}";
        }
        return $"{dt.Day:D2}/{dt.Month:D2}/{dt.Year}";
    }

    protected override void OnInitialized()
    {
        Lang.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Lang.OnChange -= StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var auth = await Auth.GetAuthAsync();
            _role = auth.Role ?? "";

            if (string.IsNullOrEmpty(_role) || _role == "Guest")
            {
                // Guests shouldn't see history
                NavManager.NavigateTo("/");
                return;
            }

            await LoadData();
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        try
        {
            var txnsTask = Http.GetFromJsonAsync<List<TransactionRow>>("api/transactions");
            var jigsTask = Http.GetFromJsonAsync<List<Jig>>("api/jigs");
            var usersTask = Http.GetFromJsonAsync<List<UserAccount>>("api/users");

            await Task.WhenAll(txnsTask, jigsTask, usersTask);

            _allTransactions = await txnsTask ?? new List<TransactionRow>();
            _allJigs = await jigsTask ?? new List<Jig>();
            _allUsers = await usersTask ?? new List<UserAccount>();

            FilterData();
        }
        catch (Exception)
        {
            // Handle error minimally
        }
    }

    private void FilterData()
    {
        _hasTransactions = _allTransactions.Any();
        
        var query = _allTransactions.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            var lowerQuery = _searchQuery.ToLowerInvariant();
            query = query.Where(t => 
            {
                var jig = _allJigs.FirstOrDefault(j => j.Uid == t.JigUid);
                return (jig?.Id?.ToLowerInvariant().Contains(lowerQuery) == true) ||
                       (t.JigUid?.ToLowerInvariant().Contains(lowerQuery) == true) ||
                       t.Action.ToLowerInvariant().Contains(lowerQuery) ||
                       t.User.ToLowerInvariant().Contains(lowerQuery);
            });
        }

        if (_actionFilter != "All")
            query = query.Where(t => t.Action == _actionFilter);
            
        if (_roleFilter != "All")
            query = query.Where(t => {
                var userAcct = _allUsers.FirstOrDefault(u => u.Name == t.User);
                var r = userAcct != null ? userAcct.Role : "Unknown";
                return r == _roleFilter;
            });

        _totalItems = query.Count();

        // Adjust current page if it's out of bounds after filtering
        int maxPage = (int)Math.Ceiling(_totalItems / (double)_pageSize);
        if (maxPage == 0) maxPage = 1;
        if (_currentPage > maxPage) _currentPage = maxPage;

        _displayTransactions = query.Skip((_currentPage - 1) * _pageSize).Take(_pageSize).ToList();
    }

    private string GetActionThai(string action) => action switch {
        "CheckOut" => "เบิกออก",
        "CheckIn" => "คืนเข้าตู้",
        "CheckInToCleaning" => "ส่งล้าง",
        "ReturnToStore" => "เก็บเข้าคลัง",
        "ReportIssue" => "แจ้งพบปัญหา",
        "Scrapped" => "จำหน่ายออก",
        "Transfer" => "โอนย้าย",
        _ => action
    };

    private async Task ExportPdf()
    {
        var isThai = Lang.Current == "TH";
        var date = DateTime.Now.ToString("dd/MM/yyyy HH:mm");

        var exportData = _allTransactions.AsEnumerable();

        if (_exportDateFrom.HasValue)
            exportData = exportData.Where(t => t.Timestamp.Date >= _exportDateFrom.Value.Date);
        if (_exportDateTo.HasValue)
            exportData = exportData.Where(t => t.Timestamp.Date <= _exportDateTo.Value.Date);

        var exportList = exportData.ToList();

        var dateRangeLabel = "";
        if (_exportDateFrom.HasValue || _exportDateTo.HasValue)
        {
            var from = _exportDateFrom.HasValue ? FormatDateDisplay(_exportDateFrom.Value) : "...";
            var to   = _exportDateTo.HasValue   ? FormatDateDisplay(_exportDateTo.Value)   : "...";
            var rangeTitle = isThai ? "ช่วงวันที่" : "Date Range";
            dateRangeLabel = $"<div>{rangeTitle}: {from} – {to}</div>";
        }

        var rows = string.Join("", exportList.Select(txn => {
            var jig      = _allJigs.FirstOrDefault(j => j.Uid == txn.JigUid);
            var jigId    = jig?.Id ?? txn.JigUid;
            var specName = jig?.SmartCodeName ?? (isThai ? "ไม่ทราบ" : "Unknown");
            var timeStr  = GetFormattedDate(txn.Timestamp) + " " + txn.Timestamp.ToString("HH:mm");
            var actionLabel = isThai ? GetActionThai(txn.Action) : txn.Action;
            var badgeClass = txn.Action switch {
                "CheckOut"          => "badge-blue",
                "CheckIn"           => "badge-green",
                "ReturnToStore"     => "badge-green",
                "CheckInToCleaning" => "badge-amber",
                "ReportIssue"       => "badge-red",
                "Transfer"          => "badge-purple",
                _                   => "badge-gray"
            };
            return $"<tr><td>{timeStr}</td><td><strong>{jigId}</strong></td><td>{specName}</td><td><span class='badge {badgeClass}'>{actionLabel}</span></td><td>{txn.User}</td></tr>";
        }));

        // Localized labels
        var title       = isThai ? "รายงานประวัติการใช้งาน" : "Transaction History Report";
        var generated   = isThai ? "สร้างเมื่อ" : "Generated";
        var totalRec    = isThai ? "จำนวนรายการ" : "Total Records";
        var colDate     = isThai ? "วันเวลา"     : "Timestamp";
        var colJigId    = isThai ? "รหัสจิก"     : "Jig ID";
        var colSpec     = isThai ? "ชื่อ Smart Code" : "Smart Code Name";
        var colAction   = isThai ? "การดำเนินการ" : "Action";
        var colUser     = isThai ? "ผู้ใช้งาน"   : "User";
        var footer      = isThai
            ? $"แมทเทล แบงคอก จำกัด &nbsp;|&nbsp; ระบบจัดการจิก &nbsp;|&nbsp; {date}"
            : $"Mattel Bangkok Limited &nbsp;|&nbsp; Jig Inventory Management System &nbsp;|&nbsp; {date}";

        var html = $@"
<div class='pdf-header'>
  <div class='logo-text'>MATTEL</div>
  <div class='meta'>
