@page "/admin/locators"
@inject frontend.Services.AuthService Auth
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@using shared.Models
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using Net.Codecrete.QrCodeGenerator
<PageTitle>Admin - Locators | Inventory</PageTitle>

<div class="px-4 py-4 md:px-6 md:py-6 pb-20">
    <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 mb-1">Locators</h1>
            <p class="text-slate-500 text-sm">Manage storage locations for physical jigs.</p>
        </div>
        <div class="flex flex-wrap gap-2">
            <div class="flex gap-2">
                <label class="inline-flex items-center px-4 py-2 bg-green-600 border border-transparent rounded-lg font-bold text-xs text-white uppercase tracking-widest hover:bg-green-700 active:bg-green-800 transition cursor-pointer mb-0">
                    <InputFile OnChange="ImportExcel" class="hidden" accept=".xlsx,.xls" />
                    <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                    Import Excel
                </label>
                <label class="inline-flex items-center px-4 py-2 bg-teal-600 border border-transparent rounded-lg font-bold text-xs text-white uppercase tracking-widest hover:bg-teal-700 active:bg-teal-800 transition cursor-pointer mb-0">
                    <InputFile OnChange="ImportExcel" class="hidden" accept=".csv" />
                    <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                    Import CSV
                </label>
                <button @onclick="OpenAddModal" class="inline-flex items-center px-4 py-2 bg-blue-600 border border-transparent rounded-lg font-bold text-xs text-white uppercase tracking-widest hover:bg-blue-700 active:bg-blue-800 transition gap-2">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                    New Locator
                </button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage) && !_showModal)
{
    <div class="mb-4 p-3 bg-red-50 text-red-700 rounded-lg text-sm border border-red-100">@_errorMessage</div>
}

@if (_isLoading)
{
    <div class="flex justify-center items-center py-12">
        <div class="text-slate-500 font-medium">Loading locators...</div>
    </div>
}
else
{
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 mb-8 mx-4 md:mx-6 mt-[-1rem]">
        <div class="flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <label for="search" class="block text-sm font-medium text-slate-700 mb-1">Search Keyword</label>
                <form class="relative" @onsubmit="FilterData" @onsubmit:preventDefault="true">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                    <input type="text" id="search" @bind="_searchQuery" @bind:event="oninput" @onkeyup="FilterData"
                           class="block w-full pl-10 pr-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="e.g. ZONE-A, Store Room, Cleaning..." />
                </form>
            </div>
            @if (_selectedLocatorIds.Any())
            {
                <div class="flex items-end mb-[2px]">
                    <button @onclick="PrintSelectedQRs" class="px-5 py-2.5 bg-slate-800 text-white font-medium text-sm rounded-lg hover:bg-slate-900 shadow-sm transition-colors flex items-center">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                        Print Selected QR (@_selectedLocatorIds.Count)
                    </button>
                    <button @onclick="() => { _selectedLocatorIds.Clear(); StateHasChanged(); }" class="ml-2 px-5 py-2.5 bg-white border border-slate-300 text-slate-600 font-medium text-sm rounded-lg hover:bg-slate-50 shadow-sm transition-colors flex items-center">
                        Clear
                    </button>
                </div>
            }
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden mb-8 mx-4 md:mx-6">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider w-12 shrink-0">
                            <input type="checkbox" checked="@(_displayLocators.Any() && _displayLocators.All(l => _selectedLocatorIds.Contains(l.Id)))" @onchange="ToggleSelectAll" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500 cursor-pointer" />
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Locator ID / Name</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Zone Type</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Location Details</th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-200">
                    @foreach (var loc in _displayLocators)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <input type="checkbox" checked="@_selectedLocatorIds.Contains(loc.Id)" @onchange="@(e => ToggleSelection(loc.Id, e.Value))" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500 cursor-pointer" />
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm font-bold text-slate-900 font-mono">@loc.Id</div>
                                <div class="text-xs text-slate-500 mt-1">@loc.Name</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if (loc.Type == "Production")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-blue-100 text-blue-800 border border-blue-200">Production</span>
                                }
                                else if (loc.Type == "Cleaning")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-amber-100 text-amber-800 border border-amber-200">Cleaning</span>
                                }
                                else if (loc.Type == "Store")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-100 text-emerald-800 border border-emerald-200">Storage</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-slate-100 text-slate-800 border border-slate-200">@loc.Type</span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if(!string.IsNullOrEmpty(loc.Site)){ <div class="text-sm text-slate-700">Site: @loc.Site</div> }
                                @if(!string.IsNullOrEmpty(loc.Cabinet)){ <div class="text-xs text-slate-500 mt-1">Cabinet: @loc.Cabinet</div> }
                                @if(!string.IsNullOrEmpty(loc.Shelf)){ <div class="text-xs text-slate-500 mt-0.5">Shelf: @loc.Shelf</div> }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <button @onclick="() => PrintQR(loc)" class="text-slate-600 hover:text-slate-900 mr-4 font-semibold px-2 py-1 rounded hover:bg-slate-100 transition-colors" title="Print QR Code">
                                    <svg class="w-4 h-4 inline-block -mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" /></svg>
                                    QR
                                </button>
                                <button @onclick="() => OpenEditModal(loc)" class="text-indigo-600 hover:text-indigo-900 mr-4 text-xs font-semibold px-2 py-1 rounded hover:bg-indigo-50 transition-colors">Edit</button>
                                <button @onclick="() => DeleteLocator(loc)" class="text-red-600 hover:text-red-900 text-xs font-semibold px-2 py-1 rounded hover:bg-red-50 transition-colors">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_showModal)
{
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center p-4">
        <div class="relative w-full max-w-lg bg-white rounded-2xl shadow-xl overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50">
                <h3 class="text-lg font-bold text-slate-900">@(_isEditMode ? "Edit Locator" : "New Locator")</h3>
                <button @onclick="CloseModal" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div class="p-6">
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="mb-4 p-3 bg-red-50 text-red-700 rounded-lg text-sm border border-red-100">
                        @_errorMessage
                    </div>
                }
                
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Locator ID *</label>
                        <input type="text" @bind="_editingLocator.Id" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Name <span class="text-slate-400 font-normal text-xs">(auto-generated from Site/Cabinet/Shelf)</span></label>
                        <div class="w-full px-3 py-2 border border-slate-200 rounded-lg bg-slate-50 text-sm text-slate-500 font-mono">
                            @(_editingLocator.Name.Length > 0 ? _editingLocator.Name : "–")
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Zone Type *</label>
                        <select @bind="_editingLocator.Type" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                            <option value="Production">Production (โซนทำงาน)</option>
                            <option value="Cleaning">Cleaning (โซนล้าง)</option>
                            <option value="Store">Storage (โซนสโต)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Site</label>
                        <input type="text" @bind="_editingLocator.Site" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Cabinet</label>
                        <input type="text" @bind="_editingLocator.Cabinet" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Shelf</label>
                        <input type="text" @bind="_editingLocator.Shelf" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 bg-slate-50 border-t border-slate-100 flex justify-end gap-3">
                <button @onclick="CloseModal" class="px-4 py-2 bg-white border border-slate-300 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50">Cancel</button>
                <button @onclick="SaveLocator" class="px-4 py-2 bg-blue-600 rounded-lg text-sm font-medium text-white hover:bg-blue-700 shadow-sm">Save</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private bool _isImporting = false;
    private bool _showModal = false;
    private bool _isEditMode = false;
    private Locator _editingLocator = new();
    private string? _originalLocatorId = null;
    private string _errorMessage = "";
    private string _searchQuery = "";
    private HashSet<string> _selectedLocatorIds = new();

    private List<Locator> _allLocators = new();
    private List<Locator> _displayLocators = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await Auth.GetAuthAsync();
        if (auth.Role != "Admin" && auth.Role != "Engineer" && auth.Role != "ProdLead")
        {
            NavManager.NavigateTo("/");
            return;
        }

        await LoadData();
        _isLoading = false;
        StateHasChanged();
    }

    private async Task LoadData()
    {
        try
        {
            _allLocators = await Http.GetFromJsonAsync<List<Locator>>("api/locators") ?? new List<Locator>();
            FilterData();
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load locators from API.";
        }
    }

    private void FilterData()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _displayLocators = _allLocators.ToList();
            return;
        }

        var lowerQuery = _searchQuery.ToLowerInvariant();
        _displayLocators = _allLocators.Where(l => 
            (l.Id ?? "").ToLowerInvariant().Contains(lowerQuery) ||
            (l.Site ?? "").ToLowerInvariant().Contains(lowerQuery) ||
            (l.Cabinet ?? "").ToLowerInvariant().Contains(lowerQuery) ||
            (l.Shelf ?? "").ToLowerInvariant().Contains(lowerQuery) ||
            (l.Position ?? "").ToLowerInvariant().Contains(lowerQuery)
        ).ToList();
    }

    private void OpenAddModal()
    {
        _isEditMode = false;
        _originalLocatorId = null;
        _editingLocator = new Locator();
        _errorMessage = "";
        _showModal = true;
    }

    private void OpenEditModal(Locator loc)
    {
        _isEditMode = true;
        _originalLocatorId = loc.Id;
        _editingLocator = new Locator
        {
            Id       = loc.Id,
            Site     = loc.Site,
            Cabinet  = loc.Cabinet,
            Shelf    = loc.Shelf,
            Position = loc.Position,
            Type     = loc.Type
        };
        _errorMessage = "";
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
    }

    private async Task SaveLocator()
    {
        if (string.IsNullOrWhiteSpace(_editingLocator.Id))
        {
            _errorMessage = "Locator ID is required.";
            return;
        }

        HttpResponseMessage response;

        if (_isEditMode)
        {
            // Always use the rename endpoint — it handles both ID-change and field-only updates safely
            response = await Http.PostAsJsonAsync($"api/locators/{_originalLocatorId}/rename", _editingLocator);
        }
        else
        {
            if (_allLocators.Any(l => l.Id == _editingLocator.Id))
            {
                _errorMessage = "A locator with this ID already exists.";
                return;
            }
            response = await Http.PostAsJsonAsync("api/locators", _editingLocator);
        }

        if (response.IsSuccessStatusCode)
        {
            await LoadData();
            _showModal = false;
            _errorMessage = "";
            StateHasChanged();
        }
        else
        {
            var body = await response.Content.ReadAsStringAsync();
            _errorMessage = $"Save failed: {body}";
        }
    }

    private async Task DeleteLocator(Locator loc)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Delete Locator", $"Are you sure you want to delete locator {loc.Id}?", "Yes, delete", "error");
        if (!confirmed) return;

        var response = await Http.DeleteAsync($"api/locators/{loc.Id}");
        if (response.IsSuccessStatusCode)
        {
            _selectedLocatorIds.Remove(loc.Id);
            await LoadData();
            StateHasChanged();
        }
        else
        {
            _errorMessage = "Failed to delete locator from API.";
        }
    }

    private async Task PrintQR(Locator loc)
    {
        var qr = QrCode.EncodeText(loc.Id, QrCode.Ecc.Medium);
        var svgStr = qr.ToSvgString(4, "#000000", "#ffffff");
        var data = new {
            id = loc.Id,
            site = loc.Site,
            cabinet = loc.Cabinet,
            shelf = loc.Shelf,
            type = loc.Type
        };
        await JSRuntime.InvokeVoidAsync("printLocatorQR", svgStr, data);
    }

    private void ToggleSelection(string locId, object? isChecked)
    {
        if (isChecked is bool cb && cb)
            _selectedLocatorIds.Add(locId);
        else
            _selectedLocatorIds.Remove(locId);
            
        StateHasChanged();
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        bool selectAll = (bool)(e.Value ?? false);
        if (selectAll)
        {
            foreach (var loc in _displayLocators) _selectedLocatorIds.Add(loc.Id);
        }
        else
        {
            foreach (var loc in _displayLocators) _selectedLocatorIds.Remove(loc.Id);
        }
        StateHasChanged();
    }

    private async Task PrintSelectedQRs()
    {
        if (!_selectedLocatorIds.Any()) return;

        var qrList = new List<object>();
        foreach (var id in _selectedLocatorIds)
        {
            var loc = _allLocators.FirstOrDefault(l => l.Id == id);
            if (loc == null) continue;
            var qr = QrCode.EncodeText(id, QrCode.Ecc.Medium);
            var svgStr = qr.ToSvgString(4, "#000000", "#ffffff");
            qrList.Add(new {
                svg = svgStr,
                id = id,
                site = loc.Site,
                cabinet = loc.Cabinet,
                shelf = loc.Shelf,
                type = loc.Type
            });
        }

        await JSRuntime.InvokeVoidAsync("printLocatorQRs", qrList);
        _selectedLocatorIds.Clear();
    }

    private class ImportResponse
    {
        public int inserted { get; set; }
        public int updated { get; set; }
        public List<string> errors { get; set; } = new();
    }

    private async Task ImportExcel(InputFileChangeEventArgs e)
    {
        _isImporting = true;
        StateHasChanged();
        
        // Assuming there isn't an ImportLocatorsAsync in the controller yet,
        // Wait, we didn't add Locators upload in UploadController? Actually we only added jig specs and physical jigs.
        // We need to either add it or comment it out for now.
        // Let's call the endpoint, if we implement it.
        try
        {
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(e.File.OpenReadStream(10_000_000));
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(e.File.ContentType);
            content.Add(fileContent, "file", e.File.Name);

            var response = await Http.PostAsync("api/upload/locators", content);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ImportResponse>();
                if (result != null)
                {
                    var msg = $"Import complete: {result.inserted} added, {result.updated} updated.";
                    if (result.errors != null && result.errors.Any())
                    {
                        msg += $"\nErrors:\n{string.Join("\n", result.errors)}";
                        await JSRuntime.InvokeVoidAsync("alert", msg);
                    }
                    else
                    {
                        await JSRuntime.InvokeVoidAsync("alert", msg);
                    }
                }
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Import API failed: {response.StatusCode} (Does the endpoint exist?)");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Import failed: {ex.Message}");
        }
        finally
        {
            _isImporting = false;
            await LoadData();
            StateHasChanged();
        }
    }
}
