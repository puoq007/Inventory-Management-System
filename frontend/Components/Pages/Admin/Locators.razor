@page "/admin/locators"
@* Version 102 (Strict RBAC) *@
@inject frontend.Services.AuthService Auth
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject LanguageService Lang
@implements IDisposable
@using shared.Models
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using Net.Codecrete.QrCodeGenerator
<PageTitle>Locators | Inventory</PageTitle>

<div class="mb-6 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-100 mb-2">@Lang.T("ตำแหน่งจัดเก็บ", "Locators")</h1>
        <p class="text-slate-400">@Lang.T("จัดการตำแหน่งจัดเก็บสำหรับจิกกายภาพ", "Manage storage locations for physical jigs.")</p>
    </div>
    <div class="flex flex-wrap gap-2">
        @if (_currentRole == "Admin" || _currentRole == "ProdLead")
        {
            <label class="px-5 py-2.5 bg-emerald-700 text-white font-medium text-sm rounded-lg hover:bg-emerald-800 shadow-xl transition-colors cursor-pointer flex items-center mb-0">
                <InputFile OnChange="ImportExcel" class="hidden" accept=".xlsx,.xls" />
                <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                @if(_isImporting) { <span>@Lang.T("กำลังนำเข้า...", "Importing...")</span> } else { <span>@Lang.T("นำเข้า Excel", "Import Excel")</span> }
            </label>
            
            <button @onclick="OpenAddModal" class="px-5 py-2.5 bg-mattel-red text-white font-medium text-sm rounded-lg hover:bg-mattel-hover shadow-xl transition-colors flex items-center">
                <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                @Lang.T("เพิ่มตำแหน่งใหม่", "New Locator")
            </button>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage) && !_showModal)
{
    <div class="mb-4 p-3 bg-red-900/30 text-red-400 rounded-lg text-sm border border-red-900/40">@_errorMessage</div>
}

@if (_isLoading)
{
    <div class="flex justify-center items-center py-12">
        <div class="text-slate-400 font-medium">@Lang.T("กำลังโหลดข้อมูลตำแหน่ง...", "Loading locators...")</div>
    </div>
}
else 
{
    <div class="bg-slate-800 p-6 rounded-2xl shadow-xl border border-slate-700 mb-8">
        <div class="flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <label for="search" class="block text-sm font-semibold text-slate-300 mb-1.5 flex items-center gap-1.5">
                    <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    @Lang.T("ค้นหาตำแหน่ง", "Search Locators")
                </label>
                <div class="relative group">
                    <input type="text" id="search" @bind="_searchQuery" @bind:event="oninput" @onkeyup="FilterData"
                           class="block w-full pl-4 pr-10 py-2.5 bg-slate-900 text-slate-200 border border-slate-700 rounded-xl focus:ring-2 focus:ring-mattel-red/20 focus:border-mattel-red focus:bg-slate-800 transition-all sm:text-sm outline-none" 
                           placeholder="@Lang.T("ค้นหารหัส, กลุ่ม, ตู้, ชั้น...", "Search ID, Site, Cabinet, Shelf...")" />
                    @if (!string.IsNullOrEmpty(_searchQuery))
                    {
                        <button @onclick='() => { _searchQuery = ""; FilterData(); }' class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-slate-400">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                        </button>
                    }
                </div>
            </div>
            @if (_selectedLocatorIds.Any())
            {
                <div class="flex items-end">
                    <button @onclick="PrintSelectedQRs" class="px-5 py-2.5 bg-slate-700 text-slate-200 font-medium text-sm rounded-xl hover:bg-slate-600 transition-colors flex items-center gap-2 border border-slate-600">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 00-2 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                        @Lang.T($"พิมพ์ QR ที่เลือก ({_selectedLocatorIds.Count})", $"Print QR ({_selectedLocatorIds.Count})")
                    </button>
                </div>
            }
            <div class="flex items-end gap-2">
                <button @onclick="ClearAll" class="px-5 py-2.5 bg-slate-700 text-slate-300 font-medium text-sm rounded-xl border border-slate-600 hover:bg-slate-600 hover:text-white transition-colors shrink-0">@Lang.T("ล้างค่า", "Clear")</button>
                <button @onclick="FilterData" class="px-5 py-2.5 bg-mattel-red text-white font-medium text-sm rounded-xl hover:bg-mattel-hover transition-colors shrink-0">@Lang.T("ค้นหา", "Search")</button>
            </div>
        </div>
    </div>

    <div class="bg-slate-800 rounded-2xl shadow-xl border border-slate-700 mb-8 block w-full relative">
        <div class="w-full pb-48">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-900 sticky top-0 z-10 shadow-xl">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider w-12 shrink-0 rounded-tl-2xl">
                            <input type="checkbox" checked="@(_displayLocators.Any() && _displayLocators.All(l => _selectedLocatorIds.Contains(l.Id)))" @onchange="ToggleSelectAll" class="rounded border-slate-700 text-blue-400 focus:ring-mattel-red cursor-pointer" />
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider whitespace-nowrap min-w-[200px]">@Lang.T("รหัส / ชื่อตำแหน่ง", "Locator ID / Name")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider relative cursor-pointer group select-none shrink-0 whitespace-nowrap min-w-[150px]" @onclick="ToggleZoneFilter">
                            <div class="flex items-center gap-2 transition-colors @(_zoneFilter != "All" ? "text-blue-400" : "text-slate-400 hover:text-blue-400")">
                                <span class="tracking-widest">@Lang.T("ประเภทโซน", "Zone")@(_zoneFilter != "All" ? $": {(_zoneFilter == "Store" ? "Storage" : _zoneFilter)}" : "")</span>
                                <div class='flex items-center justify-center w-5 h-5 rounded-full transition-all @(_showZoneFilter ? "bg-blue-50 rotate-180" : "group-hover:bg-slate-700")'>
                                    <svg class='w-3.5 h-3.5 @(_zoneFilter != "All" ? "text-blue-500" : "text-slate-400")' fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                                @if (_zoneFilter != "All")
                                {
                                    <span class="flex h-2 w-2 rounded-full bg-blue-500 animate-pulse shadow-[0_0_8px_rgba(59,130,246,0.5)]"></span>
                                }
                            </div>
                            @if (_showZoneFilter)
                            {
                                <div class="absolute left-6 top-full z-20 mt-2 w-48 bg-slate-800 rounded-2xl shadow-2xl border border-slate-700 overflow-hidden transform origin-top-left ring-1 ring-black/5 animate-in fade-in zoom-in duration-200" @onclick:stopPropagation>
                                    <div class="flex items-center justify-between px-4 py-2.5 bg-slate-900/50 border-b border-slate-700">
                                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">@Lang.T("กรองประเภทโซน", "Filter Zone")</span>
                                        @if (_zoneFilter != "All")
                                        {
                                            <button @onclick='() => SetZoneFilter("All")' class="text-[10px] font-bold text-blue-400 hover:text-blue-400 transition-colors">@Lang.T("ล้าง", "RESET")</button>
                                        }
                                    </div>
                                    <div class="py-1.5">
                                        @foreach (var opt in new[] { ("All", Lang.T("แสดงทั้งหมด", "Show All Zones")), ("Production", Lang.T("โซนผลิต", "Production")), ("Cleaning", Lang.T("โซนล้าง", "Cleaning")), ("Store", Lang.T("คลังจัดเก็บ", "Storage")) })
                                        {
                                            <button @onclick="() => SetZoneFilter(opt.Item1)" 
                                                    class='flex items-center justify-between w-full px-4 py-2 text-xs text-left transition-all @(_zoneFilter == opt.Item1 ? "bg-blue-50/80 text-blue-400 font-bold" : "text-slate-400 hover:bg-slate-900")'>
                                                <span>@opt.Item2</span>
                                                @if (_zoneFilter == opt.Item1)
                                                {
                                                    <svg class="w-3.5 h-3.5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                    </svg>
                                                }
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider whitespace-nowrap min-w-[150px]">@Lang.T("รายละเอียดตำแหน่ง", "Location Details")</th>
                        @if (_hasActions)
                        {
                            <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-slate-400 uppercase tracking-wider whitespace-nowrap min-w-[200px] rounded-tr-2xl">@Lang.T("การดำเนินการ", "Actions")</th>
                        }
                    </tr>
                </thead>
                <tbody class="bg-slate-800 divide-y divide-slate-200">
                    @if (_displayLocators != null && _displayLocators.Any())
                    {
                        @foreach (var loc in _displayLocators)
                        {
                            <tr class="hover:bg-slate-900 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <input type="checkbox" checked="@_selectedLocatorIds.Contains(loc.Id)" @onchange="@(e => ToggleSelection(loc.Id, e.Value))" class="rounded border-slate-700 text-blue-400 focus:ring-mattel-red cursor-pointer" />
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-bold text-slate-100 font-mono">@loc.Id</div>
                                    <div class="text-xs text-slate-400 mt-1">@loc.Name</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    @if (loc.Type == "Production")
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-blue-900/40 text-blue-400 border border-blue-900/40">@Lang.T("ผลิต", "Production")</span>
                                    }
                                    else if (loc.Type == "Cleaning")
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-amber-900/40 text-amber-400 border border-amber-900/40">@Lang.T("ล้าง", "Cleaning")</span>
                                    }
                                    else if (loc.Type == "Store")
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-900/40 text-emerald-400 border border-emerald-900/40">@Lang.T("คลัง", "Storage")</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-slate-700 text-slate-200 border border-slate-600">@loc.Type</span>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    @if(!string.IsNullOrEmpty(loc.Site)){ <div class="text-sm text-slate-300">@Lang.T("กลุ่ม:", "Site:") @loc.Site</div> }
                                    @if(!string.IsNullOrEmpty(loc.Cabinet)){ <div class="text-xs text-slate-400 mt-1">@Lang.T("ตู้:", "Cabinet:") @loc.Cabinet</div> }
                                    @if(!string.IsNullOrEmpty(loc.Shelf)){ <div class="text-xs text-slate-400 mt-0.5">@Lang.T("ชั้น:", "Shelf:") @loc.Shelf</div> }
                                </td>
                                @if (_hasActions)
                                {
                                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                                        <div class="flex items-center justify-end gap-2">
                                            <button @onclick="() => PrintQR(loc)" class="text-slate-300 hover:text-white bg-slate-700 hover:bg-slate-600 px-3 py-1.5 rounded-lg transition-colors text-xs font-medium flex items-center gap-1" title="Print QR Code">
                                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" /></svg>
                                                QR
                                            </button>
                                            @if (_currentRole == "Admin" || _currentRole == "ProdLead")
                                            {
                                                <button @onclick="() => OpenEditModal(loc)" class="text-blue-400 hover:text-white bg-blue-900/30 hover:bg-blue-800 px-3 py-1.5 rounded-lg transition-colors text-xs font-medium">@Lang.T("แก้ไข", "Edit")</button>
                                                <button @onclick="() => DeleteLocator(loc)" class="text-red-400 hover:text-white bg-red-900/30 hover:bg-red-800 px-3 py-1.5 rounded-lg transition-colors text-xs font-medium">@Lang.T("ลบ", "Delete")</button>
                                            }
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-20 text-center">
                                <div class="flex flex-col items-center justify-center space-y-3">
                                    <div class="p-4 bg-slate-900 rounded-full">
                                        <svg class="w-10 h-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                        </svg>
                                    </div>
                                    <div class="space-y-1">
                                        <h3 class="text-lg font-bold text-slate-100">@Lang.T("ไม่พบข้อมูลตำแหน่ง", "No locators found")</h3>
                                        <p class="text-sm text-slate-400">@Lang.T("ไม่พบตำแหน่งจัดเก็บที่ตรงตามเงื่อนไขการค้นหา", "We couldn't find any positions matching your filters.")</p>
                                    </div>
                                    <button @onclick='() => { _searchQuery = ""; _zoneFilter = "All"; FilterData(); }' 
                                            class="mt-4 px-4 py-2 bg-slate-800 border border-slate-700 text-blue-400 font-bold text-sm rounded-xl hover:bg-slate-700 hover:border-blue-900/40 transition-all shadow-xl">
                                        @Lang.T("ล้างตัวกรองทั้งหมด", "Clear all filters")
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_showModal)
{
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center p-4">
        <div class="relative w-full max-w-lg bg-slate-800 rounded-2xl shadow-xl p-6 border border-slate-700 text-left max-h-[90vh] flex flex-col">
            <h3 class="text-2xl font-bold text-slate-100 mb-6 shrink-0">@Lang.T(_isEditMode ? "แก้ไขตำแหน่ง" : "เพิ่มตำแหน่งใหม่", _isEditMode ? "Edit Locator" : "New Locator")</h3>
            <div class="space-y-4 mb-6 overflow-y-auto pr-2 flex-grow">
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="mb-4 p-3 bg-red-900/30 text-red-400 rounded-lg text-sm border border-red-900/40">
                        @_errorMessage
                    </div>
                }
                
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("รหัสตำแหน่ง", "Locator ID") <span class="text-slate-400 font-normal text-xs">@Lang.T("(สร้างอัตโนมัติ)", "(auto-generated)")</span></label>
                        <div class="w-full px-3 py-2 border border-slate-700 rounded-lg bg-slate-900 text-sm font-mono text-slate-300 select-all" title="Auto-generated ID">
                            @_editingLocator.GetGeneratedId()
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("ชื่อตำแหน่ง", "Name") <span class="text-slate-400 font-normal text-xs">@Lang.T("(สร้างอัตโนมัติจาก Site/ตู้/ชั้น)", "(auto-generated from Site/Cabinet/Shelf)")</span></label>
                        <div class="w-full px-3 py-2 border border-slate-700 rounded-lg bg-slate-900 text-sm text-slate-400 font-mono">
                            @(_editingLocator.GetName(Lang.Current).Length > 0 ? _editingLocator.GetName(Lang.Current) : "–")
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("ประเภทโซน *", "Zone Type *")</label>
                        <select @bind="_editingLocator.Type" class="w-full px-3 py-2 bg-slate-900 text-slate-200 border border-slate-700 rounded-lg focus:ring-mattel-red focus:border-mattel-red sm:text-sm">
                            <option value="Production">@Lang.T("โซนผลิต (Production)", "Production Zone")</option>
                            <option value="Cleaning">@Lang.T("จุดทำความสะอาด (Cleaning)", "Cleaning Zone")</option>
                            <option value="Store">@Lang.T("ชั้นจัดเก็บ (Storage)", "Storage Zone")</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("กลุ่ม (Site)", "Site")</label>
                        <input type="text" @bind="_editingLocator.Site" @bind:event="oninput" class="w-full px-3 py-2 bg-slate-900 text-slate-200 border border-slate-700 rounded-lg focus:ring-mattel-red focus:border-mattel-red sm:text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("ตู้ (Cabinet)", "Cabinet")</label>
                        <input type="text" @bind="_editingLocator.Cabinet" @bind:event="oninput" class="w-full px-3 py-2 bg-slate-900 text-slate-200 border border-slate-700 rounded-lg focus:ring-mattel-red focus:border-mattel-red sm:text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("ชั้น (Shelf)", "Shelf")</label>
                        <input type="text" @bind="_editingLocator.Shelf" @bind:event="oninput" class="w-full px-3 py-2 bg-slate-900 text-slate-200 border border-slate-700 rounded-lg focus:ring-mattel-red focus:border-mattel-red sm:text-sm" />
                    </div>
                </div>
            </div>
            <div class="flex justify-end space-x-3 pt-4 border-t border-slate-700 shrink-0">
                <button @onclick="CloseModal" class="px-4 py-2 bg-slate-800 text-slate-300 border border-slate-700 font-medium rounded-lg hover:bg-slate-900 transition-colors text-sm">@Lang.T("ยกเลิก", "Cancel")</button>
                <button @onclick="SaveLocator" class="px-4 py-2 bg-mattel-red text-white font-medium rounded-lg hover:bg-mattel-hover transition-colors text-sm">@Lang.T("บันทึก", "Save")</button>
            </div>
        </div>
    </div>
}

@code {
    private string _currentRole = "";
    private bool _isLoading = true;
    private bool _isImporting = false;
    private bool _showModal = false;
    private bool _isEditMode = false;
    private Locator _editingLocator = new();
    private string? _originalLocatorId = null;
    private bool _hasActions => true; // Everyone currently has at least QR access
    private string _errorMessage = "";
    private string _searchQuery = "";
    private string _zoneFilter = "All";
    private bool _showZoneFilter = false;
    private HashSet<string> _selectedLocatorIds = new();

    private List<Locator> _allLocators = new();
    private List<Locator> _displayLocators = new();

    protected override void OnInitialized()
    {
        Lang.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Lang.OnChange -= StateHasChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await Auth.GetAuthAsync();
        _currentRole = auth.Role ?? "";
        
        if (_currentRole != "Admin" && _currentRole != "Engineer" && _currentRole != "ProdLead")
        {
            NavManager.NavigateTo("/");
            return;
        }

        await LoadData();
        _isLoading = false;
        StateHasChanged();
    }

    private async Task LoadData()
    {
        try
        {
            _allLocators = await Http.GetFromJsonAsync<List<Locator>>("api/locators") ?? new List<Locator>();
            FilterData();
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load locators from API.";
        }
    }

    private void ToggleZoneFilter() { _showZoneFilter = !_showZoneFilter; }

    private void SetZoneFilter(string val)
    {
        _zoneFilter = val;
        FilterData();
        _showZoneFilter = false;
    }

    private void ClearAll()
    {
        _searchQuery = "";
        _zoneFilter = "All";
        _selectedLocatorIds.Clear();
        _showZoneFilter = false;
        FilterData();
    }

    private void FilterData()
    {
        var lowerQuery = (_searchQuery ?? "").ToLowerInvariant();
        _displayLocators = _allLocators.Where(l => 
            (string.IsNullOrWhiteSpace(lowerQuery) || 
             (l.Id ?? "").ToLowerInvariant().Contains(lowerQuery) ||
             (l.Site ?? "").ToLowerInvariant().Contains(lowerQuery) ||
             (l.Cabinet ?? "").ToLowerInvariant().Contains(lowerQuery) ||
             (l.Shelf ?? "").ToLowerInvariant().Contains(lowerQuery) ||
             (l.Position ?? "").ToLowerInvariant().Contains(lowerQuery)) &&
            (_zoneFilter == "All" || l.Type == _zoneFilter)
        ).ToList();
    }

    private void OpenAddModal()
    {
        _isEditMode = false;
        _originalLocatorId = null;
        _editingLocator = new Locator();
        _errorMessage = "";
        _showModal = true;
    }

    private void OpenEditModal(Locator loc)
    {
        _isEditMode = true;
        _originalLocatorId = loc.Id;
        _editingLocator = new Locator
        {
            Id       = loc.Id,
            Site     = loc.Site,
            Cabinet  = loc.Cabinet,
            Shelf    = loc.Shelf,
            Position = loc.Position,
            Type     = loc.Type
        };
        _errorMessage = "";
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
    }

    private async Task SaveLocator()
    {
        _editingLocator.Id = _editingLocator.GetGeneratedId();
        
        if (string.IsNullOrWhiteSpace(_editingLocator.Id))
        {
            _errorMessage = "Locator ID is required.";
            return;
        }

        HttpResponseMessage response;

        if (_isEditMode)
        {
            // Always use the rename endpoint — it handles both ID-change and field-only updates safely
            response = await Http.PostAsJsonAsync($"api/locators/{_originalLocatorId}/rename", _editingLocator);
        }
        else
        {
            if (_allLocators.Any(l => l.Id == _editingLocator.Id))
            {
                _errorMessage = "A locator with this ID already exists.";
                return;
            }
            response = await Http.PostAsJsonAsync("api/locators", _editingLocator);
        }

        if (response.IsSuccessStatusCode)
        {
            await LoadData();
            _showModal = false;
            _errorMessage = "";
            StateHasChanged();
        }
        else
        {
            var body = await response.Content.ReadAsStringAsync();
            _errorMessage = $"Save failed: {body}";
        }
    }

    private async Task DeleteLocator(Locator loc)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Delete Locator", $"Are you sure you want to delete locator {loc.Id}?", "Yes, delete", "error");
        if (!confirmed) return;

        var response = await Http.DeleteAsync($"api/locators/{loc.Id}");
        if (response.IsSuccessStatusCode)
        {
            _selectedLocatorIds.Remove(loc.Id);
            await LoadData();
            StateHasChanged();
        }
        else
        {
            _errorMessage = "Failed to delete locator from API.";
        }
    }

    private async Task PrintQR(Locator loc)
    {
        var qr = QrCode.EncodeText(loc.Id, QrCode.Ecc.Medium);
        var svgStr = qr.ToSvgString(4, "#000000", "#ffffff");
        var data = new {
            id = loc.Id,
            site = loc.Site,
            cabinet = loc.Cabinet,
            shelf = loc.Shelf,
            type = loc.Type
        };
        await JSRuntime.InvokeVoidAsync("printLocatorQR", svgStr, data);
    }

    private void ToggleSelection(string locId, object? isChecked)
    {
        if (isChecked is bool cb && cb)
            _selectedLocatorIds.Add(locId);
        else
            _selectedLocatorIds.Remove(locId);
            
        StateHasChanged();
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        bool selectAll = (bool)(e.Value ?? false);
        if (selectAll)
        {
            foreach (var loc in _displayLocators) _selectedLocatorIds.Add(loc.Id);
        }
        else
        {
            foreach (var loc in _displayLocators) _selectedLocatorIds.Remove(loc.Id);
        }
        StateHasChanged();
    }

    private async Task PrintSelectedQRs()
    {
        if (!_selectedLocatorIds.Any()) return;

        var qrList = new List<object>();
        foreach (var id in _selectedLocatorIds)
        {
            var loc = _allLocators.FirstOrDefault(l => l.Id == id);
            if (loc == null) continue;
            var qr = QrCode.EncodeText(id, QrCode.Ecc.Medium);
            var svgStr = qr.ToSvgString(4, "#000000", "#ffffff");
            qrList.Add(new {
                svg = svgStr,
                id = id,
                site = loc.Site,
                cabinet = loc.Cabinet,
                shelf = loc.Shelf,
                type = loc.Type
            });
        }

        await JSRuntime.InvokeVoidAsync("printLocatorQRs", qrList);
        _selectedLocatorIds.Clear();
    }

    private class ImportResponse
    {
        public int inserted { get; set; }
        public int updated { get; set; }
        public List<string> errors { get; set; } = new();
    }

    private async Task ImportExcel(InputFileChangeEventArgs e)
    {
        _isImporting = true;
        StateHasChanged();
        
        // Assuming there isn't an ImportLocatorsAsync in the controller yet,
        // Wait, we didn't add Locators upload in UploadController? Actually we only added jig specs and physical jigs.
        // We need to either add it or comment it out for now.
        // Let's call the endpoint, if we implement it.
        try
        {
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(e.File.OpenReadStream(10_000_000));
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(e.File.ContentType);
            content.Add(fileContent, "file", e.File.Name);

            var response = await Http.PostAsync("api/upload/locators", content);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ImportResponse>();
                if (result != null)
                {
                    var msg = $"Import complete: {result.inserted} added, {result.updated} updated.";
                    if (result.errors != null && result.errors.Any())
                    {
                        msg += $"\nErrors:\n{string.Join("\n", result.errors)}";
                        await JSRuntime.InvokeVoidAsync("alert", msg);
                    }
                    else
                    {
                        await JSRuntime.InvokeVoidAsync("alert", msg);
                    }
                }
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Import API failed: {response.StatusCode} (Does the endpoint exist?)");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Import failed: {ex.Message}");
        }
        finally
        {
            _isImporting = false;
            await LoadData();
            StateHasChanged();
        }
    }
}
