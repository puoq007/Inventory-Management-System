@page "/admin/register-jig"
@using shared.Models
@using System.Net.Http.Json
@using frontend.Services
@using Net.Codecrete.QrCodeGenerator
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject LanguageService Lang

<PageTitle>@Lang.T("จัดการจิ๊ก (Jigs Master)", "Jigs Master") | Inventory</PageTitle>

<div class="mb-6 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 mb-2">@Lang.T("จัดการจิ๊ก (Jigs Master)", "Jigs Master")</h1>
        <p class="text-slate-500">@Lang.T("ลงทะเบียนจิ๊กใหม่และดูรายละเอียดทั้งหมดแบบตาราง", "Register and view all jigs in a data table.")</p>
    </div>
    
    <div class="flex gap-2">
        <label class="cursor-pointer px-5 py-2.5 bg-emerald-600 text-white font-medium text-sm rounded-lg hover:bg-emerald-700 shadow-sm transition-colors flex items-center shrink-0">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
            @Lang.T("นำเข้าข้อมูล (Excel)", "Import Excel")
            <InputFile class="hidden" OnChange="UploadFiles" accept=".xlsx, .xls" />
        </label>
        <button @onclick="OpenAddModal" class="px-5 py-2.5 bg-blue-600 text-white font-medium text-sm rounded-lg hover:bg-blue-700 shadow-sm transition-colors flex items-center shrink-0">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            @Lang.T("ลงทะเบียนจิ๊กใหม่", "New Jig")
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_globalError))
{
    <div class="mb-4 p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg">@_globalError</div>
}

<div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 mb-8">
    <div class="flex flex-col md:flex-row gap-4">
        <div class="flex-1">
            <label for="search" class="block text-sm font-semibold text-slate-700 mb-1.5 flex items-center gap-1.5">
                <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                @Lang.T("ค้นหาจิ๊ก", "Search Jigs")
            </label>
            <div class="relative group">
                <input type="text" id="search" @bind="_searchQuery" @bind:event="oninput" @onkeyup="FilterData"
                       class="block w-full pl-4 pr-10 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all sm:text-sm outline-none" 
                       placeholder="Search ID, Smart Code, Tool No..." />
            </div>
        </div>
        @if (_selectedJigIds.Any())
        {
            <div class="flex items-end gap-2 mb-[2px]">
                <button @onclick="PrintSelectedQRs" class="px-5 py-2.5 bg-slate-800 text-white font-medium text-sm rounded-lg hover:bg-slate-900 shadow-sm transition-colors flex items-center shrink-0">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 00-2 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                    @Lang.T($"พิมพ์คิวอาร์ที่เลือก ({_selectedJigIds.Count})", $"Print Selected ({_selectedJigIds.Count})")
                </button>
                <button @onclick="ClearSelection" class="px-5 py-2.5 bg-white text-slate-700 font-medium text-sm rounded-lg border border-slate-300 hover:bg-slate-50 shadow-sm transition-colors shrink-0">
                    @Lang.T("ล้างค่า", "Clear")
                </button>
            </div>
        }
    </div>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-slate-100 max-w-full overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50">
                <tr>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase w-12 shrink-0">
                        <input type="checkbox" checked="@(_displayJigs.Any() && _displayJigs.All(j => _selectedJigIds.Contains(j.Uid)))" @onchange="ToggleSelectAll" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500 cursor-pointer" />
                    </th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase">Jig ID</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase">Smart Code Name</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase">Type / Part</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase">Status</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase">Locator</th>
                    <th class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
                @if (_isLoading)
                {
                    <tr><td colspan="5" class="px-6 py-8 text-center text-slate-500">Loading...</td></tr>
                }
                else if (_displayJigs.Any())
                {
                    @foreach (var jig in _displayJigs)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <input type="checkbox" checked="@_selectedJigIds.Contains(jig.Uid)" @onchange="@(e => ToggleSelection(jig.Uid, e.Value))" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500 cursor-pointer" />
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap"><div class="font-mono text-sm font-bold bg-slate-100 px-2 py-1 rounded inline-block">@jig.Id</div></td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm font-medium text-slate-700 truncate max-w-xs" title="@jig.SmartCodeName">@(jig.SmartCodeName ?? "-")</div>
                                <div class="text-xs text-slate-500 mt-1">Tool # @(jig.ToolNo ?? "-")</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm">@jig.JigType</div>
                                <div class="text-xs text-slate-500 mt-1">@jig.PartType</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-3 py-1 inline-flex text-xs font-bold rounded-full border @(jig.Status == "Available" ? "bg-emerald-100 text-emerald-800" : "bg-blue-100 text-blue-800")">
                                    @jig.Status
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600">
                                @GetLocatorName(jig.LocatorId)
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                                <button @onclick="() => PrintQR(jig)" class="text-slate-600 hover:bg-slate-100 px-2 py-1 rounded mr-2" title="Print QR">QR</button>
                                <button @onclick="() => OpenEditModal(jig)" class="text-indigo-600 hover:bg-indigo-50 px-2 py-1 rounded">Edit</button>
                                <button @onclick="() => DeleteJig(jig)" class="text-red-600 hover:bg-red-50 px-2 py-1 rounded">Delete</button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="px-6 py-8 text-center text-slate-500">No jigs found</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (_showModal)
{
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm h-full w-full z-50 flex items-center justify-center p-4">
        <div class="relative w-full max-w-xl bg-white rounded-2xl shadow-xl flex flex-col max-h-[95vh]">
            <div class="p-6 border-b border-slate-100 shrink-0">
                <h3 class="text-2xl font-bold text-slate-900">@Lang.T(_isEditMode ? "แก้ไขข้อมูลจิ๊ก" : "ลงทะเบียนจิ๊กใหม่", _isEditMode ? "Edit Jig" : "Register New Jig")</h3>
            </div>
            
            <div class="p-6 overflow-y-auto flex-1">
                @if (!string.IsNullOrEmpty(_modalError))
                { <div class="mb-4 p-4 bg-red-50 text-red-700 rounded">@_modalError</div> }

                <EditForm Model="_editingJig" OnValidSubmit="SaveJig">
                    <div class="flex flex-col gap-4">
                        
                        <!-- Primary Info -->
                        <div class="pb-3 border-b border-slate-100">
                            <h3 class="text-sm font-bold text-slate-800 mb-2">Primary Info</h3>
                            <div class="grid grid-cols-1 gap-3">
                                <div>
                                    <label class="block text-xs font-semibold mb-1">Jig ID <span class="text-red-500">*</span></label>
                                    <input type="text" @bind="_editingJig.Id" required class="w-full px-3 py-1.5 border rounded-lg focus:ring-1 text-sm @(_isEditMode ? "bg-amber-50" : "")" placeholder="e.g. JIG-0001" />
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-blue-800 mb-1">Smart Code Preview</label>
                                    <div class="w-full px-3 py-1.5 bg-blue-50 border border-blue-100 rounded-lg text-blue-900 font-mono text-xs min-h-[32px] flex items-center">
                                        @GenerateSmartCodePreview()
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Smart Code Specs -->
                        <div class="pb-3 border-b border-slate-100">
                            <h3 class="text-sm font-bold text-slate-800 mb-2">Specifications</h3>
                            <div class="grid grid-cols-2 gap-x-4 gap-y-2">
                                <div><label class="block text-[10px] font-semibold text-slate-500 mb-0.5 uppercase">Tool No.</label><input type="text" @bind="_editingJig.ToolNo" @bind:event="oninput" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div><label class="block text-[10px] font-semibold text-slate-500 mb-0.5 uppercase">Step Print</label><input type="text" @bind="_editingJig.StepPrint" @bind:event="oninput" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div><label class="block text-[10px] font-semibold text-slate-500 mb-0.5 uppercase">Part Type</label><input type="text" @bind="_editingJig.PartType" @bind:event="oninput" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div><label class="block text-[10px] font-semibold text-slate-500 mb-0.5 uppercase">Date</label><input type="text" @bind="_editingJig.Date" @bind:event="oninput" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div><label class="block text-[10px] font-semibold text-slate-500 mb-0.5 uppercase">Feed</label><input type="text" @bind="_editingJig.Feed" @bind:event="oninput" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div><label class="block text-[10px] font-semibold text-slate-500 mb-0.5 uppercase">Scan</label><input type="text" @bind="_editingJig.Scan" @bind:event="oninput" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div><label class="block text-[10px] font-semibold text-slate-500 mb-0.5 uppercase">Q'ty / Print</label><input type="text" @bind="_editingJig.QtyPrint" @bind:event="oninput" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div><label class="block text-[10px] font-semibold text-slate-500 mb-0.5 uppercase">Height Jig</label><input type="text" @bind="_editingJig.HeightJig" @bind:event="oninput" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div><label class="block text-[10px] font-semibold text-slate-500 mb-0.5 uppercase">Jig Type</label><input type="text" @bind="_editingJig.JigType" @bind:event="oninput" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div><label class="block text-[10px] font-semibold text-slate-500 mb-0.5 uppercase">Process</label><input type="text" @bind="_editingJig.Process" @bind:event="oninput" class="w-full px-2 py-1 border rounded text-sm" /></div>
                            </div>
                        </div>

                        <!-- Extra info -->
                        <div>
                            <h3 class="text-sm font-bold text-slate-800 mb-2">Other References</h3>
                            <div class="grid grid-cols-2 gap-x-4 gap-y-2">
                                <div><label class="block text-[10px] font-semibold text-slate-500 mb-0.5 uppercase">Toy Number</label><input type="text" @bind="_editingJig.ToyNumber" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div><label class="block text-[10px] font-semibold text-slate-500 mb-0.5 uppercase">Part Number</label><input type="text" @bind="_editingJig.PartNumber" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div>
                                    <label class="block text-[10px] font-semibold text-slate-500 mb-0.5 uppercase">Locator</label>
                                    <select @bind="_editingJig.LocatorId" class="w-full px-2 py-1 border rounded text-sm bg-white">
                                        <option value="">-- No Location --</option>
                                        @foreach (var loc in _allLocators)
                                        {
                                            <option value="@loc.Id">@loc.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-span-2"><label class="block text-[10px] font-semibold text-slate-500 mb-0.5 uppercase">Rev.</label><input type="text" @bind="_editingJig.Rev" class="w-full px-2 py-1 border rounded text-sm" /></div>
                            </div>
                        </div>
                    </div>
                    <button id="hiddenSubmitBtn" type="submit" class="hidden"></button>
                </EditForm>
            </div>
            
            <div class="p-6 flex justify-end gap-3 bg-slate-50 rounded-b-2xl">
                <button @onclick="CloseModal" class="px-5 py-2.5 bg-white border rounded-xl hover:bg-slate-100">Cancel</button>
                <button disabled="@_isSubmitting" onclick="document.getElementById('hiddenSubmitBtn').click()" class="px-6 py-2.5 bg-blue-600 text-white rounded-xl hover:bg-blue-700">
                    @(_isSubmitting ? "Saving..." : "Save Jig")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private string _searchQuery = "";
    private string _globalError = "";
    private List<Jig> _allJigs = new();
    private List<Locator> _allLocators = new();
    private IEnumerable<Jig> _displayJigs = Array.Empty<Jig>();

    private bool _showModal = false;
    private bool _isEditMode = false;
    private bool _isSubmitting = false;
    private string _modalError = "";
    private Jig _editingJig = new Jig { Status = "Available", Condition = "Good" };
    private HashSet<string> _selectedJigIds = new();

    protected override void OnInitialized() { Lang.OnChange += StateHasChanged; }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var jigsTask = Http.GetFromJsonAsync<List<Jig>>("api/jigs");
            var locsTask = Http.GetFromJsonAsync<List<Locator>>("api/locators");
            
            _allJigs = await jigsTask ?? new();
            _allLocators = await locsTask ?? new();
            
            FilterData();
        }
        catch (Exception ex) { _globalError = ex.Message; }
        _isLoading = false;
        StateHasChanged();
    }

    private void FilterData()
    {
        var lower = _searchQuery.ToLowerInvariant();
        _displayJigs = string.IsNullOrWhiteSpace(lower) ? _allJigs : _allJigs.Where(j => 
            (j.Id?.ToLower().Contains(lower) == true) || (j.SmartCodeName?.ToLower().Contains(lower) == true));
    }

    private void OpenAddModal()
    {
        _isEditMode = false;
        _editingJig = new Jig { Status = "Available", Condition = "Good" };
        _modalError = "";
        _showModal = true;
    }

    private void OpenEditModal(Jig jig)
    {
        _isEditMode = true;
        _editingJig = new Jig { 
            Uid = jig.Uid,
            Id = jig.Id, 
            SmartCodeName = jig.SmartCodeName, 
            ToolNo = jig.ToolNo, 
            StepPrint = jig.StepPrint, 
            PartType = jig.PartType, 
            Date = jig.Date, 
            Feed = jig.Feed, 
            Scan = jig.Scan, 
            QtyPrint = jig.QtyPrint, 
            HeightJig = jig.HeightJig, 
            JigType = jig.JigType, 
            Process = jig.Process, 
            ToyNumber = jig.ToyNumber, 
            PartNumber = jig.PartNumber, 
            Rev = jig.Rev, 
            Status = jig.Status, 
            Condition = jig.Condition, 
            LocatorId = jig.LocatorId 
        };
        _modalError = "";
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private string GenerateSmartCodePreview()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(_editingJig.ToolNo)) parts.Add(_editingJig.ToolNo);
        if (!string.IsNullOrWhiteSpace(_editingJig.StepPrint)) parts.Add(_editingJig.StepPrint);
        if (!string.IsNullOrWhiteSpace(_editingJig.PartType)) parts.Add(_editingJig.PartType);
        if (!string.IsNullOrWhiteSpace(_editingJig.Date)) parts.Add(_editingJig.Date);
        if (!string.IsNullOrWhiteSpace(_editingJig.Feed) && !string.IsNullOrWhiteSpace(_editingJig.Scan)) parts.Add($"{_editingJig.Feed}/{_editingJig.Scan}");
        else if (!string.IsNullOrWhiteSpace(_editingJig.Feed)) parts.Add(_editingJig.Feed);
        else if (!string.IsNullOrWhiteSpace(_editingJig.Scan)) parts.Add(_editingJig.Scan);
        if (!string.IsNullOrWhiteSpace(_editingJig.QtyPrint)) parts.Add(_editingJig.QtyPrint);
        if (!string.IsNullOrWhiteSpace(_editingJig.HeightJig)) parts.Add(_editingJig.HeightJig);
        if (!string.IsNullOrWhiteSpace(_editingJig.JigType)) parts.Add(_editingJig.JigType);
        if (!string.IsNullOrWhiteSpace(_editingJig.Process)) parts.Add(_editingJig.Process);
        return string.Join(" ", parts);
    }

    private async Task SaveJig()
    {
        // Deep Sanitization
        _editingJig.Id = CleanAllSpaces(_editingJig.Id) ?? "";
        _editingJig.ToolNo = CleanAllSpaces(_editingJig.ToolNo) ?? "";
        _editingJig.ToyNumber = CleanAllSpaces(_editingJig.ToyNumber) ?? "";
        _editingJig.PartNumber = CleanAllSpaces(_editingJig.PartNumber) ?? "";
        _editingJig.LocatorId = CleanAllSpaces(_editingJig.LocatorId) ?? "";
        _editingJig.Rev = CleanAllSpaces(_editingJig.Rev);
        _editingJig.Date = CleanAllSpaces(_editingJig.Date);
        _editingJig.Feed = CleanAllSpaces(_editingJig.Feed);
        _editingJig.Scan = CleanAllSpaces(_editingJig.Scan);
        _editingJig.QtyPrint = CleanAllSpaces(_editingJig.QtyPrint);
        _editingJig.HeightJig = CleanAllSpaces(_editingJig.HeightJig);

        _editingJig.PartType = CleanAllSpaces(_editingJig.PartType);
        _editingJig.StepPrint = NormalizeSpaces(_editingJig.StepPrint);
        _editingJig.JigType = NormalizeSpaces(_editingJig.JigType);
        _editingJig.Process = NormalizeSpaces(_editingJig.Process);
        _editingJig.Status = CleanAllSpaces(_editingJig.Status) ?? "Available";
        _editingJig.Condition = CleanAllSpaces(_editingJig.Condition) ?? "Good";

        if (string.IsNullOrWhiteSpace(_editingJig.Id)) { _modalError = "ID Required"; return; }
        _isSubmitting = true; _modalError = "";
        try
        {
            _editingJig.SmartCodeName = GenerateSmartCodePreview();
            var response = _isEditMode 
                ? await Http.PutAsJsonAsync($"api/jigs/{_editingJig.Uid}", _editingJig) 
                : await Http.PostAsJsonAsync("api/jigs", _editingJig);
            if (response.IsSuccessStatusCode) { await LoadData(); _showModal = false; }
            else { _modalError = await response.Content.ReadAsStringAsync(); }
        }
        catch (Exception ex) { _modalError = ex.Message; }
        finally { _isSubmitting = false; StateHasChanged(); }
    }

    private async Task DeleteJig(Jig jig)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Confirm", "Delete this jig?", "Yes", "error");
        if (!confirmed) return;
        if ((await Http.DeleteAsync($"api/jigs/{jig.Uid}")).IsSuccessStatusCode) await LoadData();
    }

    private async Task UploadFiles(Microsoft.AspNetCore.Components.Forms.InputFileChangeEventArgs e)
    {
        _isLoading = true;
        _globalError = "";
        StateHasChanged();

        try
        {
            var file = e.File;
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream(15 * 1024 * 1024)); // 15MB max
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync("api/jigs/upload", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UploadResult>();
                _globalError = Lang.T($"นำเข้าสำเร็จ: เพิ่ม {result?.Inserted} รายการ, อัปเดต {result?.Updated} รายการ", 
                                      $"Successfully imported: {result?.Inserted} inserted, {result?.Updated} updated.");
                await LoadData();
            }
            else
            {
                var t = await response.Content.ReadAsStringAsync();
                _globalError = $"Upload failed. Status: {response.StatusCode}. Details: {t}";
            }
        }
        catch (Exception ex)
        {
            _globalError = "Error uploading file: " + ex.Message;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    public class UploadResult
    {
        public int Inserted { get; set; }
        public int Updated { get; set; }
        public List<string> Errors { get; set; } = new();
    }

    private string? CleanAllSpaces(string? val)
    {
        if (string.IsNullOrWhiteSpace(val)) return val?.Trim();
        return new string(val.Where(c => !char.IsWhiteSpace(c)).ToArray());
    }

    private string? NormalizeSpaces(string? val)
    {
        if (string.IsNullOrWhiteSpace(val)) return val?.Trim();
        return System.Text.RegularExpressions.Regex.Replace(val.Trim(), @"\s+", " ");
    }

    private void ToggleSelection(string jigId, object? isChecked)
    {
        if (isChecked is bool cb && cb) _selectedJigIds.Add(jigId);
        else _selectedJigIds.Remove(jigId);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if ((bool)(e.Value ?? false)) foreach (var j in _displayJigs) _selectedJigIds.Add(j.Uid);
        else foreach (var j in _displayJigs) _selectedJigIds.Remove(j.Uid);
    }

    private void ClearSelection() => _selectedJigIds.Clear();

    private async Task PrintQR(Jig jig)
    {
        var qr = QrCode.EncodeText(jig.Id, QrCode.Ecc.Medium);
        var svgStr = qr.ToSvgString(4, "#000000", "#ffffff");
        var data = new { id = jig.Id, toyNumber = jig.ToyNumber, partNumber = jig.PartNumber, part = jig.PartType, stepPrint = jig.StepPrint, jigType = jig.JigType };
        await JSRuntime.InvokeVoidAsync("printQR", svgStr, data);
    }

    private async Task PrintSelectedQRs()
    {
        if (!_selectedJigIds.Any()) return;
        var qrList = new List<object>();
        foreach (var uid in _selectedJigIds)
        {
            var jig = _allJigs.FirstOrDefault(j => j.Uid == uid);
            if (jig == null) continue;
            var qr = QrCode.EncodeText(jig.Id, QrCode.Ecc.Medium);
            var svgStr = qr.ToSvgString(4, "#000000", "#ffffff");
            qrList.Add(new { id = jig.Id, svg = svgStr, toyNumber = jig.ToyNumber, partNumber = jig.PartNumber, part = jig.PartType, stepPrint = jig.StepPrint, jigType = jig.JigType });
        }
        await JSRuntime.InvokeVoidAsync("printQRs", qrList);
        _selectedJigIds.Clear();
    }
    private string GetLocatorName(string? id)
    {
        if (string.IsNullOrEmpty(id)) return "-";
        var loc = _allLocators.FirstOrDefault(l => l.Id == id);
        return loc?.Name ?? id;
    }
}
