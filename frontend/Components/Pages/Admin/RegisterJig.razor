@page "/admin/register-jig"
@using shared.Models
@using System.Net.Http.Json
@using frontend.Services
@using Net.Codecrete.QrCodeGenerator
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject LanguageService Lang
@inject frontend.Services.AuthService Auth
@inject NavigationManager NavManager

<PageTitle>@Lang.T("การจัดการ Jig", "Jigs Management") | Inventory</PageTitle>

<div class="mb-6 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-100 mb-2">@Lang.T("การจัดการ Jig", "Jigs Management")</h1>
        <p class="text-slate-400">@Lang.T("ลงทะเบียนจิ๊กใหม่และดูรายละเอียดทั้งหมดแบบตาราง", "Register and view all jigs in a data table.")</p>
    </div>
    
    <div class="flex gap-2">
        @if (_userRole == "Admin" || _userRole == "Engineer")
        {
            <label class="cursor-pointer px-5 py-2.5 bg-emerald-700 text-white font-medium text-sm rounded-lg hover:bg-emerald-800 shadow-xl transition-colors flex items-center shrink-0">
                <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                @Lang.T("นำเข้าข้อมูล (Excel)", "Import Excel")
                <InputFile class="hidden" OnChange="UploadFiles" accept=".xlsx, .xls" />
            </label>
            <button @onclick="OpenAddModal" class="px-5 py-2.5 bg-mattel-red text-white font-medium text-sm rounded-lg hover:bg-mattel-hover shadow-xl transition-colors flex items-center shrink-0">
                <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                @Lang.T("ลงทะเบียนจิ๊กใหม่", "New Jig")
            </button>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(_globalError))
{
    <div class="mb-4 p-4 bg-red-900/30 border border-red-900/40 text-red-400 rounded-lg">@_globalError</div>
}

<div class="bg-slate-800 p-6 rounded-2xl shadow-xl border border-slate-700 mb-8">
    <div class="flex flex-col md:flex-row gap-4">
        <div class="flex-1">
            <label for="search" class="block text-sm font-semibold text-slate-300 mb-1.5 flex items-center gap-1.5">
                <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                @Lang.T("ค้นหาจิ๊ก", "Search Jigs")
            </label>
            <div class="relative group">
                <input type="text" id="search" @bind="_searchQuery" @bind:event="oninput" @onkeyup="FilterData"
                       class="block w-full pl-4 pr-10 py-2.5 bg-slate-900 text-slate-200 border border-slate-700 rounded-xl focus:ring-2 focus:ring-mattel-red/20 focus:border-mattel-red focus:bg-slate-800 transition-all sm:text-sm outline-none" 
                       placeholder="Search ID, Smart Code, Tool No..." />
            </div>
        </div>
        @if (_selectedJigIds.Any())
        {
            <div class="flex items-end gap-2 mb-[2px]">
                <button @onclick="PrintSelectedQRs" class="px-5 py-2.5 bg-slate-800 text-white font-medium text-sm rounded-lg hover:bg-slate-900 shadow-xl transition-colors flex items-center shrink-0">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 00-2 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                    @Lang.T($"พิมพ์คิวอาร์ที่เลือก ({_selectedJigIds.Count})", $"Print Selected ({_selectedJigIds.Count})")
                </button>
                <button @onclick="ClearSelection" class="px-5 py-2.5 bg-slate-800 text-slate-300 font-medium text-sm rounded-lg border border-slate-700 hover:bg-slate-900 shadow-xl transition-colors shrink-0">
                    @Lang.T("ล้างค่า", "Clear")
                </button>
            </div>
        }
    </div>
</div>

<div class="bg-slate-800 rounded-2xl shadow-xl border border-slate-700 max-w-full overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-900">
                <tr>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase w-12 shrink-0">
                        <input type="checkbox" checked="@(_displayJigs.Any() && _displayJigs.All(j => _selectedJigIds.Contains(j.Uid)))" @onchange="ToggleSelectAll" class="rounded border-slate-700 text-blue-600 focus:ring-mattel-red cursor-pointer" />
                    </th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase">@Lang.T("รหัส JIG", "Jig ID")</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase">@Lang.T("ชื่อ Smart Code", "Smart Code Name")</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase">@Lang.T("ประเภท / ส่วนประกอบ", "Type / Part")</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase">@Lang.T("สถานะ", "Status")</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase">@Lang.T("ตำแหน่ง", "Locator")</th>
                    <th class="px-6 py-4 text-right text-xs font-semibold text-slate-400 uppercase">@Lang.T("เครื่องมือ", "Actions")</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
                @if (_isLoading)
                {
                    <tr><td colspan="5" class="px-6 py-8 text-center text-slate-400">Loading...</td></tr>
                }
                else if (_displayJigs.Any())
                {
                    @foreach (var jig in _displayJigs)
                    {
                        <tr class="hover:bg-slate-900 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <input type="checkbox" checked="@_selectedJigIds.Contains(jig.Uid)" @onchange="@(e => ToggleSelection(jig.Uid, e.Value))" class="rounded border-slate-700 text-blue-600 focus:ring-mattel-red cursor-pointer" />
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap"><div class="font-mono text-sm font-bold bg-slate-900 px-2 py-1 rounded inline-block">@jig.Id</div></td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center gap-3">
                                    @if (!string.IsNullOrEmpty(jig.ImageUrl))
                                    {
                                        <img src="@GetImageSrc(jig.ImageUrl)" alt="@jig.Id" class="w-10 h-10 rounded-lg object-cover border border-slate-700 shadow-xl flex-shrink-0" />
                                    }
                                    else
                                    {
                                        <div class="w-10 h-10 rounded-lg bg-slate-900 border border-slate-700 flex items-center justify-center flex-shrink-0">
                                            <svg class="w-5 h-5 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                                        </div>
                                    }
                                    <div class="min-w-0">
                                        <div class="text-sm font-medium text-slate-300 truncate max-w-xs" title="@jig.SmartCodeName">@(jig.SmartCodeName ?? "-")</div>
                                        <div class="text-xs text-slate-400 mt-0.5">Tool # @(jig.ToolNo ?? "-")</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm">@jig.JigType</div>
                                <div class="text-xs text-slate-400 mt-1">@jig.PartType</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-3 py-1 inline-flex text-xs font-bold rounded-full border @(GetStatusBadgeClass(jig.Status))">
                                    @Lang.T(GetStatusThai(jig.Status), jig.Status)
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-400">
                                @GetLocatorName(jig.LocatorId)
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                                <button @onclick="() => PrintQR(jig)" class="text-slate-400 hover:text-slate-100 mr-4 font-semibold px-2 py-1 rounded hover:bg-slate-900 transition-colors" title="Print QR Sticker (2.5cm)">
                                    <svg class="w-4 h-4 inline-block -mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" /></svg>
                                    QR
                                </button>
                                @if (_userRole == "Admin" || _userRole == "Engineer")
                                {
                                    <button @onclick="() => OpenEditModal(jig)" class="text-indigo-400 hover:text-indigo-900 mr-4 font-semibold px-2 py-1 rounded hover:bg-indigo-900/30 transition-colors">@Lang.T("แก้ไข", "Edit")</button>
                                    <button @onclick="() => DeleteJig(jig)" class="text-red-400 hover:text-red-900 font-semibold px-2 py-1 rounded hover:bg-red-900/30 transition-colors">@Lang.T("ลบ", "Delete")</button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="px-6 py-8 text-center text-slate-400">No jigs found</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (_showModal)
{
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm h-full w-full z-50 flex items-center justify-center p-4">
        <div class="relative w-full max-w-xl bg-slate-800 rounded-2xl shadow-xl flex flex-col max-h-[90vh] overflow-hidden">
            <div class="p-6 border-b border-slate-700 shrink-0 bg-slate-800 z-10">
                <h3 class="text-2xl font-bold text-slate-100">@Lang.T(_isEditMode ? "แก้ไขข้อมูลจิ๊ก" : "ลงทะเบียนจิ๊กใหม่", _isEditMode ? "Edit Jig" : "Register New Jig")</h3>
            </div>
            
            <div class="p-6 overflow-y-auto overflow-x-hidden flex-1 min-h-0 w-full custom-scrollbar" style="max-height: calc(90vh - 140px);">
                @if (!string.IsNullOrEmpty(_modalError))
                { <div class="mb-4 p-4 bg-red-900/30 text-red-400 rounded-xl">@_modalError</div> }

                <EditForm Model="_editingJig" OnValidSubmit="SaveJig">
                    <div class="flex flex-col gap-4">
                        
                        <!-- Primary Info -->
                        <div class="pb-3 border-b border-slate-700">
                            <h3 class="text-sm font-bold text-slate-200 mb-2">@Lang.T("ข้อมูลหลัก", "Primary Info")</h3>
                            <div class="grid grid-cols-1 gap-3">
                                <div>
                                    <label class="block text-xs font-semibold mb-1">@Lang.T("รหัส JIG", "Jig ID") <span class="text-red-500">*</span></label>
                                    <input type="text" @bind="_editingJig.Id" required class="w-full px-3 py-1.5 border rounded-lg focus:ring-1 text-sm @(_isEditMode ? "bg-amber-50" : "")" placeholder="e.g. JIG-0001" />
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-blue-800 mb-1">@Lang.T("ตัวอย่าง Smart Code", "Smart Code Preview")</label>
                                    <div class="w-full px-3 py-1.5 bg-blue-50 border border-blue-100 rounded-lg text-blue-900 font-mono text-xs min-h-[32px] flex items-center shadow-inner break-words">
                                        @GenerateSmartCodePreview()
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Specifications -->
                        <div class="pb-3 border-b border-slate-700">
                            <h3 class="text-sm font-bold text-slate-200 mb-2">@Lang.T("ข้อมูลจำเพาะ (Specifications)", "Specifications")</h3>
                            <div class="grid grid-cols-2 gap-x-4 gap-y-2">
                                <div><label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("รหัสเครื่องมือ (Tool No.)", "Tool No.")</label><input type="text" @bind="_editingJig.ToolNo" @bind:event="oninput" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div>
                                    <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("ลำดับการพิมพ์ (Step Print)", "Step Print")</label>
                                    <div class="flex flex-col gap-2">
                                        <select class="w-full px-2 py-1 border rounded text-sm bg-slate-800" @onchange="AddStep">
                                            <option value="">-- Add Step --</option>
                                            @foreach (var opt in _stepPrintOptions) { <option value="@opt">@opt</option> }
                                        </select>
                                        <div class="flex flex-wrap gap-2 mt-2">
                                            @foreach (var step in _selectedSteps)
                                            {
                                                <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-sm font-semibold bg-blue-50 text-blue-700 border border-blue-200 shadow-xl">
                                                    @step
                                                    <button type="button" @onclick="() => _selectedSteps.Remove(step)" class="ml-2 text-blue-400 hover:text-blue-600 transition-colors">✕</button>
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("ประเภทชิ้นส่วน (Part Type)", "Part Type")</label>
                                    <select @bind="_editingJig.PartType" class="w-full px-2 py-1 border rounded text-sm bg-slate-800">
                                        <option value="">-- Select --</option>
                                        @foreach (var opt in _partTypeOptions) { <option value="@opt">@opt</option> }
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("วันที่ (Date)", "Date")</label>
                                    <input type="date" @bind="SelectedDate" class="w-full px-2 py-1 border rounded text-sm h-[30px]" />
                                </div>
                                <div><label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("ฟีด (Feed)", "Feed")</label><input type="text" @bind="_editingJig.Feed" @bind:event="oninput" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div><label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("สแกน (Scan)", "Scan")</label><input type="text" @bind="_editingJig.Scan" @bind:event="oninput" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div><label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("จำนวน / การพิมพ์ (Q'ty / Print)", "Q'ty / Print")</label><input type="text" @bind="_editingJig.QtyPrint" @bind:event="oninput" class="w-full px-2 py-1 border rounded text-sm" /></div>
                                <div>
                                    <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("ความสูง JIG (Height Jig)", "Height Jig")</label>
                                    <select @bind="_editingJig.HeightJig" class="w-full px-2 py-1 border rounded text-sm bg-slate-800">
                                        <option value="">-- Select --</option>
                                        @foreach (var opt in _heightJigOptions) { <option value="@opt">@{ if(opt == "HMR Plywood" || opt == "MDF Plywood") { @opt } else { @(opt + " mm") } }</option> }
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("ประเภท JIG (Jig Type)", "Jig Type")</label>
                                    <select @bind="_editingJig.JigType" class="w-full px-2 py-1 border rounded text-sm bg-slate-800">
                                        <option value="">-- Select --</option>
                                        @foreach (var opt in _jigTypeOptions) { <option value="@opt">@opt</option> }
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("กระบวนการ (Process)", "Process")</label>
                                    <select @bind="_editingJig.Process" class="w-full px-2 py-1 border rounded text-sm bg-slate-800">
                                        <option value="">-- Select --</option>
                                        @foreach (var opt in _processOptions) { <option value="@opt">@opt</option> }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Other References -->
                        <div>
                            <h3 class="text-sm font-bold text-slate-200 mb-2">@Lang.T("ข้อมูลอ้างอิงอื่นๆ", "Other References")</h3>
                            
                            <!-- Part Numbers -->
                            <div class="mb-3">
                                <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("รหัสชิ้นส่วนที่รองรับ (กด Enter เพื่อเพิ่ม)", "Compatible Part Numbers (Press Enter)")</label>
                                <input type="text" @bind="_newPartInput" @onkeydown="HandlePartKeyDown" onkeypress="return event.keyCode != 13;" placeholder="e.g. P-1234" class="w-full px-2 py-1.5 border border-slate-700 rounded focus:border-mattel-red text-sm" autocomplete="off" />
                                @if (_compatiblePartsModel.Any())
                                {
                                    <div class="flex flex-wrap gap-2 mt-2">
                                        @foreach (var part in _compatiblePartsModel)
                                        {
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-sm font-semibold bg-slate-900 text-slate-300 border border-slate-700 shadow-xl">
                                                @part.PartNumber
                                                <button type="button" @onclick="() => RemovePartNumber(part.PartNumber)" class="ml-2 text-slate-400 hover:text-red-500 transition-colors">✕</button>
                                            </span>
                                        }
                                    </div>
                                }
                            </div>



                            <div class="grid grid-cols-2 gap-x-4 gap-y-2">
                                <div>
                                    <label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("ตำแหน่งปัจจุบัน", "Locator")</label>
                                    <select @bind="_editingJig.LocatorId" class="w-full px-2 py-1.5 border rounded text-sm bg-slate-800">
                                        <option value="">-- @Lang.T("ไม่มีตำแหน่ง", "No Location") --</option>
                                        @foreach (var loc in _allLocators)
                                        {
                                            <option value="@loc.Id">@loc.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-span-1"><label class="block text-[10px] font-semibold text-slate-400 mb-0.5 uppercase">@Lang.T("เวอร์ชัน (Rev.)", "Rev.")</label><input type="text" @bind="_editingJig.Rev" class="w-full px-2 py-1.5 border rounded text-sm" /></div>
                            </div>

                            @* Image Upload *@
                            <div class="mt-3 pt-3 border-t border-slate-700">
                                <label class="block text-[10px] font-semibold text-slate-400 mb-1.5 uppercase">@Lang.T("รูปภาพจิ๊ก", "Jig Photo")</label>
                                <div class="flex items-start gap-4">
                                    @if (!string.IsNullOrEmpty(_imagePreview))
                                    {
                                        <div class="relative group">
                                            <img src="@_imagePreview" alt="Preview" class="w-24 h-24 rounded-xl object-cover border-2 border-slate-700 shadow-xl" />
                                            <button type="button" @onclick="RemoveImage" class="absolute -top-2 -right-2 w-6 h-6 bg-red-900/300 text-white rounded-full text-xs font-bold hover:bg-red-600 shadow-md flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">✕</button>
                                        </div>
                                    }
                                    else if (!string.IsNullOrEmpty(_editingJig.ImageUrl))
                                    {
                                        <div class="relative group">
                                            <img src="@GetImageSrc(_editingJig.ImageUrl)" alt="Current" class="w-24 h-24 rounded-xl object-cover border-2 border-slate-700 shadow-xl" />
                                            <button type="button" @onclick="RemoveImage" class="absolute -top-2 -right-2 w-6 h-6 bg-red-900/300 text-white rounded-full text-xs font-bold hover:bg-red-600 shadow-md flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">✕</button>
                                        </div>
                                    }
                                    <label class="flex-1 cursor-pointer">
                                        <div class="flex flex-col items-center justify-center py-4 px-3 border-2 border-dashed border-slate-700 rounded-xl hover:border-blue-400 hover:bg-blue-50/50 transition-all">
                                            <svg class="w-8 h-8 text-slate-400 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                                            <span class="text-xs font-medium text-slate-400">@Lang.T("คลิกเพื่อเลือกรูป", "Click to select image")</span>
                                            <span class="text-[10px] text-slate-400 mt-0.5">JPG, PNG, WebP (max 5MB)</span>
                                        </div>
                                        <InputFile class="hidden" OnChange="OnImageSelected" accept=".jpg,.jpeg,.png,.webp" />
                                    </label>
                                </div>
                                @if (_isUploadingImage)
                                {
                                    <div class="mt-2 text-xs text-blue-600 font-medium flex items-center gap-1">
                                        <span class="inline-block animate-spin h-3 w-3 border-2 border-blue-600 rounded-full border-t-transparent"></span>
                                        @Lang.T("กำลังอัปโหลดรูป...", "Uploading image...")
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <button id="hiddenSubmitBtn" type="submit" class="hidden"></button>
                </EditForm>
            </div>
            
            <div class="p-6 flex justify-end gap-3 bg-slate-900 border-t border-slate-700 rounded-b-2xl shrink-0 w-full z-10">
                <button @onclick="CloseModal" class="px-5 py-2.5 bg-slate-800 border rounded-xl hover:bg-slate-900">@Lang.T("ยกเลิก", "Cancel")</button>
                <button disabled="@_isSubmitting" onclick="document.getElementById('hiddenSubmitBtn').click()" class="px-6 py-2.5 bg-mattel-red text-white rounded-xl hover:bg-mattel-hover">
                    @(_isSubmitting ? Lang.T("กำลังบันทึก...", "Saving...") : Lang.T("บันทึกข้อมูล", "Save Jig"))
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private string _searchQuery = "";
    private string _globalError = "";
    private List<Jig> _allJigs = new();
    private List<Locator> _allLocators = new();
    private IEnumerable<Jig> _displayJigs = Array.Empty<Jig>();

    private bool _showModal = false;
    private bool _isEditMode = false;
    private bool _isSubmitting = false;
    private string _modalError = "";
    private Jig _editingJig = new Jig { Status = "Available", Condition = "Good" };
    private HashSet<string> _selectedJigIds = new();
    
    private List<shared.Models.PartMaster> _compatiblePartsModel = new();
    private string _newPartInput = "";
    private string _userRole = "";
    
    // Image upload state
    private IBrowserFile? _selectedImageFile;
    private string? _imagePreview;
    private bool _isUploadingImage = false;
    private bool _removeExistingImage = false;

    // Dropdown options from reference image
    private readonly string[] _stepPrintOptions = { "1 : L", "2 : R", "3 : Hood", "4 : Roof", "5 : Re.Hood", "6 : Front", "7 : Rear", "8 : Under", "9 : Re.L", "10 : Re.R" };

    // Mapping from old text-only step names to numbers
    private static readonly Dictionary<string, string> _stepNameToNumber = new(StringComparer.OrdinalIgnoreCase)
    {
        ["L"] = "1", ["R"] = "2", ["Hood"] = "3", ["Roof"] = "4",
        ["Re.Hood"] = "5", ["Front"] = "6", ["Rear"] = "7", ["Under"] = "8",
        ["Re.L"] = "9", ["Re.R"] = "10",
        
        // Keep old typo mappings for backwards compatibility with existing database entries
        ["Read Hood"] = "5", ["Read"] = "7"
    };

    private string StepNumberToLabel(string num)
    {
        var match = _stepPrintOptions.FirstOrDefault(o => o.StartsWith(num + " "));
        return match ?? num;
    }
    private readonly string[] _partTypeOptions = { "Body", "Wing", "Window", "Interior", "Chassis", "Bumper", "Wheel", "Face", "Grill", "Teeth", "Tail", "Spoiler", "Tender" };
    private readonly string[] _jigTypeOptions = { "Plywood", "Stack", "Flip", "Spoiler", "Hybrid", "BBQ", "Plywood Flag", "JIG Wheel" };
    private readonly string[] _processOptions = { "PIM", "PL", "VUM", "HSP", "RB", "LQ", "TP", "AS" };
    private readonly string[] _heightJigOptions = { "40", "45", "50", "75", "80", "90", "HMR Plywood", "MDF Plywood" };

    // Multi-selection for Step Print
    private List<string> _selectedSteps = new();

    // Date helper for calendar
    private DateTime? _selectedDate; 
    private DateTime? SelectedDate { 
        get => _selectedDate; 
        set {
            _selectedDate = value;
            if (value.HasValue) _editingJig.Date = value.Value.ToString("dd/MM/yy");
            else _editingJig.Date = null;
        }
    }

    protected override void OnInitialized() { Lang.OnChange += StateHasChanged; }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var auth = await Auth.GetAuthAsync();
            var role = auth.Role ?? "";
            _userRole = role;
            
            if (role != "Admin" && role != "Engineer" && role != "ProdLead")
            {
                NavManager.NavigateTo("/");
                return;
            }
            
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var jigsTask = Http.GetFromJsonAsync<List<Jig>>("api/jigs");
            var locsTask = Http.GetFromJsonAsync<List<Locator>>("api/locators");
            
            _allJigs = await jigsTask ?? new();
            _allLocators = await locsTask ?? new();
            
            FilterData();
        }
        catch (Exception ex) { _globalError = ex.Message; }
        _isLoading = false;
        StateHasChanged();
    }

    private void FilterData()
    {
        var lower = _searchQuery.ToLowerInvariant();
        var query = string.IsNullOrWhiteSpace(lower) 
            ? _allJigs 
            : _allJigs.Where(j => 
                (j.Id?.ToLowerInvariant().Contains(lower) == true) || 
                (j.SmartCodeName?.ToLowerInvariant().Contains(lower) == true) ||
                (j.PartNumber?.ToLowerInvariant().Contains(lower) == true) ||
                (j.ToolNo?.ToLowerInvariant().Contains(lower) == true)
            );
            
        _displayJigs = query.OrderBy(j => j.Id);
    }

    private void OpenAddModal()
    {
        _isEditMode = false;
        _editingJig = new Jig { Status = "Available", Condition = "Good" };
        _modalError = "";
        _compatiblePartsModel.Clear();
        _newPartInput = "";
        _selectedImageFile = null;
        _imagePreview = null;
        _selectedDate = null;
        _selectedSteps = new();
        _removeExistingImage = false;
        _showModal = true;
    }

    private void OpenEditModal(Jig jig)
    {
        _isEditMode = true;
        _editingJig = new Jig { 
            Uid = jig.Uid,
            Id = jig.Id, 
            SmartCodeName = jig.SmartCodeName, 
            ToolNo = jig.ToolNo, 
            StepPrint = jig.StepPrint, 
            PartType = jig.PartType, 
            Date = jig.Date, 
            Feed = jig.Feed, 
            Scan = jig.Scan, 
            QtyPrint = jig.QtyPrint, 
            HeightJig = jig.HeightJig, 
            JigType = jig.JigType, 
            Process = jig.Process, 
            PartNumber = jig.PartNumber, 
            Rev = jig.Rev, 
            Status = jig.Status, 
            Condition = jig.Condition, 
            LocatorId = jig.LocatorId,
            ImageUrl = jig.ImageUrl
        };
        _modalError = "";
        _compatiblePartsModel.Clear();
        _newPartInput = "";
        _selectedImageFile = null;
        _imagePreview = null;
        _removeExistingImage = false;
        _selectedDate = null;

        // Parse date for calendar
        if (!string.IsNullOrEmpty(_editingJig.Date))
        {
            if (DateTime.TryParseExact(_editingJig.Date, "dd/MM/yy", System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var d))
                _selectedDate = d;
        }

        _showModal = true;

        // Parse step print for multi-select
        // DB stores numbers like "1-2-3", reconstruct full labels for display
        if (!string.IsNullOrEmpty(_editingJig.StepPrint))
        {
            _selectedSteps = _editingJig.StepPrint
                .Split(new[] { ',', '-' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(s => s.Trim())
                .Select(s => {
                    // If it's already a full label like "1 : L", keep it
                    if (s.Contains(':')) return s;
                    // If it's a number, convert to full label
                    if (int.TryParse(s, out _)) return StepNumberToLabel(s);
                    // Old text format like "L", "R" → convert to full label via mapping
                    if (_stepNameToNumber.TryGetValue(s, out var num)) return StepNumberToLabel(num);
                    return s;
                })
                .ToList();
        }
        else _selectedSteps = new();
        
        // Fire and forget data loading for mapped parts
        _ = LoadPartsForJig(_editingJig.ToolNo);
    }

    private void AddStep(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        if (!string.IsNullOrEmpty(val) && !_selectedSteps.Contains(val))
        {
            _selectedSteps.Add(val);
        }
    }

    private async Task LoadPartsForJig(string toolNo)
    {
        if (string.IsNullOrWhiteSpace(toolNo)) return;
        try
        {
            var parts = await Http.GetFromJsonAsync<List<PartMaster>>($"api/jigs/parts/{toolNo}");
            if (parts != null) 
            {
                _compatiblePartsModel = parts;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { /* ignore */ }
    }



    private void AddPartNumber()
    {
        var p = CleanAllSpaces(_newPartInput) ?? "";
        if (!string.IsNullOrWhiteSpace(p) && !_compatiblePartsModel.Any(x => x.PartNumber.Equals(p, StringComparison.OrdinalIgnoreCase)))
        {
            _compatiblePartsModel.Add(new PartMaster { PartNumber = p });
        }
        _newPartInput = "";
    }

    private void RemovePartNumber(string part)
    {
        _compatiblePartsModel.RemoveAll(x => x.PartNumber == part);
    }



    private void HandlePartKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddPartNumber();
    }



    private void CloseModal() => _showModal = false;

    private string GetImageSrc(string imageUrl)
    {
        if (string.IsNullOrEmpty(imageUrl)) return "";
        // If it's a relative path like /uploads/xxx.jpg, prepend the backend base URL
        if (imageUrl.StartsWith("/"))
            return $"http://localhost:5105{imageUrl}";
        return imageUrl;
    }

    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > 5_000_000)
        {
            _modalError = "Image is too large. Max 5MB.";
            return;
        }

        _selectedImageFile = file;
        _removeExistingImage = false;

        // Create preview
        var buffer = new byte[file.Size];
        await file.OpenReadStream(5_000_000).ReadAsync(buffer);
        _imagePreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
        StateHasChanged();
    }

    private void RemoveImage()
    {
        _selectedImageFile = null;
        _imagePreview = null;
        _removeExistingImage = true;
        _editingJig.ImageUrl = null;
        StateHasChanged();
    }

    private string GenerateSmartCodePreview()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(_editingJig.ToolNo)) parts.Add(_editingJig.ToolNo);
        
        var steps = ExtractStepNumber(string.Join("-", _selectedSteps));
        if (steps != "-") parts.Add(steps);

        if (!string.IsNullOrWhiteSpace(_editingJig.PartType)) parts.Add(_editingJig.PartType);
        if (!string.IsNullOrWhiteSpace(_editingJig.Date)) parts.Add(_editingJig.Date);
        if (!string.IsNullOrWhiteSpace(_editingJig.Feed) && !string.IsNullOrWhiteSpace(_editingJig.Scan)) parts.Add($"{_editingJig.Feed}/{_editingJig.Scan}");
        else if (!string.IsNullOrWhiteSpace(_editingJig.Feed)) parts.Add(_editingJig.Feed);
        else if (!string.IsNullOrWhiteSpace(_editingJig.Scan)) parts.Add(_editingJig.Scan);
        if (!string.IsNullOrWhiteSpace(_editingJig.QtyPrint)) parts.Add(_editingJig.QtyPrint);
        if (!string.IsNullOrWhiteSpace(_editingJig.HeightJig)) parts.Add(_editingJig.HeightJig);
        if (!string.IsNullOrWhiteSpace(_editingJig.JigType)) parts.Add(_editingJig.JigType);
        if (!string.IsNullOrWhiteSpace(_editingJig.Process)) parts.Add(_editingJig.Process);
        return string.Join(" ", parts);
    }

    private async Task SaveJig()
    {
        // Deep Sanitization
        _editingJig.Id = CleanAllSpaces(_editingJig.Id) ?? "";
        _editingJig.ToolNo = CleanAllSpaces(_editingJig.ToolNo) ?? "";
        _editingJig.PartNumber = CleanAllSpaces(_editingJig.PartNumber) ?? "";
        _editingJig.LocatorId = CleanAllSpaces(_editingJig.LocatorId) ?? "";
        _editingJig.Rev = CleanAllSpaces(_editingJig.Rev);
        _editingJig.Date = CleanAllSpaces(_editingJig.Date);
        _editingJig.Feed = CleanAllSpaces(_editingJig.Feed);
        _editingJig.Scan = CleanAllSpaces(_editingJig.Scan);
        _editingJig.QtyPrint = CleanAllSpaces(_editingJig.QtyPrint);
        _editingJig.HeightJig = CleanAllSpaces(_editingJig.HeightJig);

        _editingJig.PartType = CleanAllSpaces(_editingJig.PartType);
        _editingJig.StepPrint = NormalizeSpaces(_editingJig.StepPrint);
        _editingJig.JigType = NormalizeSpaces(_editingJig.JigType);
        _editingJig.Process = NormalizeSpaces(_editingJig.Process);
        _editingJig.Status = CleanAllSpaces(_editingJig.Status) ?? "Available";
        _editingJig.Condition = CleanAllSpaces(_editingJig.Condition) ?? "Good";

        // Strictly extract numbers from selected steps
        var joinedSteps = string.Join("-", _selectedSteps);
        var extractedStr = ExtractStepNumber(joinedSteps);
        _editingJig.StepPrint = extractedStr == "-" ? "" : extractedStr;

        if (string.IsNullOrWhiteSpace(_editingJig.Id)) { _modalError = "ID Required"; return; }
        if (string.IsNullOrWhiteSpace(_editingJig.ToolNo)) { _modalError = "Tool No Required for Product Mapping"; return; }
        
        // Auto-fill legacy Part fields based on first mapping if available (for list view)
        _editingJig.PartNumber = _compatiblePartsModel.FirstOrDefault()?.PartNumber ?? "";

        _isSubmitting = true; _modalError = "";
        try
        {
            _editingJig.SmartCodeName = GenerateSmartCodePreview();
            var response = _isEditMode 
                ? await Http.PutAsJsonAsync($"api/jigs/{_editingJig.Uid}", _editingJig) 
                : await Http.PostAsJsonAsync("api/jigs", _editingJig);
                
            if (response.IsSuccessStatusCode) 
            { 
                // For new jigs, get the Uid from the response
                if (!_isEditMode)
                {
                    var created = await response.Content.ReadFromJsonAsync<Jig>();
                    if (created != null) _editingJig.Uid = created.Uid;
                }

                // Upload image if selected
                if (_selectedImageFile != null)
                {
                    _isUploadingImage = true;
                    StateHasChanged();
                    try
                    {
                        using var imgContent = new MultipartFormDataContent();
                        var imgStream = new StreamContent(_selectedImageFile.OpenReadStream(5_000_000));
                        imgStream.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(_selectedImageFile.ContentType);
                        imgContent.Add(imgStream, "file", _selectedImageFile.Name);
                        await Http.PostAsync($"api/jigs/{_editingJig.Uid}/image", imgContent);
                    }
                    catch { /* image upload failed, but jig saved */ }
                    finally { _isUploadingImage = false; }
                }
                else if (_removeExistingImage)
                {
                    await Http.DeleteAsync($"api/jigs/{_editingJig.Uid}/image");
                }

                // Save independent mappings
                await Http.PostAsJsonAsync($"api/jigs/parts/{_editingJig.ToolNo}", _compatiblePartsModel);

                await LoadData(); 
                _showModal = false; 
            }
            else { _modalError = await response.Content.ReadAsStringAsync(); }
        }
        catch (Exception ex) { _modalError = ex.Message; }
        finally { _isSubmitting = false; StateHasChanged(); }
    }

    private async Task DeleteJig(Jig jig)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Confirm", "Delete this jig?", "Yes", "error");
        if (!confirmed) return;
        if ((await Http.DeleteAsync($"api/jigs/{jig.Uid}")).IsSuccessStatusCode) await LoadData();
    }

    private async Task UploadFiles(Microsoft.AspNetCore.Components.Forms.InputFileChangeEventArgs e)
    {
        _isLoading = true;
        _globalError = "";
        StateHasChanged();

        try
        {
            var file = e.File;
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream(15 * 1024 * 1024)); // 15MB max
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync("api/jigs/upload", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UploadResult>();
                _globalError = Lang.T($"นำเข้าสำเร็จ: เพิ่ม {result?.Inserted} รายการ, อัปเดต {result?.Updated} รายการ", 
                                      $"Successfully imported: {result?.Inserted} inserted, {result?.Updated} updated.");
                await LoadData();
            }
            else
            {
                var t = await response.Content.ReadAsStringAsync();
                _globalError = $"Upload failed. Status: {response.StatusCode}. Details: {t}";
            }
        }
        catch (Exception ex)
        {
            _globalError = "Error uploading file: " + ex.Message;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    public class UploadResult
    {
        public int Inserted { get; set; }
        public int Updated { get; set; }
        public List<string> Errors { get; set; } = new();
    }

    private string? CleanAllSpaces(string? val)
    {
        if (string.IsNullOrWhiteSpace(val)) return val?.Trim();
        return new string(val.Where(c => !char.IsWhiteSpace(c)).ToArray());
    }

    private string? NormalizeSpaces(string? val)
    {
        if (string.IsNullOrWhiteSpace(val)) return val?.Trim();
        return System.Text.RegularExpressions.Regex.Replace(val.Trim(), @"\s+", " ");
    }

    private void ToggleSelection(string jigId, object? isChecked)
    {
        if (isChecked is bool cb && cb) _selectedJigIds.Add(jigId);
        else _selectedJigIds.Remove(jigId);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if ((bool)(e.Value ?? false)) foreach (var j in _displayJigs) _selectedJigIds.Add(j.Uid);
        else foreach (var j in _displayJigs) _selectedJigIds.Remove(j.Uid);
    }

    private void ClearSelection() => _selectedJigIds.Clear();

    private string ExtractStepNumber(string? stepStr)
    {
        if (string.IsNullOrEmpty(stepStr)) return "-";
        
        var items = stepStr.Split(new[] { ',', '-' }, StringSplitOptions.RemoveEmptyEntries);
        var resultNums = new List<string>();
        
        foreach (var item in items)
        {
            var trimmed = item.Trim();
            
            if (trimmed.Contains(':')) 
            {
                var prefix = trimmed.Split(':')[0].Trim();
                if (int.TryParse(prefix, out _)) { resultNums.Add(prefix); continue; }
            }
            
            if (int.TryParse(trimmed, out _)) { resultNums.Add(trimmed); continue; }
            
            // Clean specific compounded ones first
            var lower = trimmed.ToLowerInvariant();
            if (lower.Contains("re.hood") || lower.Contains("read hood")) { resultNums.Add("5"); continue; }
            if (lower.Contains("re.l")) { resultNums.Add("9"); continue; }
            if (lower.Contains("re.r")) { resultNums.Add("10"); continue; }
            
            // Tokenize by punctuation/spaces to safely catch exact matches like "L" without triggering on "WHEEL"
            var tokens = trimmed.Split(new[] { ' ', '.', '_', '/' }, StringSplitOptions.RemoveEmptyEntries);
            foreach (var token in tokens)
            {
                if (_stepNameToNumber.TryGetValue(token, out var num))
                {
                    resultNums.Add(num);
                }
            }
        }
        
        var finalNums = resultNums.Where(n => !string.IsNullOrEmpty(n)).Distinct().ToList();
        return finalNums.Any() ? string.Join("-", finalNums) : "-";
    }

    private async Task PrintQR(Jig jig)
    {
        var qr = QrCode.EncodeText(jig.Id, QrCode.Ecc.Low); // Low for small stickers
        var svgStr = qr.ToSvgString(4, "#000000", "#ffffff");
        var data = new { 
            id = jig.Id, 
            date = jig.Date, 
            toolNo = jig.ToolNo,
            stepPrint = ExtractStepNumber(jig.StepPrint)
        };
        await JSRuntime.InvokeVoidAsync("printQR", svgStr, data);
    }

    private async Task PrintSelectedQRs()
    {
        if (!_selectedJigIds.Any()) return;
        var qrList = new List<object>();
        foreach (var uid in _selectedJigIds)
        {
            var jig = _allJigs.FirstOrDefault(j => j.Uid == uid);
            if (jig == null) continue;
            var qr = QrCode.EncodeText(jig.Id, QrCode.Ecc.Low);
            var svgStr = qr.ToSvgString(4, "#000000", "#ffffff");
            qrList.Add(new { 
                id = jig.Id, 
                svg = svgStr, 
                date = jig.Date, 
                toolNo = jig.ToolNo,
                stepPrint = ExtractStepNumber(jig.StepPrint)
            });
        }
        await JSRuntime.InvokeVoidAsync("printQRs", qrList);
        _selectedJigIds.Clear();
    }

    private string GetLocatorName(string? id)
    {
        if (string.IsNullOrEmpty(id)) return "-";
        var loc = _allLocators.FirstOrDefault(l => l.Id == id);
        return loc?.Name ?? id;
    }

    private string GetStatusThai(string? status) => status switch
    {
        "Available" => "พร้อมใช้งาน",
        "InUse" => "กำลังใช้งาน",
        "Cleaning" => "กำลังทำความสะอาด",
        "Evaluation" => "รอประเมินสภาพ",
        "Lost" => "สูญหาย",
        _ => status ?? "-"
    };

    private string GetStatusBadgeClass(string? status) => status switch
    {
        "Available" => "bg-emerald-50 text-emerald-700 border-emerald-200",
        "InUse" => "bg-blue-50 text-blue-700 border-blue-200",
        "Cleaning" => "bg-amber-50 text-amber-700 border-amber-200",
        "Evaluation" => "bg-purple-50 text-purple-700 border-purple-200",
        "Lost" => "bg-slate-900 text-slate-400 border-slate-700",
        _ => "bg-slate-900 text-slate-300 border-slate-700"
    };
}
