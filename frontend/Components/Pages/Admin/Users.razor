@page "/admin/users"
@inject frontend.Services.AuthService Auth
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject LanguageService Lang
@using frontend.Components.Shared
@implements IDisposable
@using shared.Models
@using System.Net.Http.Json
@using Net.Codecrete.QrCodeGenerator

<PageTitle>Users | Inventory</PageTitle>

<div class="mb-6 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-100 mb-2">@Lang.T("จัดการผู้ใช้งาน", "User Management")</h1>
        <p class="text-slate-400">@Lang.T("เพิ่ม แก้ไข และจัดการบัญชีผู้ใช้งานรวมถึงสิทธิ์การเข้าถึง", "Add, edit, and manage user accounts and access roles.")</p>
    </div>
    
    <button @onclick="OpenAddModal" class="px-5 py-2.5 bg-mattel-red text-white font-medium text-sm rounded-lg hover:bg-mattel-hover shadow-xl transition-colors flex items-center">
        <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        @Lang.T("เพิ่มผู้ใช้งานใหม่", "New User")
    </button>
</div>

@if (_isLoading)
{
    <div class="flex justify-center items-center py-12">
        <div class="text-slate-400 font-medium">@Lang.T("กำลังโหลดข้อมูลผู้ใช้งาน...", "Loading users...")</div>
    </div>
}
else
{
    <div class="bg-slate-800 p-6 rounded-2xl shadow-xl border border-slate-700 mb-8">
    <div class="flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <label for="search" class="block text-sm font-semibold text-slate-300 mb-1.5 flex items-center gap-1.5">
                    <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    @Lang.T("ค้นหาผู้ใช้งาน", "Search Users")
                </label>
                <div class="relative group">
                    <input type="text" id="search" @bind="_searchQuery" @bind:event="oninput" @onkeyup="FilterData"
                           class="block w-full pl-4 pr-10 py-2.5 bg-slate-900 text-slate-200 border border-slate-700 rounded-xl focus:ring-2 focus:ring-mattel-red/20 focus:border-mattel-red focus:bg-slate-800 transition-all sm:text-sm outline-none" 
                           placeholder="@Lang.T("ค้นหารหัสพนักงาน, ชื่อ, หรือสิทธิ์...", "Search Employee ID, Name, or Role...")" />
                    @if (!string.IsNullOrEmpty(_searchQuery))
                    {
                        <button @onclick='() => { _searchQuery = ""; FilterData(); }' class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-slate-400">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                        </button>
                    }
                </div>
            </div>
            @if (_selectedUserIds.Any())
            {
                <div class="flex items-end">
                    <button @onclick="PrintSelectedQRs" class="px-5 py-2.5 bg-slate-700 text-slate-200 font-medium text-sm rounded-xl hover:bg-slate-600 transition-colors flex items-center gap-2 border border-slate-600">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 00-2 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                        @Lang.T($"พิมพ์ QR ที่เลือก ({_selectedUserIds.Count})", $"Print QR ({_selectedUserIds.Count})")
                    </button>
                </div>
            }
            <div class="flex items-end gap-3 shrink-0">
                <PageSizeSelector @bind-PageSize="_pageSize" OnChanged="FilterData" />
            </div>
        </div>
    </div>

    <div class="bg-slate-800 rounded-2xl shadow-xl border border-slate-700 mb-8 max-w-full relative">
        <div class="block w-full overflow-x-auto min-h-[300px]">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-900">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider w-12 shrink-0">
                            <input type="checkbox" checked="@(_displayUsers != null && _displayUsers.Any() && _displayUsers.All(u => _selectedUserIds.Contains(u.EmployeeId)))" @onchange="ToggleSelectAll" class="w-5 h-5 rounded border-slate-700 text-blue-400 focus:ring-mattel-red cursor-pointer" />
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">@Lang.T("รหัสพนักงาน", "Employee ID")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">@Lang.T("ชื่อ-นามสกุล", "Name")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider relative cursor-pointer group select-none" @onclick="ToggleRoleFilter">
                            <div class="flex items-center gap-2 transition-colors @(_roleFilter != "All" ? "text-blue-400" : "text-slate-400 hover:text-blue-400")">
                                <span class="tracking-widest">@Lang.T("สิทธิ์", "Role")@(_roleFilter != "All" ? $": {_roleFilter}" : "")</span>
                                <div class='flex items-center justify-center w-5 h-5 rounded-full transition-all @(_showRoleFilter ? "bg-blue-900/40 rotate-180" : "group-hover:bg-slate-700")'>
                                    <svg class='w-3.5 h-3.5 @(_roleFilter != "All" ? "text-blue-500" : "text-slate-400")' fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                                @if (_roleFilter != "All")
                                {
                                    <span class="flex h-2 w-2 rounded-full bg-blue-500 animate-pulse shadow-[0_0_8px_rgba(59,130,246,0.5)]"></span>
                                }
                            </div>
                            @if (_showRoleFilter)
                            {
                                <div class="absolute left-6 top-full z-20 mt-2 w-48 bg-slate-800 rounded-2xl shadow-2xl border border-slate-700 overflow-hidden transform origin-top-left ring-1 ring-black/5 animate-in fade-in zoom-in duration-200" @onclick:stopPropagation>
                                    <div class="flex items-center justify-between px-4 py-2.5 bg-slate-900/50 border-b border-slate-700">
                                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">@Lang.T("กรองสิทธิ์", "Filter Role")</span>
                                        @if (_roleFilter != "All")
                                        {
                                            <button @onclick='() => SetRoleFilter("All")' class="text-[10px] font-bold text-blue-400 hover:text-blue-400 transition-colors">@Lang.T("ล้างค่า", "RESET")</button>
                                        }
                                    </div>
                                    <div class="py-1.5">
                                        @foreach (var opt in new[] { 
                                            ("All", Lang.T("แสดงทุกสิทธิ์", "Show All Roles")), 
                                            ("Admin", Lang.T("ผู้ดูแลระบบ", "Admin")), 
                                            ("Engineer", Lang.T("วิศวกร", "Engineer")), 
                                            ("ProdLead", Lang.T("หัวหน้าฝ่ายผลิต", "Prod Lead")), 
                                            ("Operator", Lang.T("พนักงานปฏิบัติการ", "Operator")) 
                                        })
                                        {
                                            <button @onclick="() => SetRoleFilter(opt.Item1)" 
                                                    class='flex items-center justify-between w-full px-4 py-2 text-xs text-left transition-all @(_roleFilter == opt.Item1 ? "bg-blue-50/80 text-blue-400 font-bold" : "text-slate-400 hover:bg-slate-900")'>
                                                <span>@opt.Item2</span>
                                                @if (_roleFilter == opt.Item1)
                                                {
                                                    <svg class="w-3.5 h-3.5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                    </svg>
                                                }
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">@Lang.T("รหัสผ่าน", "Password")</th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-slate-400 uppercase tracking-wider">@Lang.T("ดำเนินการ", "Actions")</th>
                    </tr>
                </thead>
                <tbody class="bg-slate-800 divide-y divide-slate-700">
                    @if (_displayUsers != null && _displayUsers.Any())
                    {
                        @foreach (var user in _displayUsers)
                        {
                            <tr class="hover:bg-slate-900 transition-colors cursor-pointer" @onclick="() => ToggleRowSelection(user.EmployeeId)">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <input type="checkbox" checked="@_selectedUserIds.Contains(user.EmployeeId)" class="w-5 h-5 rounded border-slate-700 text-blue-400 focus:ring-mattel-red cursor-pointer" />
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-slate-300">
                                    @user.EmployeeId
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-400">
                                    @user.Name
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-3 py-1 inline-flex text-xs leading-5 font-bold rounded-full border shadow-xl
                                        @(user.Role == "Admin" ? "bg-purple-900/40 text-purple-400 border-purple-900/40" :
                                          user.Role == "Engineer" ? "bg-blue-900/40 text-blue-400 border-blue-900/40" :
                                          user.Role == "ProdLead" ? "bg-emerald-900/40 text-emerald-400 border-emerald-900/40" :
                                          user.Role == "Operator" ? "bg-amber-900/40 text-amber-400 border-amber-900/40" :
                                          "bg-slate-700 text-slate-300 border-slate-600")">
                                        @Lang.T(user.Role == "Admin" ? "ผู้ดูแลระบบ" : user.Role == "Engineer" ? "วิศวกร" : user.Role == "ProdLead" ? "หัวหน้าฝ่ายผลิต" : user.Role == "Operator" ? "พนักงานปฏิบัติการ" : user.Role, user.Role)
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-400 font-mono tracking-[0.3em] text-lg">
                                    ••••
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm" @onclick:stopPropagation="true">
                                    <div class="flex items-center justify-end gap-2">
                                        <button @onclick="() => PrintQR(user)" class="text-slate-300 hover:text-white bg-slate-700 hover:bg-slate-600 px-3 py-1.5 rounded-lg transition-colors text-xs font-medium flex items-center gap-1" title="Print QR Code">
                                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" /></svg>
                                            QR
                                        </button>
                                        <button @onclick="() => OpenEditModal(user)" class="text-blue-400 hover:text-white bg-blue-900/30 hover:bg-blue-800 px-3 py-1.5 rounded-lg transition-colors text-xs font-medium">@Lang.T("แก้ไข", "Edit")</button>
                                        <button @onclick="() => DeleteUser(user)" class="text-red-400 hover:text-white bg-red-900/30 hover:bg-red-800 px-3 py-1.5 rounded-lg transition-colors text-xs font-medium">@Lang.T("ลบ", "Delete")</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-20 text-center">
                                <div class="flex flex-col items-center justify-center space-y-3">
                                    <div class="p-4 bg-slate-900 rounded-full">
                                        <svg class="w-10 h-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                        </svg>
                                    </div>
                                    <div class="space-y-1">
                                        <h3 class="text-lg font-bold text-slate-100">@Lang.T("ไม่พบผู้ใช้งาน", "No users found")</h3>
                                        <p class="text-sm text-slate-400">@Lang.T("ขออภัย ไม่พบรายชื่อผู้ใช้งานที่ตรงกับคำค้นหาของคุณ", "We couldn't find any accounts matching your search.")</p>
                                    </div>
                                    <button @onclick='() => { _searchQuery = ""; _roleFilter = "All"; FilterData(); }' 
                                            class="mt-4 px-4 py-2 bg-slate-800 border border-slate-700 text-blue-400 font-bold text-sm rounded-xl hover:bg-slate-700 hover:border-blue-900/40 transition-all shadow-xl">
                                        @Lang.T("ล้างการกรองทั้งหมด", "Clear all filters")
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <Pagination TotalItems="@_totalItems" @bind-CurrentPage="_currentPage" PageSize="@_pageSize" OnChanged="FilterData" />
    </div>
}

@if (_showModal)
{
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center p-4">
        <div class="relative w-full max-w-md bg-slate-800 rounded-2xl shadow-xl p-6 border border-slate-700 text-left">
            <h3 class="text-2xl font-bold text-slate-100 mb-6">@Lang.T(_isEditMode ? "แก้ไขข้อมูลผู้ใช้งาน" : "เพิ่มผู้ใช้งานใหม่", _isEditMode ? "Edit User" : "Add New User")</h3>

            <div class="space-y-4 mb-6">
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("รหัสพนักงาน", "Employee ID")</label>
                    <input type="text" @bind="_editingUser.EmployeeId" disabled="@_isEditMode" class="block w-full border border-slate-700 rounded-lg px-4 py-2 focus:ring-mattel-red focus:border-mattel-red sm:text-sm bg-slate-900 text-slate-200 disabled:bg-slate-800 disabled:text-slate-500" placeholder="@Lang.T("เช่น 9005", "e.g. 9005")" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("ชื่อ-นามสกุล", "Full Name")</label>
                    <input type="text" @bind="_editingUser.Name" class="block w-full border border-slate-700 rounded-lg px-4 py-2 focus:ring-mattel-red focus:border-mattel-red sm:text-sm bg-slate-900 text-slate-200" placeholder="@Lang.T("เช่น สมชาย รักเรียน", "e.g. John Doe")" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("ตำแหน่ง / สิทธิ์", "Role")</label>
                    <select @bind="_editingUser.Role" class="block w-full border border-slate-700 rounded-lg px-4 py-2 focus:ring-mattel-red focus:border-mattel-red sm:text-sm bg-slate-900 text-slate-200">
                        <option value="Admin">@Lang.T("ผู้ดูแลระบบ (Admin)", "Admin")</option>
                        <option value="Engineer">@Lang.T("วิศวกร (Engineer)", "Engineer")</option>
                        <option value="ProdLead">@Lang.T("หัวหน้าฝ่ายผลิต (ProdLead)", "Production Lead")</option>
                        <option value="Operator">@Lang.T("พนักงานปฏิบัติการ (Operator)", "Operator")</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("รหัสผ่าน", "Password")</label>
                    <input type="text" @bind="_editingUser.Password" class="block w-full border border-slate-700 rounded-lg px-4 py-2 focus:ring-mattel-red focus:border-mattel-red sm:text-sm bg-slate-900 text-slate-200" placeholder="@Lang.T("พิมพ์รหัสผ่านที่นี่", "Any default password")" />
                </div>
                
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="text-red-500 text-sm font-medium mt-2">@_errorMessage</div>
                }
            </div>

            <div class="flex justify-end space-x-3 pt-4 border-t border-slate-700">
                <button @onclick="CloseModal" class="px-4 py-2 bg-slate-800 text-slate-300 border border-slate-700 font-medium rounded-lg hover:bg-slate-900 transition-colors text-sm">@Lang.T("ยกเลิก", "Cancel")</button>
                <button @onclick="SaveUser" class="px-4 py-2 bg-mattel-red text-white font-medium rounded-lg hover:bg-mattel-hover transition-colors text-sm">@Lang.T("บันทึกการเปลี่ยนแปลง", "Save Changes")</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private bool _showModal = false;
    private bool _isEditMode = false;
    private UserAccount _editingUser = new();
    private string _errorMessage = "";
    private string _currentRole = "";
    private string _searchQuery = "";
    private string _roleFilter = "All";
    private bool _showRoleFilter = false;
    private int _currentPage = 1;
    private int _pageSize = 10;
    private int _totalItems = 0;
    private List<UserAccount> _allUsers = new();
    private IEnumerable<UserAccount>? _displayUsers;
    private HashSet<string> _selectedUserIds = new();

    private async Task PrintQR(UserAccount user)
    {
        var qr = QrCode.EncodeText(user.EmployeeId, QrCode.Ecc.Medium);
        var svgStr = qr.ToSvgString(4, "#000000", "#ffffff");
        var data = new {
            id = user.EmployeeId,
            name = user.Name,
            role = user.Role
        };
        await JSRuntime.InvokeVoidAsync("printUserQR", svgStr, data);
    }

    private void ToggleSelection(string empId, object? isChecked)
    {
        if (isChecked is bool cb && cb)
            _selectedUserIds.Add(empId);
        else
            _selectedUserIds.Remove(empId);
            
        StateHasChanged();
    }

    private void ToggleRowSelection(string empId)
    {
        ToggleSelection(empId, !_selectedUserIds.Contains(empId));
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        bool selectAll = (bool)(e.Value ?? false);
        if (selectAll && _displayUsers != null)
        {
            foreach (var user in _displayUsers) _selectedUserIds.Add(user.EmployeeId);
        }
        else if (_displayUsers != null)
        {
            foreach (var user in _displayUsers) _selectedUserIds.Remove(user.EmployeeId);
        }
        StateHasChanged();
    }

    private async Task PrintSelectedQRs()
    {
        if (!_selectedUserIds.Any()) return;

        var qrList = new List<object>();
        foreach (var id in _selectedUserIds)
        {
            var user = _allUsers.FirstOrDefault(u => u.EmployeeId == id);
            if (user == null) continue;
            var qr = QrCode.EncodeText(id, QrCode.Ecc.Medium);
            var svgStr = qr.ToSvgString(4, "#000000", "#ffffff");
            qrList.Add(new {
                svg = svgStr,
                id = id,
                name = user.Name,
                role = user.Role
            });
        }

        await JSRuntime.InvokeVoidAsync("printUserQRs", qrList);
        _selectedUserIds.Clear();
    }

    protected override void OnInitialized()
    {
        Lang.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Lang.OnChange -= StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var auth = await Auth.GetAuthAsync();
            var role = auth.Role ?? "";
            _currentRole = role;

            // Admin area validation
            if (string.IsNullOrEmpty(role) || role != "Admin")
            {
                NavManager.NavigateTo("/");
                return;
            }

            await LoadUsers();
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadUsers()
    {
        try
        {
            _allUsers = await Http.GetFromJsonAsync<List<UserAccount>>("api/users") ?? new List<UserAccount>();
            FilterData();
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load users from API.";
        }
    }

    private void ToggleRoleFilter() { _showRoleFilter = !_showRoleFilter; }

    private void SetRoleFilter(string val)
    {
        _roleFilter = val;
        FilterData();
        _showRoleFilter = false;
    }

    private void ClearAll()
    {
        _searchQuery = "";
        _roleFilter = "All";
        _selectedUserIds.Clear();
        _showRoleFilter = false;
        FilterData();
    }

    private void FilterData()
    {
        var lowerQuery = (_searchQuery ?? "").ToLowerInvariant();
        var query = _allUsers.Where(u => 
            (string.IsNullOrWhiteSpace(lowerQuery) || 
             u.EmployeeId.ToLowerInvariant().Contains(lowerQuery) ||
             u.Name.ToLowerInvariant().Contains(lowerQuery) ||
             u.Role.ToLowerInvariant().Contains(lowerQuery)) &&
            (_roleFilter == "All" || u.Role == _roleFilter)
        );

        _totalItems = query.Count();

        // Adjust current page if out of bounds
        int maxPage = (int)Math.Ceiling(_totalItems / (double)_pageSize);
        if (maxPage == 0) maxPage = 1;
        if (_currentPage > maxPage) _currentPage = maxPage;

        _displayUsers = query.Skip((_currentPage - 1) * _pageSize).Take(_pageSize).ToList();
    }

    private void OpenAddModal()
    {
        _editingUser = new UserAccount { Role = "Operator" };
        _isEditMode = false;
        _errorMessage = "";
        _showModal = true;
    }

    private void OpenEditModal(UserAccount user)
    {
        _editingUser = new UserAccount 
        { 
            EmployeeId = user.EmployeeId, 
            Name = user.Name, 
            Role = user.Role, 
            Password = user.Password 
        };
        _isEditMode = true;
        _errorMessage = "";
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
    }

    private async Task SaveUser()
    {
        var actionName = _isEditMode ? "Edit User" : "Add User";
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", actionName, "Are you sure you want to save this user?", "Yes, save", "question");
        if (!confirmed) return;

        if (string.IsNullOrWhiteSpace(_editingUser.EmployeeId) || string.IsNullOrWhiteSpace(_editingUser.Name))
        {
            _errorMessage = "Employee ID and Name are required.";
            return;
        }

        HttpResponseMessage response;

        if (_isEditMode)
        {
            response = await Http.PutAsJsonAsync($"api/users/{_editingUser.EmployeeId}", _editingUser);
        }
        else
        {
            response = await Http.PostAsJsonAsync("api/users", _editingUser);
        }

        if (response.IsSuccessStatusCode)
        {
            await LoadUsers();
            _showModal = false;
            StateHasChanged();
        }
        else
        {
            _errorMessage = "Failed to save user via API.";
        }
    }

    private async Task DeleteUser(UserAccount user)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Delete User", $"Are you sure you want to remove user {user.Name}?", "Yes, delete", "error");
        if (!confirmed) return;

        var response = await Http.DeleteAsync($"api/users/{user.EmployeeId}");
        if (response.IsSuccessStatusCode)
        {
            await LoadUsers();
            StateHasChanged();
        }
        else
        {
            _errorMessage = "Failed to delete from API.";
        }
    }
}
