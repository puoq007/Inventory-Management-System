@page "/admin/users"
@inject frontend.Services.AuthService Auth
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject LanguageService Lang
@implements IDisposable
@using shared.Models
@using System.Net.Http.Json

<PageTitle>Admin - Users | Inventory</PageTitle>

<div class="mb-6 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 mb-2">@Lang.T("จัดการผู้ใช้งาน (User Management)", "User Management")</h1>
        <p class="text-slate-500">@Lang.T("เพิ่ม แก้ไข และจัดการบัญชีผู้ใช้งานรวมถึงสิทธิ์การเข้าถึง", "Add, edit, and manage user accounts and access roles.")</p>
    </div>
    
    <button @onclick="OpenAddModal" class="px-5 py-2.5 bg-blue-600 text-white font-medium text-sm rounded-lg hover:bg-blue-700 shadow-sm transition-colors flex items-center">
        <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        @Lang.T("เพิ่มผู้ใช้งานใหม่", "New User")
    </button>
</div>

@if (_isLoading)
{
    <div class="flex justify-center items-center py-12">
        <div class="text-slate-500 font-medium">@Lang.T("กำลังโหลดข้อมูลผู้ใช้งาน...", "Loading users...")</div>
    </div>
}
else
{
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 mb-8">
        <div class="flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <label for="search" class="block text-sm font-semibold text-slate-700 mb-1.5 flex items-center gap-1.5">
                    <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    @Lang.T("ค้นหาผู้ใช้งาน", "Search Users")
                </label>
                <div class="relative group">
                    <input type="text" id="search" @bind="_searchQuery" @bind:event="oninput" @onkeyup="FilterData"
                           class="block w-full pl-4 pr-10 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all sm:text-sm outline-none" 
                           placeholder="@Lang.T("ค้นหารหัสพนักงาน, ชื่อ, หรือสิทธิ์...", "Search Employee ID, Name, or Role...")" />
                    @if (!string.IsNullOrEmpty(_searchQuery))
                    {
                        <button @onclick='() => { _searchQuery = ""; FilterData(); }' class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-slate-600">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 mb-8 max-w-full">
        <div class="block w-full overflow-x-auto pb-44 -mb-44">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">@Lang.T("รหัสพนักงาน", "Employee ID")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">@Lang.T("ชื่อ-นามสกุล", "Name")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider relative cursor-pointer group select-none" @onclick="ToggleRoleFilter">
                            <div class="flex items-center gap-2 transition-colors @(_roleFilter != "All" ? "text-blue-600" : "text-slate-600 hover:text-blue-700")">
                                <span class="tracking-widest">@Lang.T("สิทธิ์", "Role")@(_roleFilter != "All" ? $": {_roleFilter}" : "")</span>
                                <div class='flex items-center justify-center w-5 h-5 rounded-full transition-all @(_showRoleFilter ? "bg-blue-50 rotate-180" : "group-hover:bg-slate-100")'>
                                    <svg class='w-3.5 h-3.5 @(_roleFilter != "All" ? "text-blue-500" : "text-slate-500")' fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                                @if (_roleFilter != "All")
                                {
                                    <span class="flex h-2 w-2 rounded-full bg-blue-500 animate-pulse shadow-[0_0_8px_rgba(59,130,246,0.5)]"></span>
                                }
                            </div>
                            @if (_showRoleFilter)
                            {
                                <div class="absolute left-6 top-full z-20 mt-2 w-48 bg-white rounded-2xl shadow-2xl border border-slate-100 overflow-hidden transform origin-top-left ring-1 ring-black/5 animate-in fade-in zoom-in duration-200" @onclick:stopPropagation>
                                    <div class="flex items-center justify-between px-4 py-2.5 bg-slate-50/50 border-b border-slate-100">
                                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">@Lang.T("กรองสิทธิ์", "Filter Role")</span>
                                        @if (_roleFilter != "All")
                                        {
                                            <button @onclick='() => SetRoleFilter("All")' class="text-[10px] font-bold text-blue-600 hover:text-blue-800 transition-colors">@Lang.T("ล้างค่า", "RESET")</button>
                                        }
                                    </div>
                                    <div class="py-1.5">
                                        @foreach (var opt in new[] { ("All", "Show All Roles"), ("Admin", "Admin"), ("Engineer", "Engineer"), ("ProdLead", "Prod Lead"), ("Operator", "Operator"), ("Guest", "Guest") })
                                        {
                                            <button @onclick="() => SetRoleFilter(opt.Item1)" 
                                                    class='flex items-center justify-between w-full px-4 py-2 text-xs text-left transition-all @(_roleFilter == opt.Item1 ? "bg-blue-50/80 text-blue-700 font-bold" : "text-slate-600 hover:bg-slate-50")'>
                                                <span>@opt.Item2</span>
                                                @if (_roleFilter == opt.Item1)
                                                {
                                                    <svg class="w-3.5 h-3.5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                    </svg>
                                                }
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">@Lang.T("รหัสผ่าน", "Password")</th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">@Lang.T("ดำเนินการ", "Actions")</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-200">
                    @if (_displayUsers != null && _displayUsers.Any())
                    {
                        @foreach (var user in _displayUsers)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-slate-700">
                                    @user.EmployeeId
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600">
                                    @user.Name
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-3 py-1 inline-flex text-xs leading-5 font-bold rounded-full border shadow-sm
                                        @(user.Role == "Admin" ? "bg-purple-100 text-purple-800 border-purple-200" :
                                          user.Role == "Engineer" ? "bg-blue-100 text-blue-800 border-blue-200" :
                                          user.Role == "ProdLead" ? "bg-emerald-100 text-emerald-800 border-emerald-200" :
                                          "bg-slate-100 text-slate-800 border-slate-200")">
                                        @user.Role
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-400 font-mono tracking-[0.3em] text-lg">
                                    ••••
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                                    <button @onclick="() => OpenEditModal(user)" class="text-indigo-600 hover:text-indigo-900 mr-4 font-semibold px-2 py-1 rounded hover:bg-indigo-50 transition-colors">@Lang.T("แก้ไข", "Edit")</button>
                                    <button @onclick="() => DeleteUser(user)" class="text-red-600 hover:text-red-900 font-semibold px-2 py-1 rounded hover:bg-red-50 transition-colors">@Lang.T("ลบ", "Delete")</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-20 text-center">
                                <div class="flex flex-col items-center justify-center space-y-3">
                                    <div class="p-4 bg-slate-50 rounded-full">
                                        <svg class="w-10 h-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                        </svg>
                                    </div>
                                    <div class="space-y-1">
                                        <h3 class="text-lg font-bold text-slate-900">@Lang.T("ไม่พบผู้ใช้งาน", "No users found")</h3>
                                        <p class="text-sm text-slate-500">@Lang.T("ขออภัย ไม่พบรายชื่อผู้ใช้งานที่ตรงกับคำค้นหาของคุณ", "We couldn't find any accounts matching your search.")</p>
                                    </div>
                                    <button @onclick='() => { _searchQuery = ""; _roleFilter = "All"; FilterData(); }' 
                                            class="mt-4 px-4 py-2 bg-white border border-slate-200 text-blue-600 font-bold text-sm rounded-xl hover:bg-blue-50 hover:border-blue-200 transition-all shadow-sm">
                                        @Lang.T("ล้างการกรองทั้งหมด", "Clear all filters")
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_showModal)
{
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center p-4">
        <div class="relative w-full max-w-md bg-white rounded-2xl shadow-xl p-6 border border-slate-100 text-left">
            <h3 class="text-2xl font-bold text-slate-900 mb-6">@Lang.T(_isEditMode ? "แก้ไขข้อมูลผู้ใช้งาน" : "เพิ่มผู้ใช้งานใหม่", _isEditMode ? "Edit User" : "Add New User")</h3>

            <div class="space-y-4 mb-6">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">@Lang.T("รหัสพนักงาน", "Employee ID")</label>
                    <input type="text" @bind="_editingUser.EmployeeId" disabled="@_isEditMode" class="block w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm disabled:bg-slate-100 disabled:text-slate-500" placeholder="@Lang.T("เช่น 9005", "e.g. 9005")" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">@Lang.T("ชื่อ-นามสกุล", "Full Name")</label>
                    <input type="text" @bind="_editingUser.Name" class="block w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="@Lang.T("เช่น สมชาย รักเรียน", "e.g. John Doe")" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">@Lang.T("ตำแหน่ง / สิทธิ์", "Role")</label>
                    <select @bind="_editingUser.Role" class="block w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                        <option value="Admin">Admin</option>
                        <option value="Engineer">Engineer</option>
                        <option value="ProdLead">@Lang.T("Production Lead", "Production Lead")</option>
                        <option value="Operator">Operator</option>
                        <option value="Guest">Guest</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">@Lang.T("รหัสผ่าน", "Password")</label>
                    <input type="text" @bind="_editingUser.Password" class="block w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="@Lang.T("พิมพ์รหัสผ่านที่นี่", "Any default password")" />
                </div>
                
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="text-red-500 text-sm font-medium mt-2">@_errorMessage</div>
                }
            </div>

            <div class="flex justify-end space-x-3 pt-4 border-t border-slate-100">
                <button @onclick="CloseModal" class="px-4 py-2 bg-white text-slate-700 border border-slate-300 font-medium rounded-lg hover:bg-slate-50 transition-colors text-sm">@Lang.T("ยกเลิก", "Cancel")</button>
                <button @onclick="SaveUser" class="px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors text-sm">@Lang.T("บันทึกการเปลี่ยนแปลง", "Save Changes")</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private bool _showModal = false;
    private bool _isEditMode = false;
    private UserAccount _editingUser = new();
    private string _errorMessage = "";
    private string _currentRole = "";
    private string _searchQuery = "";
    private string _roleFilter = "All";
    private bool _showRoleFilter = false;
    private List<UserAccount> _allUsers = new();
    private IEnumerable<UserAccount>? _displayUsers;

    protected override void OnInitialized()
    {
        Lang.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Lang.OnChange -= StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var auth = await Auth.GetAuthAsync();
            var role = auth.Role ?? "";
            _currentRole = role;

            // Admin area validation
            if (string.IsNullOrEmpty(role) || role != "Admin")
            {
                NavManager.NavigateTo("/");
                return;
            }

            await LoadUsers();
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadUsers()
    {
        try
        {
            _allUsers = await Http.GetFromJsonAsync<List<UserAccount>>("api/users") ?? new List<UserAccount>();
            FilterData();
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load users from API.";
        }
    }

    private void ToggleRoleFilter() { _showRoleFilter = !_showRoleFilter; }

    private void SetRoleFilter(string val)
    {
        _roleFilter = val;
        FilterData();
        _showRoleFilter = false;
    }

    private void FilterData()
    {
        var lowerQuery = (_searchQuery ?? "").ToLowerInvariant();
        _displayUsers = _allUsers.Where(u => 
            (string.IsNullOrWhiteSpace(lowerQuery) || 
             u.EmployeeId.ToLowerInvariant().Contains(lowerQuery) ||
             u.Name.ToLowerInvariant().Contains(lowerQuery) ||
             u.Role.ToLowerInvariant().Contains(lowerQuery)) &&
            (_roleFilter == "All" || u.Role == _roleFilter)
        ).ToList();
    }

    private void OpenAddModal()
    {
        _editingUser = new UserAccount { Role = "Operator" };
        _isEditMode = false;
        _errorMessage = "";
        _showModal = true;
    }

    private void OpenEditModal(UserAccount user)
    {
        _editingUser = new UserAccount 
        { 
            EmployeeId = user.EmployeeId, 
            Name = user.Name, 
            Role = user.Role, 
            Password = user.Password 
        };
        _isEditMode = true;
        _errorMessage = "";
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
    }

    private async Task SaveUser()
    {
        var actionName = _isEditMode ? "Edit User" : "Add User";
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", actionName, "Are you sure you want to save this user?", "Yes, save", "question");
        if (!confirmed) return;

        if (string.IsNullOrWhiteSpace(_editingUser.EmployeeId) || string.IsNullOrWhiteSpace(_editingUser.Name))
        {
            _errorMessage = "Employee ID and Name are required.";
            return;
        }

        HttpResponseMessage response;

        if (_isEditMode)
        {
            response = await Http.PutAsJsonAsync($"api/users/{_editingUser.EmployeeId}", _editingUser);
        }
        else
        {
            response = await Http.PostAsJsonAsync("api/users", _editingUser);
        }

        if (response.IsSuccessStatusCode)
        {
            await LoadUsers();
            _showModal = false;
            StateHasChanged();
        }
        else
        {
            _errorMessage = "Failed to save user via API.";
        }
    }

    private async Task DeleteUser(UserAccount user)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Delete User", $"Are you sure you want to remove user {user.Name}?", "Yes, delete", "error");
        if (!confirmed) return;

        var response = await Http.DeleteAsync($"api/users/{user.EmployeeId}");
        if (response.IsSuccessStatusCode)
        {
            await LoadUsers();
            StateHasChanged();
        }
        else
        {
            _errorMessage = "Failed to delete from API.";
        }
    }
}
