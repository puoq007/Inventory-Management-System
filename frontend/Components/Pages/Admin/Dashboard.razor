@page "/"
@inject frontend.Services.AuthService Auth
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject LanguageService Lang
@using shared.Models
@using System.Linq
@using System.Text
@using System.Net.Http.Json
@implements IDisposable

<PageTitle>@Lang.T("แผงควบคุมผู้ดูแลระบบ | คลัง", "Admin Dashboard | Inventory")</PageTitle>

<div class="mb-6 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div class="mb-8">
        <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">@Lang.T("แผงควบคุม", "Dashboard")</h1>
        <p class="text-slate-500 font-medium mt-1">@Lang.T("สรุปภาพรวมสถานะจิกและการดำเนินงาน", "Overview of inventory status and operations")</p>
    </div>
    @if (_role == "Admin" || _role == "Engineer" || _role == "ProdLead")
    {
        <button @onclick="ExportAnalytics" class="px-4 py-2 bg-slate-800 text-white font-medium text-sm rounded-lg hover:bg-slate-900 shadow-sm transition-colors flex items-center">
            <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
            </svg>
            @Lang.T("ส่งออกรายงาน", "Export Report")
        </button>
    }
</div>

@if (_isLoading)
{
    <div class="flex justify-center items-center py-12">
        <div class="text-slate-500 font-medium">@Lang.T("กำลังโหลดข้อมูลแดชบอร์ด...", "Loading dashboard data...")</div>
    </div>
}
else
{
    <!-- Overview Metrics (from Analytics) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 flex flex-col justify-center cursor-pointer hover:border-blue-200 transition-colors group" @onclick='() => NavManager.NavigateTo("/history")'>
            <div class="flex items-center mb-2">
                <div class="w-8 h-8 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center mr-3">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
                </div>
                @Lang.T("จำนวนรายการ (เดือนนี้)", "Monthly Transactions (Month)")
            </div>
            <div class="text-3xl font-extrabold text-slate-900 tracking-tight">@_monthlyTxnCount</div>
            <a href="/history" class="text-xs text-slate-400 mt-2 group-hover:text-blue-500 transition-colors flex items-center">
                @Lang.T("คลิกเพื่อดูประวัติ", "Click to view history") <svg class="w-3 h-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
        </div>

        <!-- Ready & Available Jigs -->
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 relative overflow-hidden group hover:border-emerald-200 transition-colors cursor-pointer" @onclick='() => NavManager.NavigateTo("/current-status?status=InUse")'>
            <div class="flex items-center text-sm font-semibold text-slate-500 mb-4">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 text-emerald-600 flex items-center justify-center mr-3">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                @Lang.T("อัตราการใช้งาน (%)", "Utilization Rate (%)")
            </div>
            <div class="text-3xl font-extrabold text-slate-900 tracking-tight">@_utilizationRate%</div>
            <a href="/current-status?status=InUse" class="text-xs text-slate-400 mt-2 group-hover:text-emerald-600 transition-colors flex items-center">
                @Lang.T($"กำลังใช้งานอยู่ ({_inUseCount} ชิ้น)", $"Currently in use ({_inUseCount} Jigs)") <svg class="w-3 h-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
            <!-- Decorative bg -->
            <div class="absolute -bottom-6 -right-6 w-24 h-24 bg-emerald-50 rounded-full opacity-50 group-hover:scale-110 transition-transform"></div>
        </div>

        <!-- Needs Attention Jigs -->
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 relative overflow-hidden group hover:border-rose-200 transition-colors cursor-pointer" @onclick='() => NavManager.NavigateTo("/current-status?filter=Issues")'>
            <div class="flex items-center text-sm font-semibold text-slate-500 mb-4">
                <div class="w-8 h-8 rounded-lg bg-rose-100 text-rose-600 flex items-center justify-center mr-3">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                </div>
                @Lang.T("อัตราความเสียหาย (%)", "Repair Rate (%)")
            </div>
            <div class="text-3xl font-extrabold text-rose-600 tracking-tight">@_repairRate%</div>
            <a href="/current-status?filter=Issues" class="text-xs text-slate-400 mt-2 group-hover:text-rose-500 transition-colors flex items-center">
                @Lang.T($"ต้องได้รับการแก้ไข ({_actionRequiredCount} ชิ้น)", $"Needs attention ({_actionRequiredCount} Jigs)") <svg class="w-3 h-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
            <!-- Decorative bg -->
            <div class="absolute -bottom-6 -right-6 w-24 h-24 bg-rose-50 rounded-full opacity-50 group-hover:scale-110 transition-transform"></div>
        </div>
    </div>

    <!-- Details Sections -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Broken / Scrapped Focus -->
        @if (_role != "Guest")
        {
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
                <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center">
                    <svg class="w-5 h-5 text-red-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7a4 4 0 11-8 0 4 4 0 018 0zM9 14a6 6 0 00-6 6v1h12v-1a6 6 0 00-6-6zM21 12h-6" />
                    </svg>
                    @Lang.T("รายการที่ต้องดำเนินการ (พบปัญหา)", "Action Required (Issues)")
                </h2>
                <div class="text-slate-500 text-sm py-4 italic text-center">@Lang.T("ไม่มีปัญหาที่ต้องดำเนินการในขณะนี้", "No current issues requiring action.")</div>
            </div>
        }
        else
        {
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 flex flex-col justify-center text-center">
                <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4 tracking-wider">
                    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <h2 class="text-xl font-bold text-slate-900 mb-2">@Lang.T("ยินดีต้อนรับ!", "Welcome!")</h2>
                <p class="text-slate-500 text-sm">@Lang.T("คุณกำลังอยู่ในโหมดอ่านอย่างเดียวในฐานะผู้เยี่ยมชม คุณสามารถดูสถานะปัจจุบันของจิกที่มีอยู่ได้", "You are currently in <strong>Read-Only Mode</strong> as a Guest. You can view the current status of existing physical jigs.")</p>
                <div class="mt-6 pt-6 border-t border-slate-100">
                    <a href="/login" class="px-4 py-2 bg-slate-100 text-slate-700 font-medium rounded-lg hover:bg-slate-200 transition-colors inline-block text-sm">@Lang.T("ลงชื่อเข้าใช้เพื่อดำเนินการต่อ", "Sign In to Continue")</a>
                </div>
            </div>
        }

        <!-- Recent Transactions -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
            <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center">
                <svg class="w-5 h-5 text-blue-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                @Lang.T("กิจกรรมล่าสุด", "Recent Activity")
            </h2>
            
            <div class="space-y-4">
                @foreach (var txn in _recentTxns)
                {
                    <div class="flex items-start">
                        <div class="flex-shrink-0 mt-1">
                            @if (txn.Action == "CheckOut")
                            {
                                <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                                    </svg>
                                </div>
                            }
                            else if (txn.Action == "CheckIn" || txn.Action == "ForceCheckIn")
                            {
                                <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                                    </svg>
                                </div>
                            }
                            else
                            {
                                <div class="w-8 h-8 rounded-full bg-amber-100 flex items-center justify-center text-amber-600">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                    </svg>
                                </div>
                            }
                        </div>
                        <div class="ml-3">
                            <p class="text-sm font-medium text-slate-900">
                                @{
                                   var jig = _allJigs.FirstOrDefault(j => j.Uid == txn.JigUid);
                                   var jigIdDisplay = jig?.Id ?? txn.JigUid;
                                }
                                <span class="font-mono mr-1">@jigIdDisplay</span> 
                                @if (txn.Action == "CheckOut") { <span>@Lang.T("ถูกเบิกไปโดย", "was borrowed by")</span> }
                                else if (txn.Action == "CheckIn") { <span>@Lang.T("ถูกนำมาคืนโดย", "was returned by")</span> }
                                else if (txn.Action == "ForceCheckIn") { <span>@Lang.T("ถูกบังคับคืนโดย", "was force-returned by")</span> }
                                else if (txn.Action == "ReportIssue") { <span>@Lang.T("ถูกแจ้งพบปัญหาโดย", "was reported with an issue by")</span> }
                                else if (txn.Action == "Scrapped") { <span>@Lang.T("ถูกจำหน่ายออกโดย", "was scrapped by")</span> }
                                <span class="font-semibold text-slate-700 ml-1">@txn.User</span>
                            </p>
                            <p class="text-xs text-slate-500 mt-0.5">@txn.Timestamp.ToString("MMM dd, HH:mm")</p>
                        </div>
                    </div>
                }
                
                @if (!_recentTxns.Any())
                {
                    <div class="text-slate-500 text-sm py-4 italic text-center">@Lang.T("ไม่พบกิจกรรมล่าสุด", "No recent activity detected.")</div>
                }
            </div>
        </div>

        <!-- Top Used Jigs Analytics -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
            <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center">
                <svg class="w-5 h-5 text-purple-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
                @Lang.T("จิกที่ถูกใช้งานสูงสุด", "Top Used Jigs")
            </h2>
            
            <div class="space-y-4 mt-2">
                @if (_topUsedJigs.Any())
                {
                    @foreach (var stat in _topUsedJigs)
                    {
                        var percentage = (_totalCheckouts > 0) ? (stat.Value * 100 / _totalCheckouts) : 0;
                        <div class="relative pt-1">
                            <div class="flex mb-2 items-center justify-between">
                                <div>
                                    <span class="text-xs font-semibold inline-block py-1 px-2 uppercase rounded-full text-purple-600 bg-purple-200">
                                        @stat.Key
                                    </span>
                                </div>
                                <div class="text-right">
                                    <span class="text-xs font-semibold inline-block text-slate-600">
                                        @stat.Value @Lang.T("ครั้ง", "borrows")
                                    </span>
                                </div>
                            </div>
                            <div class="overflow-hidden h-2 mb-4 text-xs flex rounded bg-purple-100">
                                <div style="width:@percentage%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-purple-500"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-slate-500 text-sm py-4 italic text-center">@Lang.T("ไม่มีข้อมูลเพียงพอสำหรับการวิเคราะห์", "Not enough data to analyze.")</div>
                }
            </div>
        </div>
    </div>

    <!-- Activity Overview Chart -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 mt-6">
        <h2 class="text-lg font-bold text-slate-900 mb-6 flex items-center">
            <div class="w-8 h-8 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center mr-3">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c-1.105 0-2 .895-2 2s.895 2 2 2 2-.895 2-2-.895-2-2-2zm12 0c-1.105 0-2 .895-2 2s.895 2 2 2 2-.895 2-2-.895-2-2-2z" /></svg>
            </div>
            @Lang.T("กิจกรรมในสัปดาห์นี้ (จันทร์ - เสาร์)", "Activity This Week (Mon - Sat)")
        </h2>
        
        <!-- Add standard CSS animation for bar growth -->
        <style>
            @@keyframes growUp {
                from { transform: scaleY(0); transform-origin: bottom; }
                to { transform: scaleY(1); transform-origin: bottom; }
            }
            .animate-grow {
                animation: growUp 0.8s cubic-bezier(0.1, 0.9, 0.2, 1) forwards;
            }
        </style>

        <!-- Activity This Week Graph Header removed since it is built into the relative scope below -->

        <div class="relative w-full mt-4" style="height: 320px;">
            @{ 
                var maxCheckOut = _checkOutCounts.Length > 0 ? _checkOutCounts.Max() : 0;
                var maxCheckIn = _checkInCounts.Length > 0 ? _checkInCounts.Max() : 0;
                var maxCleaning = _cleaningCounts.Length > 0 ? _cleaningCounts.Max() : 0;
                var maxActivity = Math.Max(maxCheckOut, Math.Max(maxCheckIn, maxCleaning)); 
                if (maxActivity == 0) maxActivity = 4; // fallback for empty graph
            }

            <!-- Legend Top Right Floating -->
            <div style="position: absolute; top: -16px; right: 0; display: flex; align-items: center; gap: 12px; font-size: 11px; font-weight: 500; color: #475569; z-index: 20;">
                <div style="display: flex; align-items: center; background: white; padding: 6px 10px; border-radius: 9999px; box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); border: 1px solid #f1f5f9;">
                    <div style="width: 10px; height: 10px; margin-right: 6px; border-radius: 3px; background: linear-gradient(to right, #4338ca 0%, #818cf8 35%, #312e81 100%);"></div> 
                    @Lang.T("ยืมออก (Check Outs)", "Check Outs")
                </div>
                <div style="display: flex; align-items: center; background: white; padding: 6px 10px; border-radius: 9999px; box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); border: 1px solid #f1f5f9;">
                    <div style="width: 10px; height: 10px; margin-right: 6px; border-radius: 3px; background: linear-gradient(to right, #047857 0%, #34d399 35%, #064e3b 100%);"></div> 
                    @Lang.T("คืนเข้าตู้ (Store)", "Store")
                </div>
                <div style="display: flex; align-items: center; background: white; padding: 6px 10px; border-radius: 9999px; box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); border: 1px solid #f1f5f9;">
                    <div style="width: 10px; height: 10px; margin-right: 6px; border-radius: 3px; background: linear-gradient(to right, #b45309 0%, #fbbf24 35%, #78350f 100%);"></div> 
                    @Lang.T("ส่งล้าง (Cleaning)", "Cleaning")
                </div>
            </div>
            
            <!-- Guaranteed Absolute Exact Bounded Plot Area -->
            <!-- The plot height is fixed to bottom-8 (leaving exactly 32px for X-axis labels) -->
            <div style="position: absolute; top: 40px; left: 40px; right: 16px; bottom: 32px; border-bottom: 1px solid transparent;">
                
                <!-- Y-Axis Grid Lines (Perfectly absolute 100% height map) -->
                <div style="position: absolute; top: 0; bottom: 0; left: 0; right: 0; pointer-events: none; z-index: 0;">
                    <!-- Max Activity -->
                    <div style="position: absolute; top: 0%; left: 0; width: 100%; border-top: 1px solid #f1f5f9;">
                        <span style="position: absolute; top: -7px; left: -24px; color: #94a3b8; font-weight: 500; font-size: 10px;">@(maxActivity)</span>
                    </div>
                    <div style="position: absolute; top: 25%; left: 0; width: 100%; border-top: 1px solid #f1f5f9;">
                        <span style="position: absolute; top: -7px; left: -24px; color: #94a3b8; font-weight: 500; font-size: 10px;">@(maxActivity * 3 / 4)</span>
                    </div>
                    <div style="position: absolute; top: 50%; left: 0; width: 100%; border-top: 1px solid #f1f5f9;">
                        <span style="position: absolute; top: -7px; left: -24px; color: #94a3b8; font-weight: 500; font-size: 10px;">@(maxActivity / 2)</span>
                    </div>
                    <div style="position: absolute; top: 75%; left: 0; width: 100%; border-top: 1px solid #f1f5f9;">
                        <span style="position: absolute; top: -7px; left: -24px; color: #94a3b8; font-weight: 500; font-size: 10px;">@(maxActivity / 4)</span>
                    </div>
                    <!-- Exactly Zero -->
                    <div style="position: absolute; top: 100%; left: 0; width: 100%; border-top: 1px solid #cbd5e1;">
                        <span style="position: absolute; top: -7px; left: -24px; color: #64748b; font-weight: bold; font-size: 10px;">0</span>
                    </div>
                </div>

                <!-- Plot Area Elements -->
                <div style="position: absolute; top: 0; bottom: 0; left: 0; right: 0; display: flex; justify-content: space-between; align-items: flex-end; z-index: 10;">
                    @for (int i = 0; i < 6; i++)
                    {
                        var currentDayAttr = _startOfWeek.AddDays(i);

                        <div style="position: relative; flex: 1 1 0%; height: 100%; display: flex; flex-direction: column; justify-content: flex-end; align-items: center; pointer-events: auto;">
                            
                            <!-- Triple Bars Wrapper -->
                            <div style="display: flex; align-items: flex-end; justify-content: center; width: 100%; height: 100%; gap: 6px;">
                                @{
                                    var outCount = _checkOutCounts[i];
                                    var inCount = _checkInCounts[i];
                                    var cleanCount = _cleaningCounts[i];
                                    int hOut = maxActivity > 0 ? (int)((outCount * 100.0) / maxActivity) : 0;
                                    int hIn = maxActivity > 0 ? (int)((inCount * 100.0) / maxActivity) : 0;
                                    int hClean = maxActivity > 0 ? (int)((cleanCount * 100.0) / maxActivity) : 0;
                                }

                                <!-- CheckOut 3D Cylinder -->
                                @if (outCount > 0)
                                {
                                    <div class="animate-grow" style="position: relative; flex: 0 0 16px; display: flex; flex-direction: column; justify-content: flex-end; z-index: 10; border-bottom-left-radius: 2px; border-bottom-right-radius: 2px; height: @(hOut)%; background: linear-gradient(to right, #4338ca 0%, #818cf8 35%, #312e81 100%); box-shadow: inset -1px 0 3px rgba(0,0,0,0.15), 2px 0 4px rgba(0,0,0,0.1);">
                                         <div style="position: absolute; left: 0; width: 100%; border-radius: 50%; background: #a5b4fc; height: 6px; top: -3px;"></div>
                                         <span style="position: absolute; left: 50%; transform: translateX(-50%); top: -20px; font-size: 10px; font-weight: 800; color: #4338ca;">@outCount</span>
                                    </div>
                                }
                                else
                                {
                                    <div style="flex: 0 0 16px;"></div>
                                }

                                <!-- CheckIn 3D Cylinder (To Store) -->
                                @if (inCount > 0)
                                {
                                    <div class="animate-grow" style="position: relative; flex: 0 0 16px; display: flex; flex-direction: column; justify-content: flex-end; z-index: 10; border-bottom-left-radius: 2px; border-bottom-right-radius: 2px; height: @(hIn)%; background: linear-gradient(to right, #047857 0%, #34d399 35%, #064e3b 100%); box-shadow: inset -1px 0 3px rgba(0,0,0,0.15), 2px 0 4px rgba(0,0,0,0.1);">
                                         <div style="position: absolute; left: 0; width: 100%; border-radius: 50%; background: #6ee7b7; height: 6px; top: -3px;"></div>
                                         <span style="position: absolute; left: 50%; transform: translateX(-50%); top: -20px; font-size: 10px; font-weight: 800; color: #059669;">@inCount</span>
                                    </div>
                                }
                                else
                                {
                                    <div style="flex: 0 0 16px;"></div>
                                }

                                <!-- Cleaning 3D Cylinder -->
                                @if (cleanCount > 0)
                                {
                                    <div class="animate-grow" style="position: relative; flex: 0 0 16px; display: flex; flex-direction: column; justify-content: flex-end; z-index: 10; border-bottom-left-radius: 2px; border-bottom-right-radius: 2px; height: @(hClean)%; background: linear-gradient(to right, #b45309 0%, #fbbf24 35%, #78350f 100%); box-shadow: inset -1px 0 3px rgba(0,0,0,0.15), 2px 0 4px rgba(0,0,0,0.1);">
                                         <div style="position: absolute; left: 0; width: 100%; border-radius: 50%; background: #fcd34d; height: 6px; top: -3px;"></div>
                                         <span style="position: absolute; left: 50%; transform: translateX(-50%); top: -20px; font-size: 10px; font-weight: 800; color: #b45309;">@cleanCount</span>
                                    </div>
                                }
                                else
                                {
                                    <div style="flex: 0 0 16px;"></div>
                                }
                            </div>

                            <!-- X-Axis Label explicitly placed below -->
                            <div style="position: absolute; bottom: -28px; width: 100%; text-align: center; display: flex; justify-content: center;">
                                <span class="hidden md:block" style="font-size: 11px; font-weight: 600; color: #64748b;">@currentDayAttr.ToString("ddd, MMM d")</span>
                                <span class="md:hidden" style="font-size: 11px; font-weight: 600; color: #64748b;">@currentDayAttr.ToString("dd")</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string _role = "";
    private bool _isLoading = true;
    private int _totalJigs = 0;
    private int _availableJigs = 0;
    private int _inUseCount = 0; // Renamed from _inUseJigs
    private int _actionRequiredCount = 0; // Renamed from _issueJigs
    private int _monthlyTxnCount = 0;
    private double _utilizationRate = 0;
    private double _repairRate = 0;
    private int[] _checkOutCounts = new int[6];
    private int[] _checkInCounts = new int[6];
    private int[] _cleaningCounts = new int[6];
    private DateTime _startOfWeek;
    
    private Dictionary<string, int> _topUsedJigs = new();
    private int _totalCheckouts = 0;
    
    private List<TransactionRow> _recentTxns = new();
    private List<TransactionRow> _allTxns = new();
    private List<Jig> _allJigs = new();
    // Removed unused _isGuest field

    protected override void OnInitialized()
    {
        Lang.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Lang.OnChange -= StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var auth = await Auth.GetAuthAsync();
            _role = auth.Role ?? "";

            if (string.IsNullOrEmpty(_role))
            {
                NavManager.NavigateTo("/login");
                return;
            }

            await LoadData();
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        try
        {
            var txnsTask = Http.GetFromJsonAsync<List<TransactionRow>>("api/transactions");
            var jigsTask = Http.GetFromJsonAsync<List<Jig>>("api/jigs");

            await Task.WhenAll(txnsTask, jigsTask);

            _allTxns = await txnsTask ?? new List<TransactionRow>();
            _allJigs = await jigsTask ?? new List<Jig>();

            CalculateStats();
        }
        catch (Exception)
        {
            // Handle error minimally
        }
    }

    private void CalculateStats()
    {
        _recentTxns = _allTxns.OrderByDescending(t => t.Timestamp).Take(5).ToList();
        
        _totalJigs = _allJigs.Count;
        _availableJigs = _allJigs.Count(j => j.Status == "Available");
        _inUseCount = _allJigs.Count(j => j.Status == "InUse");
        _actionRequiredCount = _allJigs.Count(j => j.Condition == "NeedsCleaning" || j.Condition == "UnderRepair" || j.Condition == "Broken");
        
        var thirtyDaysAgo = DateTime.Now.AddDays(-30);
        _monthlyTxnCount = _allTxns.Count(t => t.Timestamp >= thirtyDaysAgo);

        if (_totalJigs > 0)
        {
            _utilizationRate = Math.Round((double)_inUseCount * 100 / _totalJigs, 1);
            _repairRate = Math.Round((double)_actionRequiredCount * 100 / _totalJigs, 1);
        }
        else
        {
            _utilizationRate = 0;
            _repairRate = 0;
        }

        // Calculate Analytics
        var checkouts = _allTxns.Where(t => t.Action == "CheckOut").ToList();
        _totalCheckouts = checkouts.Count;
        _topUsedJigs = checkouts
            .GroupBy(t => {
                var jig = _allJigs.FirstOrDefault(j => j.Uid == t.JigUid);
                return jig?.Id ?? t.JigUid ?? "UNKNOWN";
            })
            .Select(g => new { JigId = g.Key, Count = g.Count() })
            .OrderByDescending(x => x.Count)
            .Take(5)
            .ToDictionary(x => x.JigId, x => x.Count);

        // Calculate Activity This Week (Mon-Sat)
        DateTime today = DateTime.Now.Date;
        int diff = (7 + (today.DayOfWeek - DayOfWeek.Monday)) % 7;
        _startOfWeek = today.AddDays(-1 * diff).Date;
        _checkOutCounts = new int[6]; // Reset
        _checkInCounts = new int[6];
        _cleaningCounts = new int[6];
        
        foreach (var txn in _allTxns)
        {
            if (txn.Timestamp >= _startOfWeek)
            {
                int dayDiff = (int)(txn.Timestamp.Date - _startOfWeek).TotalDays;
                // Exclude Sunday (dayDiff == 6) and future out-of-bounds days
                if (dayDiff >= 0 && dayDiff < 6)
                {
                    if (txn.Action == "CheckOut")
                        _checkOutCounts[dayDiff]++;
                    else if (txn.Action == "CheckInToCleaning")
                        _cleaningCounts[dayDiff]++;
                    else if (txn.Action == "CheckIn" || txn.Action == "ReturnToStore" || txn.Action == "ForceCheckIn")
                        _checkInCounts[dayDiff]++;
                }
            }
        }
    }

    private async Task ExportAnalytics()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Date Generated," + DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"));
        sb.AppendLine();
        
        sb.AppendLine("Overall Status");
        sb.AppendLine($"Total Jigs,{_totalJigs}");
        sb.AppendLine($"Available,{_availableJigs}");
        sb.AppendLine($"In Use,{_inUseCount}");
        sb.AppendLine($"Issues,{_actionRequiredCount}");
        sb.AppendLine();
        
        sb.AppendLine("Top Used Jigs");
        sb.AppendLine("JigId,CheckoutCount");
        foreach(var stat in _topUsedJigs)
        {
            sb.AppendLine($"{stat.Key},{stat.Value}");
        }
        sb.AppendLine();

        sb.AppendLine("Action Required / Broken");
        sb.AppendLine("JigId,SpecId,Condition,Status");

        var csvContent = sb.ToString();
        var fileName = $"analytics_report_{DateTime.Now.ToString("yyyyMMdd")}.csv";
        
        await JSRuntime.InvokeVoidAsync("downloadTextFile", fileName, csvContent);
    }
}
