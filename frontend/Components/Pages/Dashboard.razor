@page "/"
@inject frontend.Services.AuthService Auth
@inject ApiClientService Api
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject LanguageService Lang
@using shared.Models
@using System.Linq
@using System.Text
@using System.Net.Http.Json
@implements IDisposable

<PageTitle>@Lang.T("แดชบอร์ด | คลัง", "Dashboard | Inventory")</PageTitle>

<div class="mb-6 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div class="mb-8">
        <h1 class="text-3xl font-extrabold text-slate-100 mb-2">@Lang.T("แดชบอร์ด", "Dashboard")</h1>
        <p class="text-slate-400 font-medium mt-1">@Lang.T("สรุปภาพรวมสถานะจิกและการดำเนินงาน", "Overview of inventory status and operations")</p>
    </div>
    @if (_role == "Admin" || _role == "Engineer" || _role == "ProdLead")
    {
        <button @onclick="ExportAnalytics" class="px-4 py-2 bg-slate-800 text-slate-100 font-medium text-sm rounded-lg hover:bg-slate-900 shadow-xl transition-colors flex items-center">
            <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
            </svg>
            @Lang.T("ส่งออกรายงาน PDF", "Export PDF Report")
        </button>
    }
</div>

@if (_isLoading)
{
    <div class="flex justify-center items-center py-12">
        <div class="text-slate-400 font-medium">@Lang.T("กำลังโหลดข้อมูลแดชบอร์ด...", "Loading dashboard data...")</div>
    </div>
}
else
{
    <!-- Overview Metrics (from Analytics) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-slate-800 rounded-2xl shadow-xl border border-slate-700 p-6 flex flex-col justify-center cursor-pointer hover:border-blue-800 transition-colors group" @onclick='() => NavManager.NavigateTo("/history")'>
            <div class="flex items-center mb-2">
                <div class="w-8 h-8 rounded-lg bg-blue-900/40 text-blue-400 flex items-center justify-center mr-3">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
                </div>
                @Lang.T("จำนวนรายการ (เดือนนี้)", "Monthly Transactions (Month)")
            </div>
            <div class="text-3xl font-extrabold text-slate-100 tracking-tight">@_monthlyTxnCount</div>
            <a href="/history" class="text-xs text-slate-400 mt-2 group-hover:text-blue-500 transition-colors flex items-center">
                @Lang.T("คลิกเพื่อดูประวัติ", "Click to view history") <svg class="w-3 h-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
        </div>

        <!-- Ready & Available Jigs -->
        <div class="bg-slate-800 rounded-2xl p-6 shadow-xl border border-slate-700 relative overflow-hidden group hover:border-emerald-800 transition-colors cursor-pointer" @onclick='() => NavManager.NavigateTo("/current-status?status=InUse")'>
            <div class="flex items-center text-sm font-semibold text-slate-400 mb-4">
                <div class="w-8 h-8 rounded-lg bg-emerald-900/40 text-emerald-400 flex items-center justify-center mr-3">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                @Lang.T("อัตราการใช้งาน (%)", "Utilization Rate (%)")
            </div>
            <div class="text-3xl font-extrabold text-slate-100 tracking-tight">@_utilizationRate%</div>
            <a href="/current-status?status=InUse" class="text-xs text-slate-400 mt-2 group-hover:text-emerald-400 transition-colors flex items-center">
                @Lang.T($"กำลังใช้งานอยู่ ({_inUseCount} ชิ้น)", $"Currently in use ({_inUseCount} Jigs)") <svg class="w-3 h-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
            <!-- Decorative bg -->
            <div class="absolute -bottom-6 -right-6 w-24 h-24 bg-emerald-900/30 rounded-full opacity-50 group-hover:scale-110 transition-transform"></div>
        </div>

        <!-- Needs Attention Jigs -->
        <div class="bg-slate-800 rounded-2xl p-6 shadow-xl border border-slate-700 relative overflow-hidden group hover:border-rose-800 transition-colors cursor-pointer" @onclick='() => NavManager.NavigateTo("/current-status?condition=Issues")'>
            <div class="flex items-center text-sm font-semibold text-slate-400 mb-4">
                <div class="w-8 h-8 rounded-lg bg-rose-900/40 text-rose-400 flex items-center justify-center mr-3">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                </div>
                @Lang.T("อัตราความเสียหาย (%)", "Repair Rate (%)")
            </div>
            <div class="text-3xl font-extrabold text-rose-400 tracking-tight">@_repairRate%</div>
            <a href="/current-status?condition=Issues" class="text-xs text-slate-400 mt-2 group-hover:text-rose-500 transition-colors flex items-center">
                @Lang.T($"ต้องได้รับการแก้ไข ({_actionRequiredCount} ชิ้น)", $"Needs attention ({_actionRequiredCount} Jigs)") <svg class="w-3 h-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
            <!-- Decorative bg -->
            <div class="absolute -bottom-6 -right-6 w-24 h-24 bg-rose-900/30 rounded-full opacity-50 group-hover:scale-110 transition-transform"></div>
        </div>
    </div>

    <!-- Details Sections -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Broken / Scrapped Focus -->
        @if (_role != "Guest")
        {
            <div class="bg-slate-800 rounded-2xl shadow-xl border border-slate-700 p-6">
                <div class="flex items-center justify-between mb-4 group cursor-pointer" @onclick='() => NavManager.NavigateTo("/current-status?condition=Issues")'>
                    <h2 class="text-lg font-bold text-slate-100 group-hover:text-red-700 transition-colors flex items-center">
                        <svg class="w-5 h-5 text-red-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7a4 4 0 11-8 0 4 4 0 018 0zM9 14a6 6 0 00-6 6v1h12v-1a6 6 0 00-6-6zM21 12h-6" />
                        </svg>
                        @Lang.T("รายการที่ต้องดำเนินการ (พบปัญหา)", "Action Required (Issues)")
                    </h2>
                    <svg class="w-5 h-5 text-slate-400 group-hover:text-red-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </div>
                
                @if (_actionRequiredCount > 0)
                {
                    <div class="space-y-3">
                        @foreach (var jig in _allJigs.Where(j => j.Condition == "NeedsCleaning" || j.Condition == "Broken" || j.Condition == "Lost").Take(5))
                        {
                            <div class="flex items-center justify-between p-3 bg-red-900/30 rounded-xl border border-red-900/40 cursor-pointer hover:bg-red-900/40 transition-colors" @onclick='() => NavManager.NavigateTo($"/current-status?condition=Issues")'>
                                <div class="flex gap-3 items-center">
                                    <div class="w-8 h-8 rounded-full bg-red-900/40 flex items-center justify-center text-red-400 shadow-xl border border-red-900/40">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg> 
                                    </div>
                                    <div>
                                        <div class="text-sm font-bold text-slate-200">@jig.Id</div>
                                        <div class="text-xs text-red-400 font-medium whitespace-nowrap overflow-hidden text-ellipsis max-w-[150px]">
                                            @Lang.T(GetConditionThai(jig.Condition), jig.Condition)
                                        </div>
                                    </div>
                                </div>
                                <div class="text-[10px] text-slate-400 font-medium">@FormatDate(jig.UpdatedAt)</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-slate-400 text-sm py-4 italic text-center">@Lang.T("ไม่มีปัญหาที่ต้องดำเนินการในขณะนี้", "No current issues requiring action.")</div>
                }
            </div>
        }
        else
        {
            <div class="bg-slate-800 rounded-2xl shadow-xl border border-slate-700 p-6 flex flex-col justify-center text-center">
                <div class="w-16 h-16 bg-blue-900/40 text-blue-400 rounded-full flex items-center justify-center mx-auto mb-4 tracking-wider">
                    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <h2 class="text-xl font-bold text-slate-100 mb-2">@Lang.T("ยินดีต้อนรับ!", "Welcome!")</h2>
                <p class="text-slate-400 text-sm">@Lang.T("คุณกำลังอยู่ในโหมดอ่านอย่างเดียวในฐานะผู้เยี่ยมชม คุณสามารถดูสถานะปัจจุบันของจิกที่มีอยู่ได้", "You are currently in <strong>Read-Only Mode</strong> as a Guest. You can view the current status of existing physical jigs.")</p>
                <div class="mt-6 pt-6 border-t border-slate-700">
                    <a href="/login" class="px-4 py-2 bg-mattel-red text-white font-medium rounded-lg hover:bg-mattel-hover transition-colors inline-block text-sm">@Lang.T("ลงชื่อเข้าใช้เพื่อดำเนินการต่อ", "Sign In to Continue")</a>
                </div>
            </div>
        }

        <!-- Recent Transactions -->
        <div class="bg-slate-800 rounded-2xl shadow-xl border border-slate-700 p-6">
            <h2 class="text-lg font-bold text-slate-100 mb-4 flex items-center">
                <svg class="w-5 h-5 text-blue-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                @Lang.T("กิจกรรมล่าสุด", "Recent Activity")
            </h2>
            
            <div class="space-y-4">
                @foreach (var txn in _recentTxns)
                {
                    <div class="flex items-start">
                        <div class="flex-shrink-0 mt-1">
                            @if (txn.Action == "CheckOut")
                            {
                                <div class="w-8 h-8 rounded-full bg-blue-900/40 flex items-center justify-center text-blue-400">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                                    </svg>
                                </div>
                            }
                            else if (txn.Action == "CheckIn" || txn.Action == "ForceCheckIn")
                            {
                                <div class="w-8 h-8 rounded-full bg-emerald-900/40 flex items-center justify-center text-emerald-400">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                                    </svg>
                                </div>
                            }
                            else
                            {
                                <div class="w-8 h-8 rounded-full bg-amber-900/40 flex items-center justify-center text-amber-400">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                    </svg>
                                </div>
                            }
                        </div>
                        <div class="ml-3">
                            <p class="text-sm font-medium text-slate-100">
                                @{
                                   var jig = _allJigs.FirstOrDefault(j => j.Uid == txn.JigUid);
                                   var jigIdDisplay = jig?.Id ?? txn.JigUid;
                                }
                                <span class="font-mono mr-1">@jigIdDisplay</span> 
                                @if (txn.Action == "CheckOut") { <span>@Lang.T("ถูกเบิกไปโดย", "was borrowed by")</span> }
                                else if (txn.Action == "CheckIn") { <span>@Lang.T("ถูกนำมาคืนโดย", "was returned by")</span> }
                                else if (txn.Action == "ForceCheckIn") { <span>@Lang.T("ถูกบังคับคืนโดย", "was force-returned by")</span> }
                                else if (txn.Action == "ReportIssue") { <span>@Lang.T("ถูกแจ้งพบปัญหาโดย", "was reported with an issue by")</span> }
                                else if (txn.Action == "Scrapped") { <span>@Lang.T("ถูกจำหน่ายออกโดย", "was scrapped by")</span> }
                                <span class="font-semibold text-slate-300 ml-1">@txn.User</span>
                            </p>
                            <p class="text-xs text-slate-400 mt-0.5">@FormatDate(txn.Timestamp)</p>
                        </div>
                    </div>
                }
                
                @if (!_recentTxns.Any())
                {
                    <div class="text-slate-400 text-sm py-4 italic text-center">@Lang.T("ไม่พบกิจกรรมล่าสุด", "No recent activity detected.")</div>
                }
            </div>
        </div>

        <!-- Top Used Jigs Analytics -->
        <div class="bg-slate-800 rounded-2xl shadow-xl border border-slate-700 p-6">
            <h2 class="text-lg font-bold text-slate-100 mb-4 flex items-center">
                <svg class="w-5 h-5 text-purple-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
                @Lang.T("จิกที่ถูกใช้งานสูงสุด", "Top Used Jigs")
            </h2>
            
            <div class="space-y-4 mt-2">
                @if (_topUsedJigs.Any())
                {
                    @foreach (var stat in _topUsedJigs)
                    {
                        var percentage = (_totalCheckouts > 0) ? (stat.Value * 100 / _totalCheckouts) : 0;
                        <div class="relative pt-1">
                            <div class="flex mb-2 items-center justify-between">
                                <div>
                                    <span class="text-xs font-semibold inline-block py-1 px-2 uppercase rounded-full text-purple-400 bg-purple-900/50">
                                        @stat.Key
                                    </span>
                                </div>
                                <div class="text-right">
                                    <span class="text-xs font-semibold inline-block text-slate-400">
                                        @stat.Value @Lang.T("ครั้ง", "borrows")
                                    </span>
                                </div>
                            </div>
                            <div class="overflow-hidden h-2 mb-4 text-xs flex rounded bg-purple-900/40">
                                <div style="width:@percentage%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-purple-500"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-slate-400 text-sm py-4 italic text-center">@Lang.T("ไม่มีข้อมูลเพียงพอสำหรับการวิเคราะห์", "Not enough data to analyze.")</div>
                }
            </div>
        </div>
    </div>

    <!-- Activity Overview Chart -->
    <div class="bg-slate-800 rounded-2xl shadow-xl border border-slate-700 p-6 mt-6">
        <h2 class="text-lg font-bold text-slate-100 mb-6 flex items-center">
            <div class="w-8 h-8 rounded-full bg-purple-900/40 text-purple-400 flex items-center justify-center mr-3">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c-1.105 0-2 .895-2 2s.895 2 2 2 2-.895 2-2-.895-2-2-2zm12 0c-1.105 0-2 .895-2 2s.895 2 2 2 2-.895 2-2-.895-2-2-2z" /></svg>
            </div>
            @Lang.T("กิจกรรมในสัปดาห์นี้ (จันทร์ - เสาร์)", "Activity This Week (Mon - Sat)")
        </h2>
        
        <div class="relative w-full mt-4" style="height: 320px;">
            <canvas id="activityChart"></canvas>
        </div>
    </div>
}
