@page "/current-status"
@inject frontend.Services.AuthService Auth
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@using shared.Models
@using System.Threading.Tasks
@using System.Net.Http.Json
@implements IAsyncDisposable

<PageTitle>Current Status - Inventory</PageTitle>

<div class="mb-6 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 mb-2">Current Status</h1>
        <p class="text-slate-500">Search and manage physical jigs</p>
    </div>
    @if (!string.IsNullOrEmpty(_role))
    {
        <div class="text-sm font-medium text-slate-500 bg-slate-100 px-3 py-1.5 rounded-full">
            Role: <span class="text-slate-800">@_role</span>
        </div>
    }
</div>

<div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 mb-8">
    <div class="flex flex-col md:flex-row gap-4">
        <div class="flex-1">
            <label for="search" class="block text-sm font-medium text-slate-700 mb-1">Search Part Number or Jig ID</label>
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
                <input type="text" id="search" @bind="_searchQuery" @bind:event="oninput" 
                       class="block w-full pl-10 pr-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="e.g. PN-1001 or J001" />
            </div>
        </div>
        <div class="flex items-end space-x-3 w-full md:w-auto mt-4 md:mt-0">
            <button @onclick="OpenScanModal" class="w-full md:w-auto px-4 py-2 bg-slate-100 text-slate-700 font-medium rounded-lg hover:bg-slate-200 focus:outline-none transition-colors border border-slate-200 flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                Scan QR
            </button>
            <button @onclick="FilterData" class="w-full md:w-auto px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                Search
            </button>
        </div>
    </div>
</div>

@if (_showScanModal)
{
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center">
        <div class="relative w-full max-w-sm bg-white rounded-2xl shadow-xl p-6 border border-slate-100 text-center">
            <h3 class="text-xl font-bold text-slate-900 mb-4">Scan QR Code</h3>
            <div id="qr-reader" class="mx-auto w-full mb-4 overflow-hidden rounded-lg bg-slate-50 border border-slate-200" style="min-height: 250px;"></div>
            <button @onclick="CloseScanModal" class="px-6 py-2 bg-slate-100 text-slate-700 font-medium rounded-lg hover:bg-slate-200 transition-colors">Cancel</button>
        </div>
    </div>
}

@if (_isLoading)
{
    <div class="flex items-center justify-center py-12">
        <div class="text-slate-500 font-medium tracking-wide">Loading status variables...</div>
    </div>
}
else if (_displayJigs == null)
{
    <div class="flex items-center justify-center py-12">
        <div class="text-slate-500 font-medium tracking-wide">Enter a search term to find jigs...</div>
    </div>
}
else
{
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 max-w-full relative">
        <div class="block w-full overflow-x-auto pb-64 -mb-64">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Jig ID</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Specification</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider relative cursor-pointer group select-none" @onclick="ToggleStatusFilter">
                            <div class="flex items-center gap-2 transition-colors @(_statusFilter != "All" ? "text-blue-600" : "text-slate-600 hover:text-blue-700")">
                                <span class="tracking-widest">Status@(_statusFilter != "All" ? $": {(_statusFilter == "InUse" ? "In Use" : _statusFilter)}" : "")</span>
                                <div class='flex items-center justify-center w-5 h-5 rounded-full transition-all @(_showStatusFilter ? "bg-blue-50 rotate-180" : "group-hover:bg-slate-100")'>
                                    <svg class='w-3.5 h-3.5 @(_statusFilter != "All" ? "text-blue-500" : "text-slate-500")' fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                                @if (_statusFilter != "All")
                                {
                                    <span class="flex h-2 w-2 rounded-full bg-blue-500 animate-pulse shadow-[0_0_8px_rgba(59,130,246,0.5)]"></span>
                                }
                            </div>
                            @if (_showStatusFilter)
                            {
                                <div class="absolute left-6 top-full z-20 mt-2 w-48 bg-white rounded-2xl shadow-2xl border border-slate-100 overflow-hidden transform origin-top-left ring-1 ring-black/5 animate-in fade-in zoom-in duration-200" @onclick:stopPropagation>
                                    <div class="flex items-center justify-between px-4 py-2.5 bg-slate-50/50 border-b border-slate-100">
                                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Filter Status</span>
                                        @if (_statusFilter != "All")
                                        {
                                            <button @onclick='() => SetStatusFilter("All")' class="text-[10px] font-bold text-blue-600 hover:text-blue-800 transition-colors">RESET</button>
                                        }
                                    </div>
                                    <div class="py-1.5">
                                        @foreach (var opt in new[] { ("All", "Show All Statuses"), ("Available", "Available"), ("InUse", "In Use"), ("Cleaning", "Cleaning"), ("Evaluation", "Evaluation") })
                                        {
                                            <button @onclick="() => SetStatusFilter(opt.Item1)" 
                                                    class='flex items-center justify-between w-full px-4 py-2 text-xs text-left transition-all @(_statusFilter == opt.Item1 ? "bg-blue-50/80 text-blue-700 font-bold" : "text-slate-600 hover:bg-slate-50")'>
                                                <span>@opt.Item2</span>
                                                @if (_statusFilter == opt.Item1)
                                                {
                                                    <svg class="w-3.5 h-3.5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                    </svg>
                                                }
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Location</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider relative cursor-pointer group select-none" @onclick="ToggleConditionFilter">
                            <div class="flex items-center gap-2 transition-colors @(_conditionFilter != "All" ? "text-blue-600" : "text-slate-600 hover:text-blue-700")">
                                <span class="tracking-widest">Condition@(_conditionFilter != "All" ? $": {(_conditionFilter == "NeedsCleaning" ? "Needs Clean" : _conditionFilter == "UnderRepair" ? "Repair" : _conditionFilter)}" : "")</span>
                                <div class='flex items-center justify-center w-5 h-5 rounded-full transition-all @(_showConditionFilter ? "bg-blue-50 rotate-180" : "group-hover:bg-slate-100")'>
                                    <svg class='w-3.5 h-3.5 @(_conditionFilter != "All" ? "text-blue-500" : "text-slate-500")' fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                                @if (_conditionFilter != "All")
                                {
                                    <span class="flex h-2 w-2 rounded-full bg-blue-500 animate-pulse shadow-[0_0_8px_rgba(59,130,246,0.5)]"></span>
                                }
                            </div>
                            @if (_showConditionFilter)
                            {
                                <div class="absolute left-6 top-full z-20 mt-2 w-48 bg-white rounded-2xl shadow-2xl border border-slate-100 overflow-hidden transform origin-top-left ring-1 ring-black/5 animate-in fade-in zoom-in duration-200" @onclick:stopPropagation>
                                    <div class="flex items-center justify-between px-4 py-2.5 bg-slate-50/50 border-b border-slate-100">
                                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Filter Condition</span>
                                        @if (_conditionFilter != "All")
                                        {
                                            <button @onclick='() => SetConditionFilter("All")' class="text-[10px] font-bold text-blue-600 hover:text-blue-800 transition-colors">RESET</button>
                                        }
                                    </div>
                                    <div class="py-1.5">
                                        @foreach (var opt in new[] { ("All", "Show All Conditions"), ("Good", "Good"), ("NeedsCleaning", "Needs Cleaning"), ("UnderRepair", "Under Repair"), ("Broken", "Broken") })
                                        {
                                            <button @onclick="() => SetConditionFilter(opt.Item1)" 
                                                    class='flex items-center justify-between w-full px-4 py-2 text-xs text-left transition-all @(_conditionFilter == opt.Item1 ? "bg-blue-50/80 text-blue-700 font-bold" : "text-slate-600 hover:bg-slate-50")'>
                                                <span>@opt.Item2</span>
                                                @if (_conditionFilter == opt.Item1)
                                                {
                                                    <svg class="w-3.5 h-3.5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                    </svg>
                                                }
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </th>
                        @if (_role != "Guest" && _role != "")
                        {
                            <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Action</th>
                        }
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-200">
                    @if (!_displayJigs.Any())
                    {
                        <tr>
                            <td colspan="10" class="px-6 py-12 text-center text-slate-500">
                                <div class="flex flex-col items-center justify-center">
                                    <svg class="w-16 h-16 mb-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    <div class="text-lg font-medium text-slate-900">No results found</div>
                                    <p class="text-sm text-slate-500">We couldn't find any jigs matching your current filters.</p>
                                    <button @onclick='() => { _statusFilter = "All"; _conditionFilter = "All"; _searchQuery = ""; FilterData(); }' 
                                            class="mt-4 text-sm font-semibold text-blue-600 hover:text-blue-800">
                                        Clear all filters
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in _displayJigs)
                        {
                        var spec = _allSpecs.FirstOrDefault(s => s.Id == item.SpecId);
                        var specName = spec?.Name ?? "Unknown";

                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="font-mono text-sm font-semibold text-slate-900 border border-slate-200 bg-slate-100 px-2 py-1 rounded">@item.Id</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm text-slate-900 font-medium">@specName</div>
                                <div class="text-xs text-slate-500">Spec: @item.SpecId @(!string.IsNullOrEmpty(spec?.Rev) ? $" | Rev: {spec?.Rev}" : "")</div>
                                @if(!string.IsNullOrEmpty(spec?.PartNumber)){
                                    <div class="text-xs text-slate-500 mt-0.5">Part: @spec?.PartNumber</div>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if (item.Status == "Available")
                                {
                                    <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-emerald-100 text-emerald-800 border border-emerald-200">
                                        Available
                                    </span>
                                }
                                else if (item.Status == "InUse")
                                {
                                    <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-amber-100 text-amber-800 border border-amber-200">
                                        In Use
                                    </span>
                                }
                                else
                                {
                                    <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-slate-100 text-slate-800 border border-slate-200">
                                        @item.Status
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                <div class="flex items-center">
                                    <svg class="w-4 h-4 mr-1.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                    @(_allLocators.FirstOrDefault(l => l.Id == item.LocatorId)?.Name ?? "Unknown")
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                @item.Condition
                            </td>
                            @if (_role != "Guest" && _role != "")
                            {
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    @if (_role != "Guest")
                                    {
                                        <div class="flex items-center justify-end gap-4 @(_role == "Admin" ? "flex-nowrap" : "")">
                                            @if (item.Status == "Available")
                                            {
                                                <button @onclick="() => ReportIssue(item.Id)" class="text-amber-600 hover:text-amber-900 font-semibold px-2 py-1 rounded hover:bg-amber-50 transition-colors">
                                                    Report Issue
                                                </button>
                                                <button @onclick="() => ProcessBorrow(item.Id)" class="text-indigo-600 hover:text-indigo-900 font-semibold px-2 py-1 rounded hover:bg-indigo-50 transition-colors">
                                                    Borrow
                                                </button>
                                            }
                                            else if (item.Status == "InUse")
                                            {
                                                <button @onclick="() => ProcessReturn(item.Id)" class="text-emerald-600 hover:text-emerald-900 font-semibold px-3 py-1 rounded hover:bg-emerald-50 transition-colors">
                                                    Return
                                                </button>
                                            }

                                            @if (item.Status != "Available" && (_role == "Admin" || _role == "ProdLead"))
                                            {
                                                <button @onclick="() => ForceCheckIn(item.Id)" class="text-indigo-600 hover:text-indigo-900 font-semibold px-3 py-1 rounded hover:bg-indigo-50 transition-colors">
                                                    Force Return
                                                </button>
                                            }

                                            @if ((item.Status == "Available" || item.Status == "Evaluation") && (_role == "Admin" || _role == "ProdLead"))
                                            {
                                                <button @onclick="() => ProcessScrap(item.Id)" class="text-red-600 hover:text-red-900 font-semibold px-3 py-1 rounded hover:bg-red-50 transition-colors">
                                                    Scrap
                                                </button>
                                            }
                                        </div>
                                    }
                                </td>
                            }
                        </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "filter")]
    public string? Filter { get; set; }

    [SupplyParameterFromQuery(Name = "status")]
    public string? StatusFromQuery { get; set; }

    [SupplyParameterFromQuery(Name = "condition")]
    public string? ConditionFromQuery { get; set; }

    private string _role = "";
    private string _name = "";
    private string _searchQuery = "";
    private string _statusFilter = "All";
    private string _conditionFilter = "All";
    private bool _showStatusFilter = false;
    private bool _showConditionFilter = false;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(StatusFromQuery))
        {
            _statusFilter = StatusFromQuery;
        }
        if (!string.IsNullOrEmpty(ConditionFromQuery))
        {
            _conditionFilter = ConditionFromQuery;
        }
        if (!string.IsNullOrEmpty(Filter))
        {
            // If explicit filter is "Issues", we reset other filters to prevent conflict
            if (Filter == "Issues")
            {
                _statusFilter = "All";
                _conditionFilter = "All";
            }
        }
        FilterData();
    }

    private void ToggleStatusFilter() { _showStatusFilter = !_showStatusFilter; _showConditionFilter = false; }
    private void ToggleConditionFilter() { _showConditionFilter = !_showConditionFilter; _showStatusFilter = false; }

    private void SetStatusFilter(string val)
    {
        _statusFilter = val;
        FilterData();
        _showStatusFilter = false;
    }

    private void SetConditionFilter(string val)
    {
        _conditionFilter = val;
        FilterData();
        _showConditionFilter = false;
    }

    private IEnumerable<PhysicalJig>? _displayJigs;
    private bool _isLoading = true;
    
    private List<PhysicalJig> _allJigs = new();
    private List<JigSpec> _allSpecs = new();
    private List<Locator> _allLocators = new();

    private bool _showScanModal = false;
    private DotNetObjectReference<CurrentStatus>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            var auth = await Auth.GetAuthAsync();
            _role = auth.Role ?? "";
            _name = auth.Name ?? "";

            if (string.IsNullOrEmpty(_role))
            {
                NavManager.NavigateTo("/login");
                return;
            }

            await LoadData();
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        try
        {
            var locatorsTask = Http.GetFromJsonAsync<List<Locator>>("api/locators");
            var specsTask = Http.GetFromJsonAsync<List<JigSpec>>("api/jigspecs");
            var jigsTask = Http.GetFromJsonAsync<List<PhysicalJig>>("api/physicaljigs");

            await Task.WhenAll(locatorsTask, specsTask, jigsTask);

            _allLocators = await locatorsTask ?? new List<Locator>();
            _allSpecs = await specsTask ?? new List<JigSpec>();
            _allJigs = await jigsTask ?? new List<PhysicalJig>();

            FilterData();
        }
        catch (Exception)
        {
            // Handle error minimally
            _displayJigs = new List<PhysicalJig>();
        }
    }

    private void FilterData()
    {
        var query = _allJigs.AsEnumerable();
        var lowerQuery = (_searchQuery ?? "").ToLowerInvariant();

        if (!string.IsNullOrWhiteSpace(lowerQuery))
        {
            // Search by part number to find associated spec
            var matchSpecIds = _allSpecs
                .Where(p => (p.PartNumber ?? "").ToLowerInvariant().Contains(lowerQuery))
                .Select(p => p.Id)
                .ToList();

            // Also search by Spec Name directly
            var specNameMatchIds = _allSpecs
                .Where(s => (s.Name ?? "").ToLowerInvariant().Contains(lowerQuery))
                .Select(s => s.Id)
                .ToList();
                
            matchSpecIds.AddRange(specNameMatchIds);

            query = query.Where(j => 
                (j.Id ?? "").ToLowerInvariant().Contains(lowerQuery) || 
                matchSpecIds.Contains(j.SpecId) || 
                (_allLocators.FirstOrDefault(l => l.Id == j.LocatorId)?.Name ?? "").ToLowerInvariant().Contains(lowerQuery)
            );
        }

        if (_statusFilter != "All")
        {
            query = query.Where(j => j.Status == _statusFilter);
        }

        if (_conditionFilter != "All")
        {
            query = query.Where(j => j.Condition == _conditionFilter);
        }

        // Apply special "Issues" filter if requested via URL AND no manual filter is overriding it
        if (Filter == "Issues" && _statusFilter == "All" && _conditionFilter == "All")
        {
            query = query.Where(j => j.Status == "Evaluation" || j.Condition == "Broken" || j.Condition == "UnderRepair" || j.Condition == "NeedsCleaning");
        }

        _displayJigs = query.ToList();
    }

    private async Task ProcessBorrow(string id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Borrow Jig?", $"Do you want to borrow jig {id}?", "Yes, borrow", "question");
        if (!confirmed) return;

        var jig = _allJigs.FirstOrDefault(j => j.Id == id);
        if (jig != null)
        {
            jig.Status = "InUse";
            await Http.PutAsJsonAsync($"api/physicaljigs/{id}", jig);
            await Http.PostAsJsonAsync("api/transactions", new TransactionRow { JigId = id, Action = "CheckOut", User = _name, Timestamp = DateTime.Now });
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task ProcessReturn(string id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Return Jig?", $"Do you want to return jig {id}?", "Yes, return", "question");
        if (!confirmed) return;

        var jig = _allJigs.FirstOrDefault(j => j.Id == id);
        if (jig != null)
        {
            jig.Status = "Available";
            jig.Condition = "NeedsCleaning"; // Example flow: returning makes it need cleaning
            await Http.PutAsJsonAsync($"api/physicaljigs/{id}", jig);
            await Http.PostAsJsonAsync("api/transactions", new TransactionRow { JigId = id, Action = "CheckIn", User = _name, Timestamp = DateTime.Now });
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task ReportIssue(string id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Report Issue", $"Are you sure you want to report an issue for jig {id}?", "Yes, report", "warning");
        if (!confirmed) return;

        var jig = _allJigs.FirstOrDefault(j => j.Id == id);
        if (jig != null)
        {
            jig.Status = "Evaluation";
            jig.Condition = "UnderRepair";
            await Http.PutAsJsonAsync($"api/physicaljigs/{id}", jig);
            await Http.PostAsJsonAsync("api/transactions", new TransactionRow { JigId = id, Action = "ReportIssue", User = _name, Timestamp = DateTime.Now });
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task ForceCheckIn(string id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Force Return", $"Force return jig {id}?", "Yes, force return", "warning");
        if (!confirmed) return;

        var jig = _allJigs.FirstOrDefault(j => j.Id == id);
        if (jig != null)
        {
            jig.Status = "Available";
            jig.Condition = "NeedsCleaning";
            await Http.PutAsJsonAsync($"api/physicaljigs/{id}", jig);
            await Http.PostAsJsonAsync("api/transactions", new TransactionRow { JigId = id, Action = "ForceCheckIn", User = _name, Timestamp = DateTime.Now });
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task ProcessScrap(string id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Scrap Jig", $"Are you absolutely sure you want to scrap jig {id}?", "Yes, scrap it", "error");
        if (!confirmed) return;

        var jig = _allJigs.FirstOrDefault(j => j.Id == id);
        if (jig != null)
        {
            jig.Status = "Evaluation";
            jig.Condition = "Broken";
            await Http.PutAsJsonAsync($"api/physicaljigs/{id}", jig);
            await Http.PostAsJsonAsync("api/transactions", new TransactionRow { JigId = id, Action = "Scrapped", User = _name, Timestamp = DateTime.Now });
            await LoadData();
            StateHasChanged();
        }
    }

    private void OpenScanModal()
    {
        _showScanModal = true;
        StateHasChanged();
        
        // Wait for modal to render, then start scanner
        Task.Delay(300).ContinueWith(_ => 
        {
            InvokeAsync(async () => {
                await JSRuntime.InvokeVoidAsync("startQrScan", _dotNetRef, "qr-reader");
            });
        });
    }

    private async Task CloseScanModal()
    {
        _showScanModal = false;
        await JSRuntime.InvokeVoidAsync("stopQrScan");
    }

    [JSInvokable]
    public async Task OnQrScanned(string decodedText)
    {
        await CloseScanModal();
        _searchQuery = decodedText;
        FilterData();
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        try { await JSRuntime.InvokeVoidAsync("stopQrScan"); } catch { }
    }
}
