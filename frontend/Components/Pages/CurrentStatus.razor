@page "/current-status"
@inject frontend.Services.AuthService Auth
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject LanguageService Lang
@using System.Threading.Tasks
@using System.Net.Http.Json
@implements IAsyncDisposable

<PageTitle>Current Status - Inventory</PageTitle>

<div class="mb-6 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 mb-2">@Lang.T("สถานะปัจจุบัน", "Current Status")</h1>
        <p class="text-slate-500">@Lang.T("ค้นหาและจัดการจิกกายภาพ", "Search and manage physical jigs")</p>
    </div>
    @if (!string.IsNullOrEmpty(_role))
    {
        <div class="text-sm font-medium text-slate-500 bg-slate-100 px-3 py-1.5 rounded-full">
            Role: <span class="text-slate-800">@_role</span>
        </div>
    }
</div>

<div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 mb-8">
    <div class="flex flex-col md:flex-row gap-4">
        <div class="flex-1">
            <label for="search" class="block text-sm font-medium text-slate-700 mb-1">@Lang.T("ค้นหารหัสรุ่น หรือ รหัสจิก", "Search Part Number or Jig ID")</label>
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
                <input type="text" id="search" @bind="_searchQuery" @bind:event="oninput" 
                       class="block w-full pl-10 pr-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="@Lang.T("ตัวอย่าง: PN-1001 หรือ J001", "e.g. PN-1001 or J001")" />
            </div>
        </div>
        <div class="flex items-end space-x-3 w-full md:w-auto mt-4 md:mt-0">
            <button @onclick="OpenScanModal" class="w-full md:w-auto px-4 py-2 bg-slate-100 text-slate-700 font-medium rounded-lg hover:bg-slate-200 focus:outline-none transition-colors border border-slate-200 flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                @Lang.T("สแกนคิวอาร์", "Scan QR")
            </button>
            <button @onclick="FilterData" class="w-full md:w-auto px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                @Lang.T("ค้นหา", "Search")
            </button>
        </div>
    </div>
</div>

@if (_showScanModal)
{
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center">
        <div class="relative w-full max-w-sm bg-white rounded-2xl shadow-xl p-6 border border-slate-100 text-center">
            <h3 class="text-xl font-bold text-slate-900 mb-4">@Lang.T("สแกนคิวอาร์โค้ด", "Scan QR Code")</h3>
            <div id="qr-reader" class="mx-auto w-full mb-4 overflow-hidden rounded-lg bg-slate-50 border border-slate-200" style="min-height: 250px;"></div>
            <button @onclick="CloseScanModal" class="px-6 py-2 bg-slate-100 text-slate-700 font-medium rounded-lg hover:bg-slate-200 transition-colors">@Lang.T("ยกเลิก", "Cancel")</button>
        </div>
    </div>
}

@if (_isLoading)
{
    <div class="flex items-center justify-center py-12">
        <div class="text-slate-500 font-medium tracking-wide">Loading status variables...</div>
    </div>
}

else
{
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 max-w-full relative">
        <div class="block w-full overflow-x-auto pb-64 -mb-64">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">@Lang.T("รหัสจิก", "Jig ID")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">@Lang.T("รุ่น/ข้อมูลจำเพาะ", "Specification")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider relative cursor-pointer group select-none" @onclick="ToggleStatusFilter">
                            <div class="flex items-center gap-2 transition-colors @(_statusFilter != "All" ? "text-blue-600" : "text-slate-600 hover:text-blue-700")">
                                <span class="tracking-widest">Status@(_statusFilter != "All" ? $": {(_statusFilter == "InUse" ? "In Use" : _statusFilter)}" : "")</span>
                                <div class='flex items-center justify-center w-5 h-5 rounded-full transition-all @(_showStatusFilter ? "bg-blue-50 rotate-180" : "group-hover:bg-slate-100")'>
                                    <svg class='w-3.5 h-3.5 @(_statusFilter != "All" ? "text-blue-500" : "text-slate-500")' fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                                @if (_statusFilter != "All")
                                {
                                    <span class="flex h-2 w-2 rounded-full bg-blue-500 animate-pulse shadow-[0_0_8px_rgba(59,130,246,0.5)]"></span>
                                }
                            </div>
                            @if (_showStatusFilter)
                            {
                                <div class="absolute left-6 top-full z-20 mt-2 w-48 bg-white rounded-2xl shadow-2xl border border-slate-100 overflow-hidden transform origin-top-left ring-1 ring-black/5 animate-in fade-in zoom-in duration-200" @onclick:stopPropagation>
                                    <div class="flex items-center justify-between px-4 py-2.5 bg-slate-50/50 border-b border-slate-100">
                                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">@Lang.T("กรองสถานะ", "Filter Status")</span>
                                        @if (_statusFilter != "All")
                                        {
                                            <button @onclick='() => SetStatusFilter("All")' class="text-[10px] font-bold text-blue-600 hover:text-blue-800 transition-colors">@Lang.T("ล้าง", "RESET")</button>
                                        }
                                    </div>
                                    <div class="py-1.5">
                                        @foreach (var opt in new[] { ("All", "Show All Statuses"), ("Available", "Available"), ("InUse", "In Use"), ("Cleaning", "Cleaning"), ("Evaluation", "Evaluation") })
                                        {
                                            <button @onclick="() => SetStatusFilter(opt.Item1)" 
                                                    class='flex items-center justify-between w-full px-4 py-2 text-xs text-left transition-all @(_statusFilter == opt.Item1 ? "bg-blue-50/80 text-blue-700 font-bold" : "text-slate-600 hover:bg-slate-50")'>
                                                <span>@opt.Item2</span>
                                                @if (_statusFilter == opt.Item1)
                                                {
                                                    <svg class="w-3.5 h-3.5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                    </svg>
                                                }
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">@Lang.T("ตำแหน่ง", "Location")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider relative cursor-pointer group select-none" @onclick="ToggleConditionFilter">
                            <div class="flex items-center gap-2 transition-colors @(_conditionFilter != "All" ? "text-blue-600" : "text-slate-600 hover:text-blue-700")">
                                <span class="tracking-widest">Condition@(_conditionFilter != "All" ? $": {(_conditionFilter == "NeedsCleaning" ? "Needs Clean" : _conditionFilter == "UnderRepair" ? "Repair" : _conditionFilter)}" : "")</span>
                                <div class='flex items-center justify-center w-5 h-5 rounded-full transition-all @(_showConditionFilter ? "bg-blue-50 rotate-180" : "group-hover:bg-slate-100")'>
                                    <svg class='w-3.5 h-3.5 @(_conditionFilter != "All" ? "text-blue-500" : "text-slate-500")' fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                                @if (_conditionFilter != "All")
                                {
                                    <span class="flex h-2 w-2 rounded-full bg-blue-500 animate-pulse shadow-[0_0_8px_rgba(59,130,246,0.5)]"></span>
                                }
                            </div>
                            @if (_showConditionFilter)
                            {
                                <div class="absolute left-6 top-full z-20 mt-2 w-48 bg-white rounded-2xl shadow-2xl border border-slate-100 overflow-hidden transform origin-top-left ring-1 ring-black/5 animate-in fade-in zoom-in duration-200" @onclick:stopPropagation>
                                    <div class="flex items-center justify-between px-4 py-2.5 bg-slate-50/50 border-b border-slate-100">
                                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">@Lang.T("กรองสภาพ", "Filter Condition")</span>
                                        @if (_conditionFilter != "All")
                                        {
                                            <button @onclick='() => SetConditionFilter("All")' class="text-[10px] font-bold text-blue-600 hover:text-blue-800 transition-colors">@Lang.T("ล้าง", "RESET")</button>
                                        }
                                    </div>
                                    <div class="py-1.5">
                                        @foreach (var opt in new[] { ("All", "Show All Conditions"), ("Good", "Good"), ("NeedsCleaning", "Needs Cleaning"), ("UnderRepair", "Under Repair"), ("Broken", "Broken") })
                                        {
                                            <button @onclick="() => SetConditionFilter(opt.Item1)" 
                                                    class='flex items-center justify-between w-full px-4 py-2 text-xs text-left transition-all @(_conditionFilter == opt.Item1 ? "bg-blue-50/80 text-blue-700 font-bold" : "text-slate-600 hover:bg-slate-50")'>
                                                <span>@opt.Item2</span>
                                                @if (_conditionFilter == opt.Item1)
                                                {
                                                    <svg class="w-3.5 h-3.5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                    </svg>
                                                }
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">@Lang.T("สภาพ", "Condition")</th>
                        @if (_role != "Guest" && _role != "")
                        {
                            <th scope="col" class="px-6 py-4 text-center text-xs font-semibold text-slate-500 uppercase tracking-wider">@Lang.T("การดำเนินการ", "Action")</th>
                        }
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-200">
                    @if (_displayJigs.Any())
                    {
                        @foreach (var jig in _displayJigs)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="font-mono text-sm font-bold text-slate-900">@jig.Id</div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm font-medium text-slate-900">@jig.SmartCodeName</div>
                                    <div class="text-xs text-slate-500">Tool: @jig.ToolNo | P/N: @jig.PartNumber</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-3 py-1 inline-flex text-xs font-bold rounded-full border @(GetStatusBadgeClass(jig.Status))">
                                        @Lang.T(GetStatusThai(jig.Status), jig.Status)
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600">
                                    @GetLocatorName(jig.LocatorId)
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-3 py-1 inline-flex text-xs font-bold rounded-full border @(GetConditionBadgeClass(jig.Condition))">
                                        @Lang.T(GetConditionThai(jig.Condition), jig.Condition)
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600">
                                    @jig.Condition
                                </td>
                                @if (_role != "Guest" && _role != "")
                                {
                                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
                                        <div class="flex items-center justify-center gap-2">
                                            @if (jig.Status == "Available")
                                            {
                                                <button @onclick='() => NavManager.NavigateTo($"/scan-out?id={jig.Id}")' class="text-blue-600 hover:text-blue-900 bg-blue-50 px-3 py-1 rounded-lg">Check Out</button>
                                            }
                                            else
                                            {
                                                <button @onclick='() => NavManager.NavigateTo($"/scan-out?id={jig.Id}")' class="text-emerald-600 hover:text-emerald-900 bg-emerald-50 px-3 py-1 rounded-lg">Check In / Store</button>
                                            }
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="px-6 py-12 text-center text-slate-500">
                                <div class="flex flex-col items-center justify-center">
                                    <svg class="w-16 h-16 mb-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    <div class="text-lg font-medium text-slate-900">@Lang.T("ไม่พบข้อมูล", "No results found")</div>
                                    <p class="text-sm text-slate-500">@Lang.T("ไม่พบจิ๊กที่ตรงตามเงื่อนไขการค้นหาของคุณ", "We couldn't find any jigs matching your current filters.")</p>
                                    <button @onclick='() => { _statusFilter = "All"; _conditionFilter = "All"; _searchQuery = ""; FilterData(); }' 
                                            class="mt-4 text-sm font-semibold text-blue-600 hover:text-blue-800">
                                        @Lang.T("ล้างตัวกรองทั้งหมด", "Clear all filters")
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "filter")]
    public string? Filter { get; set; }

    [SupplyParameterFromQuery(Name = "status")]
    public string? StatusFromQuery { get; set; }

    [SupplyParameterFromQuery(Name = "condition")]
    public string? ConditionFromQuery { get; set; }

    private string _role = "";
    private string _name = "";
    private string _searchQuery = "";
    private string _statusFilter = "All";
    private string _conditionFilter = "All";
    private bool _showStatusFilter = false;
    private bool _showConditionFilter = false;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(StatusFromQuery))
        {
            _statusFilter = StatusFromQuery;
        }
        if (!string.IsNullOrEmpty(ConditionFromQuery))
        {
            _conditionFilter = ConditionFromQuery;
        }
        if (!string.IsNullOrEmpty(Filter))
        {
            // If explicit filter is "Issues", we reset other filters to prevent conflict
            if (Filter == "Issues")
            {
                _statusFilter = "All";
                _conditionFilter = "All";
            }
        }
        FilterData();
    }

    private void ToggleStatusFilter() { _showStatusFilter = !_showStatusFilter; _showConditionFilter = false; }
    private void ToggleConditionFilter() { _showConditionFilter = !_showConditionFilter; _showStatusFilter = false; }

    private void SetStatusFilter(string val)
    {
        _statusFilter = val;
        FilterData();
        _showStatusFilter = false;
    }

    private void SetConditionFilter(string condition)
    {
        _conditionFilter = condition;
        _showConditionFilter = false;
        FilterData();
    }

    private string GetStatusThai(string status) => status switch
    {
        "Available" => "พร้อมใช้งาน",
        "InUse" => "กำลังใช้งาน",
        "Cleaning" => "กำลังทำความสะอาด",
        "Evaluation" => "รอประเมินสภาพ",
        _ => status
    };

    private string GetConditionThai(string condition) => condition switch
    {
        "Good" => "ใช้งานได้ดี",
        "NeedsCleaning" => "ต้องทำความสะอาด",
        "UnderRepair" => "กำลังซ่อมแซม",
        "Broken" => "ชำรุดเสียหาย",
        _ => condition
    };

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Available" => "bg-emerald-50 text-emerald-700 border-emerald-200",
        "InUse" => "bg-blue-50 text-blue-700 border-blue-200",
        "Cleaning" => "bg-amber-50 text-amber-700 border-amber-200",
        "Evaluation" => "bg-purple-50 text-purple-700 border-purple-200",
        _ => "bg-slate-50 text-slate-700 border-slate-200"
    };

    private string GetConditionBadgeClass(string condition) => condition switch
    {
        "Good" => "bg-emerald-50 text-emerald-700 border-emerald-200",
        "NeedsCleaning" => "bg-amber-50 text-amber-700 border-amber-200",
        "UnderRepair" => "bg-blue-50 text-blue-700 border-blue-100",
        "Broken" => "bg-red-50 text-red-700 border-red-200",
        _ => "bg-slate-50 text-slate-700 border-slate-200"
    };

    protected override void OnInitialized()
    {
        Lang.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Lang.OnChange -= StateHasChanged;
    }

    private bool _isLoading = true;
    private List<Jig> _allJigs = new();
    private List<Jig> _displayJigs = new();
    private List<Locator> _allLocators = new();

    private bool _showScanModal = false;
    private DotNetObjectReference<CurrentStatus>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            var auth = await Auth.GetAuthAsync();
            _role = auth.Role ?? "";
            _name = auth.Name ?? "";

            if (string.IsNullOrEmpty(_role))
            {
                NavManager.NavigateTo("/login");
                return;
            }

            await LoadData();
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        try
        {
            var jigsTask = Http.GetFromJsonAsync<List<Jig>>("api/jigs");
            var locatorsTask = Http.GetFromJsonAsync<List<Locator>>("api/locators");

            await Task.WhenAll(jigsTask, locatorsTask);

            _allJigs = await jigsTask ?? new List<Jig>();
            _allLocators = await locatorsTask ?? new List<Locator>();

            FilterData();
        }
        catch (Exception)
        {
            // Handle error minimally
        }
    }

    private void FilterData()
    {
        var lower = _searchQuery.ToLowerInvariant();
        var query = _allJigs.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(lower))
        {
            query = query.Where(j => 
                (j.Id?.ToLowerInvariant().Contains(lower) == true) || 
                (j.PartNumber?.ToLowerInvariant().Contains(lower) == true) ||
                (j.ToyNumber?.ToLowerInvariant().Contains(lower) == true) ||
                (j.SmartCodeName?.ToLowerInvariant().Contains(lower) == true)
            );
        }

        if (_statusFilter != "All")
        {
            query = query.Where(j => j.Status == _statusFilter);
        }

        if (_conditionFilter != "All")
        {
            query = query.Where(j => j.Condition == _conditionFilter);
        }

        if (Filter == "Issues")
        {
            query = query.Where(j => j.Condition == "NeedsCleaning" || j.Condition == "UnderRepair" || j.Condition == "Broken");
        }

        _displayJigs = query.ToList();
    }

    private string GetLocatorName(string? id)
    {
        if (string.IsNullOrEmpty(id)) return "-";
        var loc = _allLocators.FirstOrDefault(l => l.Id == id);
        return loc?.Name ?? id;
    }

    private void OpenScanModal()
    {
        _showScanModal = true;
        StateHasChanged();
        
        // Wait for modal to render, then start scanner
        Task.Delay(300).ContinueWith(_ => 
        {
            InvokeAsync(async () => {
                await JSRuntime.InvokeVoidAsync("startQrScan", _dotNetRef, "qr-reader");
            });
        });
    }

    private async Task CloseScanModal()
    {
        _showScanModal = false;
        await JSRuntime.InvokeVoidAsync("stopQrScan");
    }

    [JSInvokable]
    public async Task OnQrScanned(string decodedText)
    {
        await CloseScanModal();
        _searchQuery = decodedText;
        FilterData();
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        try { await JSRuntime.InvokeVoidAsync("stopQrScan"); } catch { }
    }
}
