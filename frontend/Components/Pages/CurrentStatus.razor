@page "/current-status"
@inject frontend.Services.AuthService Auth
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject LanguageService Lang
@using System.Threading.Tasks
@using System.Net.Http.Json
@using frontend.Components.Shared
@implements IAsyncDisposable

<PageTitle>@Lang.T("สถานะปัจจุบัน | คลัง", "Current Status | Inventory")</PageTitle>

<div class="mb-6 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-100 mb-2">@Lang.T("สถานะปัจจุบัน", "Current Status")</h1>
        <p class="text-slate-500">@Lang.T("ค้นหาและจัดการจิกกายภาพ", "Search and manage physical jigs")</p>
    </div>
</div>

<div class="bg-slate-800 p-6 rounded-2xl shadow-xl border border-slate-700 mb-8">
    <div class="flex flex-col md:flex-row gap-4">
        <div class="flex-1">
            <label for="search" class="block text-sm font-semibold text-slate-200 mb-1.5 flex items-center gap-1.5">
                <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                @Lang.T("ค้นหาจิก", "Search Jigs")
            </label>
            <div class="relative group">
                <input type="text" id="search" value="@_searchQuery" @oninput="OnSearchInput"
                       class="block w-full pl-4 pr-10 py-2.5 bg-slate-900 border border-slate-700 text-slate-200 rounded-xl focus:ring-2 focus:ring-mattel-red/30 focus:border-mattel-red focus:bg-slate-800 transition-all sm:text-sm outline-none" 
                       placeholder="@Lang.T("ตัวอย่าง: PN-1001 หรือ J001", "e.g. PN-1001 or J001")" />
            </div>
        </div>
        <div class="flex items-end gap-3 shrink-0">
            <PageSizeSelector @bind-PageSize="_pageSize" OnChanged="FilterData" />
        </div>
    </div>
</div>

@if (_showScanModal)
{
    <div class="fixed inset-0 bg-slate-900/80 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center">
        <div class="relative w-full max-w-sm bg-slate-800 rounded-2xl shadow-2xl p-6 border border-slate-700 text-center">
            <h3 class="text-xl font-bold text-slate-100 mb-4">@Lang.T("สแกนคิวอาร์โค้ด", "Scan QR Code")</h3>
            <div id="qr-reader" class="mx-auto w-full mb-4 overflow-hidden rounded-lg bg-slate-900 border border-slate-700" style="min-height: 250px;"></div>
            <button @onclick="CloseScanModal" class="px-6 py-2 bg-slate-900 text-slate-300 border border-slate-700 font-medium rounded-lg hover:bg-slate-700 transition-colors">@Lang.T("ยกเลิก", "Cancel")</button>
        </div>
    </div>
}

@if (_showReportModal)
{
    <div class="fixed inset-0 bg-slate-900/80 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center">
        <div class="relative w-full max-w-md bg-slate-800 rounded-2xl shadow-2xl p-6 border border-slate-700">
            <h3 class="text-xl font-bold text-mattel-red mb-4 flex items-center">
                <svg class="w-6 h-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                @Lang.T("แจ้งปัญหา จิ๊ก", "Report Issue for Jig ") @_reportJigId
            </h3>
            
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("ปัญหาที่พบ", "Issue Type")</label>
                <select @bind="_reportType" class="w-full bg-slate-900 text-slate-200 border-slate-700 rounded-lg shadow-sm focus:border-mattel-red focus:ring-mattel-red p-2 border">
                    <option value="">-- @Lang.T("เลือกปัญหา", "Select Issue") --</option>
                    <option value="Broken">🔨 @Lang.T("ชำรุด / เสีย", "Broken")</option>
                    <option value="NeedsCleaning">🧹 @Lang.T("ต้องทำความสะอาด", "Needs Cleaning")</option>
                    <option value="Lost">❓ @Lang.T("สูญหาย", "Lost")</option>
                    <option value="Other">⚠️ @Lang.T("อื่นๆ", "Other")</option>
                </select>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-medium text-slate-300 mb-1">@Lang.T("หมายเหตุ / สาเหตุ", "Remark / Reason")</label>
                <textarea @bind="_reportRemark" rows="3" class="w-full bg-slate-900 text-slate-200 border-slate-700 rounded-lg shadow-sm focus:border-mattel-red focus:ring-mattel-red p-2 border outline-none" placeholder="@Lang.T("อธิบายปัญหาที่พบสั้นๆ...", "Briefly describe the issue...")"></textarea>
            </div>

            <div class="flex justify-end gap-3">
                <button @onclick="CloseReportModal" class="px-4 py-2 bg-slate-900 text-slate-300 border border-slate-700 font-medium rounded-lg hover:bg-slate-700 transition-colors">@Lang.T("ยกเลิก", "Cancel")</button>
                <button @onclick="SubmitReportIssue" disabled="@(string.IsNullOrEmpty(_reportType))" class="px-4 py-2 bg-mattel-red text-white font-medium rounded-lg transition-opacity disabled:opacity-50 disabled:cursor-not-allowed flex items-center hover:bg-mattel-hover">
                    @if (_isSubmittingReport)
                    {
                        <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        @Lang.T("กำลังบันทึก...", "Saving...")
                    }
                    else
                    {
                        @Lang.T("ยืนยันแจ้งปัญหา", "Confirm Report")
                    }
                </button>
            </div>
        </div>
    </div>
}

@if (_isLoading)
{
    <div class="flex items-center justify-center py-12">
        <div class="text-slate-500 font-medium tracking-wide">Loading status variables...</div>
    </div>
}

else
{
    <div class="bg-slate-800 rounded-2xl shadow-xl border border-slate-700 max-w-full relative">
        <div class="block w-full overflow-x-auto min-h-[300px]">
            <table class="min-w-full divide-y divide-slate-700">
                <thead class="bg-slate-900 sticky top-0 z-10 shadow-md">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider whitespace-nowrap min-w-[120px]">@Lang.T("รหัสจิก", "Jig ID")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider min-w-[300px]">@Lang.T("รุ่น/ข้อมูลจำเพาะ", "Specification")</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider relative cursor-pointer group select-none whitespace-nowrap min-w-[180px]" @onclick="ToggleStatusFilter">
                            <div class="flex items-center gap-2 transition-colors @(_statusFilter != "All" ? "text-slate-100" : "text-slate-400 hover:text-slate-200")">
                                <span class="tracking-widest">@Lang.T("สถานะ", "Status")@(_statusFilter != "All" ? $": {(_statusFilter == "InUse" ? Lang.T("กำลังใช้งาน", "In Use") : _statusFilter)}" : "")</span>
                                <div class='flex items-center justify-center w-5 h-5 rounded-full transition-all @(_showStatusFilter ? "bg-slate-700 rotate-180" : "group-hover:bg-slate-800")'>
                                    <svg class='w-3.5 h-3.5 @(_statusFilter != "All" ? "text-mattel-red" : "text-slate-500")' fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                                @if (_statusFilter != "All")
                                {
                                    <span class="flex h-2 w-2 rounded-full bg-mattel-red animate-pulse shadow-[0_0_8px_rgba(238,0,36,0.5)]"></span>
                                }
                            </div>
                            @if (_showStatusFilter)
                            {
                                <div class="absolute left-6 top-full z-20 mt-2 w-48 bg-slate-800 rounded-2xl shadow-2xl border border-slate-700 overflow-hidden transform origin-top-left animate-in fade-in zoom-in duration-200" @onclick:stopPropagation>
                                    <div class="flex items-center justify-between px-4 py-2.5 bg-slate-900 border-b border-slate-700">
                                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">@Lang.T("กรองสถานะ", "Filter Status")</span>
                                        @if (_statusFilter != "All")
                                        {
                                            <button @onclick='() => SetStatusFilter("All")' class="text-[10px] font-bold text-mattel-red hover:text-mattel-hover transition-colors">@Lang.T("ล้าง", "RESET")</button>
                                        }
                                    </div>
                                    <div class="py-1.5">
                                        @foreach (var opt in new[] { 
                                            ("All", Lang.T("แสดงสถานะทั้งหมด", "Show All Statuses")), 
                                            ("Available", Lang.T("พร้อมใช้งาน", "Available")), 
                                            ("InUse", Lang.T("กำลังถูกใช้งาน", "In Use")), 
                                            ("Cleaning", Lang.T("ล้าง", "Cleaning")), 
                                            ("Evaluation", Lang.T("ตรวจสอบ", "Evaluation")), 
                                            ("Lost", Lang.T("สูญหาย", "Lost"))
                                        })
                                        {
                                            <button @onclick="() => SetStatusFilter(opt.Item1)" 
                                                    class='flex items-center justify-between w-full px-4 py-2 text-xs text-left transition-all @(_statusFilter == opt.Item1 ? "bg-slate-700 text-mattel-red font-bold" : "text-slate-300 hover:bg-slate-700")'>
                                                <span>@opt.Item2</span>
                                                @if (_statusFilter == opt.Item1)
                                                {
                                                    <svg class="w-3.5 h-3.5 text-mattel-red" fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                    </svg>
                                                }
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider relative cursor-pointer group select-none whitespace-nowrap min-w-[180px]" @onclick="ToggleConditionFilter">
                            <div class="flex items-center gap-2 transition-colors @(_conditionFilter != "All" ? "text-mattel-hover" : "text-slate-600 hover:text-mattel-red")">
                                <span class="tracking-widest">@Lang.T("สภาพ", "Condition")@(_conditionFilter != "All" ? $": {Lang.T(GetConditionThai(_conditionFilter), _conditionFilter)}" : "")</span>
                                <div class='flex items-center justify-center w-5 h-5 rounded-full transition-all @(_showConditionFilter ? "bg-slate-700 rotate-180" : "group-hover:bg-slate-800")'>
                                    <svg class='w-3.5 h-3.5 @(_conditionFilter != "All" ? "text-mattel-red" : "text-slate-500")' fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                                @if (_conditionFilter != "All")
                                {
                                    <span class="flex h-2 w-2 rounded-full bg-mattel-red animate-pulse shadow-[0_0_8px_rgba(238,0,36,0.5)]"></span>
                                }
                            </div>
                            @if (_showConditionFilter)
                            {
                                <div class="absolute left-6 top-full z-20 mt-2 w-48 bg-slate-800 rounded-2xl shadow-xl border border-slate-700 overflow-hidden transform origin-top-left ring-1 ring-black/5 animate-in fade-in zoom-in duration-200" @onclick:stopPropagation>
                                    <div class="flex items-center justify-between px-4 py-2.5 bg-slate-900/50 border-b border-slate-700">
                                        <span class="text-[10px] font-bold text-mattel-steel uppercase tracking-widest">@Lang.T("กรองสภาพ", "Filter Condition")</span>
                                        @if (_conditionFilter != "All")
                                        {
                                            <button @onclick='() => SetConditionFilter("All")' class="text-[10px] font-bold text-mattel-red hover:text-mattel-hover transition-colors">@Lang.T("ล้าง", "RESET")</button>
                                        }
                                    </div>
                                    <div class="py-1.5">
                                        @foreach (var opt in new[] { 
                                            ("All", Lang.T("แสดงทั้งหมด", "Show All Conditions")), 
                                            ("Issues", Lang.T("พบปัญหาทั้งหมด", "All Issues")),
                                            ("Good", Lang.T("สภาพดี", "Good")), 
                                            ("NeedsCleaning", Lang.T("ต้องทำความสะอาด", "Needs Cleaning")), 
                                            ("Broken", Lang.T("ชำรุดเสียหาย", "Broken")), 
                                            ("Lost", Lang.T("สูญหาย", "Lost")) 
                                        })
                                        {
                                            <button @onclick="() => SetConditionFilter(opt.Item1)" 
                                                    class='flex items-center justify-between w-full px-4 py-2 text-xs text-left transition-all @(_conditionFilter == opt.Item1 ? "bg-slate-700 text-mattel-red font-bold" : "text-slate-300 hover:bg-slate-700")'>
                                                <span>@opt.Item2</span>
                                                @if (_conditionFilter == opt.Item1)
                                                {
                                                    <svg class="w-3.5 h-3.5 text-mattel-red" fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                    </svg>
                                                }
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider whitespace-nowrap min-w-[150px]">@Lang.T("ตำแหน่ง", "Location")</th>

                        @if (_role != "Guest" && _role != "")
                        {
                            <th scope="col" class="px-6 py-4 text-center text-xs font-semibold text-slate-500 uppercase tracking-wider whitespace-nowrap min-w-[150px]">@Lang.T("การดำเนินการ", "Action")</th>
                        }
                    </tr>
                </thead>
                <tbody class="bg-slate-800 divide-y divide-slate-700">
                    @if (_displayJigs.Any())
                    {
                        @foreach (var jig in _displayJigs)
                        {
                            <tr class="hover:bg-slate-700/50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="font-mono text-sm font-bold text-slate-100">@jig.Id</div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm font-medium text-slate-200">@jig.SmartCodeName</div>
                                    <div class="text-xs text-slate-500">Tool: @jig.ToolNo | P/N: @jig.PartNumber</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-3 py-1 inline-flex text-xs font-bold rounded-full border @(GetStatusBadgeClass(jig.Status))">
                                        @Lang.T(GetStatusThai(jig.Status), jig.Status)
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-3 py-1 inline-flex text-xs font-bold rounded-full border @(GetConditionBadgeClass(jig.Condition))">
                                        @Lang.T(GetConditionThai(jig.Condition), jig.Condition)
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-400">
                                    @GetLocatorName(jig.LocatorId)
                                </td>

                                @if (_role != "Guest" && _role != "")
                                {
                                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
                                        <div class="flex flex-col items-center justify-center gap-2">
                                            <button @onclick='() => OpenReportModal(jig.Id)' class="w-full mt-1 text-red-400 hover:text-white bg-red-900/40 hover:bg-red-800/60 px-3 py-1 rounded-lg flex items-center justify-center gap-1 transition-colors border border-red-900/40">
                                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg> 
                                                <span>@Lang.T("แจ้งปัญหา", "Report")</span>
                                            </button>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="px-6 py-12 text-center text-slate-400">
                                <div class="flex flex-col items-center justify-center">
                                    <svg class="w-16 h-16 mb-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    <div class="text-lg font-medium text-slate-100">@Lang.T("ไม่พบข้อมูล", "No results found")</div>
                                    <p class="text-sm text-slate-400">@Lang.T("ไม่พบจิ๊กที่ตรงตามเงื่อนไขการค้นหาของคุณ", "We couldn't find any jigs matching your current filters.")</p>
                                    <button @onclick='() => { _statusFilter = "All"; _conditionFilter = "All"; _searchQuery = ""; FilterData(); }' 
                                            class="mt-4 text-sm font-semibold text-mattel-red hover:text-mattel-hover transition-colors">
                                        @Lang.T("ล้างตัวกรองทั้งหมด", "Clear all filters")
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <Pagination TotalItems="@_totalItems" @bind-CurrentPage="_currentPage" PageSize="@_pageSize" OnChanged="FilterData" />
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "filter")]
    public string? Filter { get; set; }

    [SupplyParameterFromQuery(Name = "status")]
    public string? StatusFromQuery { get; set; }

    [SupplyParameterFromQuery(Name = "condition")]
    public string? ConditionFromQuery { get; set; }

    private string _role = "";
    private string _name = "";
    private string _searchQuery = "";
    private System.Threading.CancellationTokenSource? _searchCts;

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? "";
        _searchCts?.Cancel();
        _searchCts = new System.Threading.CancellationTokenSource();
        try
        {
            await Task.Delay(300, _searchCts.Token);
            FilterData();
        }
        catch (TaskCanceledException) { }
    }
    private string _statusFilter = "All";
    private string _conditionFilter = "All";
    private bool _showStatusFilter = false;
    private bool _showConditionFilter = false;
    private int _currentPage = 1;
    private int _pageSize = 10;
    private int _totalItems = 0;
    
    // Modal state for Reporting Issue
    private bool _showReportModal = false;
    private bool _isSubmittingReport = false;
    private string _reportJigId = "";
    private string _reportType = "";
    private string _reportRemark = "";

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(StatusFromQuery))
        {
            _statusFilter = StatusFromQuery;
        }
        if (!string.IsNullOrEmpty(ConditionFromQuery))
        {
            _conditionFilter = ConditionFromQuery;
        }
        if (!string.IsNullOrEmpty(Filter))
        {
            // Map legacy Filter parameter to condition options
            if (Filter == "Issues")
            {
                _statusFilter = "All";
                _conditionFilter = "Issues";
            }
        }
        FilterData();
    }

    private void ToggleStatusFilter() { _showStatusFilter = !_showStatusFilter; _showConditionFilter = false; }
    private void ToggleConditionFilter() { _showConditionFilter = !_showConditionFilter; _showStatusFilter = false; }

    private void SetStatusFilter(string val)
    {
        _statusFilter = val;
        _showStatusFilter = false;
        var uri = NavManager.GetUriWithQueryParameters(new Dictionary<string, object?> { { "status", val == "All" ? null : val }, { "filter", null } });
        NavManager.NavigateTo(uri, forceLoad: false);
    }

    private void SetConditionFilter(string condition)
    {
        _conditionFilter = condition;
        _showConditionFilter = false;
        var uri = NavManager.GetUriWithQueryParameters(new Dictionary<string, object?> { { "condition", condition == "All" ? null : condition }, { "filter", null } });
        NavManager.NavigateTo(uri, forceLoad: false);
    }

    private string GetStatusThai(string status) => status switch
    {
        "Available" => "พร้อมใช้งาน",
        "InUse" => "กำลังใช้งาน",
        "Cleaning" => "กำลังทำความสะอาด",
        "Evaluation" => "รอประเมินสภาพ",
        "Lost" => "สูญหาย",
        _ => status
    };

    private string GetConditionThai(string condition) => condition switch
    {
        "Good" => "ใช้งานได้ดี",
        "NeedsCleaning" => "ต้องทำความสะอาด",
        "UnderRepair" => "กำลังซ่อมแซม",
        "Broken" => "ชำรุดเสียหาย",
        "Lost" => "สูญหาย",
        "Issues" => "พบปัญหาทั้งหมด",
        _ => condition
    };

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Available" => "bg-emerald-900/40 text-emerald-400 border-emerald-800",
        "InUse" => "bg-blue-900/40 text-blue-400 border-blue-800",
        "Cleaning" => "bg-amber-900/40 text-amber-400 border-amber-800",
        "Evaluation" => "bg-purple-900/40 text-purple-400 border-purple-800",
        "Lost" => "bg-slate-700 text-slate-400 border-slate-600",
        _ => "bg-slate-700 text-slate-400 border-slate-600"
    };

    private string GetConditionBadgeClass(string condition) => condition switch
    {
        "Good" => "bg-emerald-900/40 text-emerald-400 border-emerald-800",
        "NeedsCleaning" => "bg-amber-900/40 text-amber-400 border-amber-800",
        "UnderRepair" => "bg-blue-900/40 text-blue-400 border-blue-800",
        "Broken" => "bg-red-900/40 text-red-400 border-red-800",
        "Lost" => "bg-slate-700 text-slate-400 border-slate-600",
        _ => "bg-slate-700 text-slate-400 border-slate-600"
    };

    protected override void OnInitialized()
    {
        Lang.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Lang.OnChange -= StateHasChanged;
    }

    private bool _isLoading = true;
    private List<Jig> _allJigs = new();
    private List<Jig> _displayJigs = new();
    private List<Locator> _allLocators = new();

    private bool _showScanModal = false;
    private DotNetObjectReference<CurrentStatus>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            var auth = await Auth.GetAuthAsync();
            _role = auth.Role ?? "";
            _name = auth.Name ?? "";

            if (string.IsNullOrEmpty(_role))
            {
                NavManager.NavigateTo("/login");
                return;
            }

            await LoadData();
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        try
        {
            var jigsTask = Http.GetFromJsonAsync<List<Jig>>("api/jigs");
            var locatorsTask = Http.GetFromJsonAsync<List<Locator>>("api/locators");

            await Task.WhenAll(jigsTask, locatorsTask);

            _allJigs = await jigsTask ?? new List<Jig>();
            _allLocators = await locatorsTask ?? new List<Locator>();

            FilterData();
        }
        catch (Exception)
        {
            // Handle error minimally
        }
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        // Still support explicit Enter if needed, though FilterData is reactive on onkeyup
        if (e.Key == "Enter") FilterData();
    }

    private void FilterData()
    {
        var lower = _searchQuery.ToLowerInvariant();
        var query = _allJigs.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(lower))
        {
            query = query.Where(j => 
                (j.Id?.ToLowerInvariant().Contains(lower) == true) || 
                (j.PartNumber?.ToLowerInvariant().Contains(lower) == true) ||
                (j.SmartCodeName?.ToLowerInvariant().Contains(lower) == true)
            );
        }

        if (_statusFilter != "All")
        {
            query = query.Where(j => j.Status == _statusFilter);
        }

        if (_conditionFilter == "Issues")
        {
            query = query.Where(j => j.Condition == "NeedsCleaning" || j.Condition == "Broken" || j.Condition == "Lost");
        }
        else if (_conditionFilter != "All")
        {
            query = query.Where(j => j.Condition == _conditionFilter);
        }

        _totalItems = query.Count();

        // Adjust current page if out of bounds
        int maxPage = (int)Math.Ceiling(_totalItems / (double)_pageSize);
        if (maxPage == 0) maxPage = 1;
        if (_currentPage > maxPage) _currentPage = maxPage;

        _displayJigs = query.OrderBy(j => j.Id).Skip((_currentPage - 1) * _pageSize).Take(_pageSize).ToList();
    }

    private string GetLocatorName(string? id)
    {
        if (string.IsNullOrEmpty(id)) return "-";
        var loc = _allLocators.FirstOrDefault(l => l.Id == id);
        if (loc == null) return id;

        string name = loc.Name;
        if (name.IndexOf("Zone", StringComparison.OrdinalIgnoreCase) >= 0)
        {
            var cleaned = name.Replace("1 Cabinet Shelf", "").Replace("Cabinet Shelf", "")
                             .Replace("Cabinet", "").Replace("Shelf", "")
                             .Trim();
            if (cleaned.StartsWith("1 ")) cleaned = cleaned.Substring(2).Trim();
            return cleaned;
        }
        return name;
    }

    private void OpenScanModal()
    {
        _showScanModal = true;
        StateHasChanged();
        
        // Wait for modal to render, then start scanner
        Task.Delay(300).ContinueWith(_ => 
        {
            InvokeAsync(async () => {
                await JSRuntime.InvokeVoidAsync("startQrScan", _dotNetRef, "qr-reader");
            });
        });
    }

    private async Task CloseScanModal()
    {
        _showScanModal = false;
        await JSRuntime.InvokeVoidAsync("stopQrScan");
    }

    [JSInvokable]
    public async Task OnQrScanned(string decodedText)
    {
        await CloseScanModal();
        _searchQuery = decodedText;
        FilterData();
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        try { await JSRuntime.InvokeVoidAsync("stopQrScan"); } catch { }
    }

    private void OpenReportModal(string jigId)
    {
        _reportJigId = jigId;
        _reportType = "";
        _reportRemark = "";
        _showReportModal = true;
    }

    private void CloseReportModal()
    {
        _showReportModal = false;
        _isSubmittingReport = false;
    }

    private async Task SubmitReportIssue()
    {
        if (string.IsNullOrEmpty(_reportJigId) || string.IsNullOrEmpty(_reportType)) return;

        _isSubmittingReport = true;
        StateHasChanged();

        try
        {
            var req = new
            {
                JigId = _reportJigId,
                User = _name,
                IssueType = _reportType,
                Remark = _reportRemark
            };

            var res = await Http.PostAsJsonAsync("api/transactions/reportissue", req);
            if (res.IsSuccessStatusCode)
            {
                await LoadData();
                CloseReportModal();
            }
            else
            {
                // Optionally show error to user
            }
        }
        catch
        {
            // Fallback
        }
        finally
        {
            _isSubmittingReport = false;
            StateHasChanged();
        }
    }
}
