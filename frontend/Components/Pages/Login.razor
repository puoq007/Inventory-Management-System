@page "/login"
@layout AuthLayout
@inject NavigationManager NavManager
@inject AuthService Auth
@inject HttpClient Http

<form @onsubmit="ProcessLogin">
    <div class="mb-6">
        <label for="employeeid" class="block text-sm font-medium text-slate-300 mb-2">Employee ID</label>
        <div class="relative">
            <input @ref="_employeeIdInput" @bind="_employeeId" @bind:event="oninput" type="text" id="employeeid" inputmode="numeric" pattern="[0-9]*" maxlength="10" 
                   class="block w-full rounded-xl bg-slate-900 border-slate-700 text-slate-100 shadow-sm focus:border-mattel-red focus:ring-mattel-red sm:text-base py-3 px-4 border transition-colors" placeholder="Enter ID and press Return" />
            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                <span class="text-slate-500 text-sm">⏎</span>
            </div>
        </div>
    </div>
    <!-- Hidden submit button to allow Enter key to submit form across all browsers securely -->
    <button type="submit" class="hidden"></button>
</form>

@code {
    private string _employeeId = "";
    private ElementReference _employeeIdInput;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Auth.ClearAuthAsync();
            Auth.PendingEmployeeId = null;
            try
            {
                await _employeeIdInput.FocusAsync();
            }
            catch {}
        }
    }



    private async Task ProcessLogin()
    {
        // 1. numeric only (max 10) - achieved by HTML attributes and we could validate here
        var numericId = new string(_employeeId.Where(char.IsDigit).ToArray());
        if (numericId.Length == 0) return;

        var response = await Http.GetAsync($"api/users/{numericId}");
        
        if (response.IsSuccessStatusCode)
        {
            // found -> password required
            Auth.PendingEmployeeId = numericId;
            NavManager.NavigateTo("/login/password");
        }
        else
        {
            // not found -> guest -> direct to home
            // Guest does NOT require password
            await Auth.SetAuthAsync(numericId, "Guest", "Guest User");
            NavManager.NavigateTo("/");
        }
    }
}
