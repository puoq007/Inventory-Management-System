@page "/login/password"
@layout AuthLayout
@using frontend.Services
@inject NavigationManager NavManager
@inject AuthService Auth
@inject ApiClientService Api
@inject IJSRuntime JSRuntime
@inject LanguageService Lang
@using shared.Models
@using System.Net.Http.Json

<div>
    @if (_user != null)
    {
        <div class="mb-4 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-slate-700 text-mattel-red mb-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            </div>
            <h2 class="text-xl font-bold text-slate-100">@_user.Name</h2>
            <p class="text-sm text-slate-400">@Lang.T("รหัสพนักงาน", "Employee ID") #@_user.EmployeeId</p>
        </div>

        <form @onsubmit="VerifyAndLogin" class="space-y-4">
            <div>
                <label for="password" class="block text-sm font-medium text-slate-300 mb-2">@Lang.T("รหัสผ่าน", "Password")</label>
                <input @ref="_passwordInput" @bind="_password" @bind:event="oninput" type="password" id="password"
                       class="block w-full rounded-xl bg-slate-900 border-slate-700 text-slate-100 shadow-sm focus:border-mattel-red focus:ring-mattel-red sm:text-base py-3 px-4 border transition-colors" placeholder="••••••••" />
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="text-red-400 text-sm font-medium text-center">@_errorMessage</div>
            }

            <div class="flex flex-col gap-3 mt-6">
                <button type="submit" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-sm text-sm font-bold text-white bg-mattel-red hover:bg-mattel-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors">
                    @Lang.T("เข้าสู่ระบบ", "Sign in")
                </button>
                <button type="button" @onclick="GoBack" class="w-full flex justify-center py-3 px-4 border border-slate-700 rounded-xl shadow-sm text-sm font-medium text-slate-300 bg-slate-900 hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-slate-500 transition-colors">
                    @Lang.T("ย้อนกลับ", "Back")
                </button>
            </div>
        </form>
    }
    else
    {
        <div class="text-center p-4">
            <p class="text-slate-400 mb-4">@Lang.T("ไม่พบข้อมูลการเข้าสู่ระบบที่ค้างอยู่", "No pending login found.")</p>
            <button @onclick="GoBack" class="text-mattel-red hover:underline font-medium">@Lang.T("กลับไปหน้าล็อกอิน", "Return to Login")</button>
        </div>
    }
</div>

@code {
    /// <summary>รหัสผ่านที่ผู้ใช้กรอก</summary>
    private string _password = "";
    /// <summary>ข้อความแสดงข้อผิดพลาด</summary>
    private string _errorMessage = "";
    /// <summary>ข้อมูลพนักงานที่กำลังล็อกอิน</summary>
    private UserAccount? _user;
    /// <summary>Reference สำหรับช่องกรอกรหัสผ่าน</summary>
    private ElementReference _passwordInput;

    /// <summary>
    /// สั่ง Focus ที่ช่องกรอกรหัสผ่านหลังจากหน้าจอแสดงผลเสร็จ
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_user != null && !_focused)
        {
            _focused = true;
            try { await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('password')?.focus()"); } catch {}
        }
    }

    private bool _focused = false;

    /// <summary>
    /// ตรวจสอบว่ามีรหัสพนักงานที่ค้างรอการล็อกอินอยู่หรือไม่ ถ้าไม่มีให้กลับไปหน้าแรก
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        var pendingId = Auth.PendingEmployeeId;
        if (string.IsNullOrEmpty(pendingId))
        {
            NavManager.NavigateTo("/login");
            return;
        }

        try
        {
            _user = await Api.GetFromJsonAsync<UserAccount>($"api/users/{pendingId}");
            if (_user == null)
            {
                NavManager.NavigateTo("/login");
            }
        }
        catch
        {
            NavManager.NavigateTo("/login");
        }
    }



    /// <summary>โครงสร้างข้อมูลสำหรับรับ Response จาก API Login</summary>
    private class LoginResponsePayload
    {
        public string token { get; set; } = "";
        public UserAccount user { get; set; } = new();
    }

    /// <summary>
    /// ตรวจสอบรหัสผ่านกับระบบผ่าน API:
    /// - ถ้าถูกต้อง -> บันทึก Auth State (JWT) และไปหน้า Home
    /// - ถ้าผิด -> แสดงข้อความแจ้งเตือน
    /// </summary>
    private async Task VerifyAndLogin()
    {
        if (_user == null) return;

        var response = await Api.PostAsJsonAsync("api/users/login", new { EmployeeId = _user.EmployeeId, Password = _password });

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<LoginResponsePayload>();
            if (result != null && result.user != null)
            {
                await Auth.SetAuthAsync(result.user.EmployeeId, result.user.Role, result.user.Name, result.token);
                
                Auth.PendingEmployeeId = null;
                if (result.user.Role == "Operator")
                {
                    NavManager.NavigateTo("/scan-out");
                }
                else
                {
                    NavManager.NavigateTo("/");
                }
            }
        }
        else
        {
            _errorMessage = Lang.T("รหัสผ่านไม่ถูกต้อง", "Invalid password.");
        }
    }

    /// <summary>
    /// ยกเลิกการล็อกอินและกลับไปหน้ากรอกรหัสพนักงาน
    /// </summary>
    private void GoBack()
    {
        Auth.PendingEmployeeId = null;
        NavManager.NavigateTo("/login");
    }
}

