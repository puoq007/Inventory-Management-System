@page "/login/password"
@layout AuthLayout
@inject NavigationManager NavManager
@inject AuthService Auth
@inject HttpClient Http
@using shared.Models
@using System.Net.Http.Json

<div>
    @if (_user != null)
    {
        <div class="mb-4 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-blue-100 text-blue-600 mb-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            </div>
            <h2 class="text-xl font-bold text-slate-800">@_user.Name</h2>
            <p class="text-sm text-slate-500">Employee #@_user.EmployeeId</p>
        </div>

        <form @onsubmit="VerifyAndLogin" class="space-y-4">
            <div>
                <label for="password" class="block text-sm font-medium text-slate-700 mb-2">Password</label>
                <input @ref="_passwordInput" @bind="_password" @bind:event="oninput" type="password" id="password"
                       class="block w-full rounded-xl border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-base py-3 px-4 bg-slate-50 transition-colors" placeholder="••••••••" />
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="text-red-500 text-sm font-medium text-center">@_errorMessage</div>
            }

            <div class="flex flex-col gap-3 mt-6">
                <button type="submit" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-sm text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                    Sign in
                </button>
                <button type="button" @onclick="GoBack" class="w-full flex justify-center py-3 px-4 border border-slate-300 rounded-xl shadow-sm text-sm font-medium text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                    Back
                </button>
            </div>
        </form>
    }
    else
    {
        <div class="text-center p-4">
            <p class="text-slate-500 mb-4">No pending login found.</p>
            <button @onclick="GoBack" class="text-blue-600 hover:underline font-medium">Return to Login</button>
        </div>
    }
</div>

@code {
    private string _password = "";
    private string _errorMessage = "";
    private UserAccount? _user;
    private ElementReference _passwordInput;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _user != null)
        {
            try
            {
                await _passwordInput.FocusAsync();
            }
            catch {}
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var pendingId = Auth.PendingEmployeeId;
        if (string.IsNullOrEmpty(pendingId))
        {
            NavManager.NavigateTo("/login");
            return;
        }

        try
        {
            _user = await Http.GetFromJsonAsync<UserAccount>($"api/users/{pendingId}");
            if (_user == null)
            {
                NavManager.NavigateTo("/login");
            }
        }
        catch
        {
            NavManager.NavigateTo("/login");
        }
    }



    private class LoginResponsePayload
    {
        public string token { get; set; } = "";
        public UserAccount user { get; set; } = new();
    }

    private async Task VerifyAndLogin()
    {
        if (_user == null) return;

        var response = await Http.PostAsJsonAsync("api/users/login", new { EmployeeId = _user.EmployeeId, Password = _password });

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<LoginResponsePayload>();
            if (result != null && result.user != null)
            {
                await Auth.SetAuthAsync(result.user.EmployeeId, result.user.Role, result.user.Name, result.token);
                
                // Set the token on the HttpClient so subsequent requests are authenticated
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", result.token);

                Auth.PendingEmployeeId = null;
                NavManager.NavigateTo("/");
            }
        }
        else
        {
            _errorMessage = "Invalid password.";
        }
    }

    private void GoBack()
    {
        Auth.PendingEmployeeId = null;
        NavManager.NavigateTo("/login");
    }
}

