@page "/scan-out"
@* Version 102 (Strict RBAC) *@
@using shared.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject frontend.Services.AuthService Auth
@inject LanguageService Lang
@implements IDisposable

<PageTitle>Scan In/Out | Inventory</PageTitle>

<div class="h-full flex flex-col space-y-6">
    <div>
        <h1 class="text-3xl font-bold tracking-tight text-slate-100">@Lang.T("เบิก/คืน จิก", "Scan In / Out")</h1>
        <p class="text-slate-500 mt-1">@Lang.T("สแกนคิวอาร์โค้ดของจิกเพื่อทำรายการเบิกหรือคืน", "Scan a Jig QR code to check it in or out.")</p>
    </div>

    @* Safelist for Tailwind JIT to ensure dynamic C# formatting classes are included in the build *@
    <div class="hidden bg-blue-600 bg-amber-600 bg-emerald-600 bg-blue-50 bg-amber-50 bg-emerald-50 text-blue-900 text-amber-900 text-emerald-900 text-blue-600 text-amber-600 text-emerald-600 border-blue-200 border-amber-200 border-emerald-200 bg-blue-100 bg-amber-100 bg-emerald-100 text-blue-700 text-amber-700 text-emerald-700 hover:bg-blue-50 hover:bg-amber-50 hover:bg-emerald-50 hover:bg-blue-700 hover:bg-amber-700 hover:bg-emerald-700 focus:ring-blue-500 focus:ring-amber-500 focus:ring-emerald-500"></div>



    <div class="bg-slate-800 rounded-xl shadow-xl border border-slate-700 p-6 flex flex-col items-center">
        @if (!String.IsNullOrEmpty(_errorMessage) && !_sessionHistory.Any())
        {
            <div class="mb-4 bg-red-900/40 text-red-400 p-3 rounded-lg border border-red-900/40 w-full max-w-md">
                @_errorMessage
            </div>
        }

        @if (!String.IsNullOrEmpty(_successMessage) && !_sessionHistory.Any())
        {
            <div class="mb-4 bg-green-900/40 text-green-400 p-3 rounded-lg border border-green-900/40 w-full max-w-md">
                @_successMessage
            </div>
        }

        @* Physical Scanner section *@
        @{
            var containerStyle = "bg-slate-900 border-slate-700";
            var textStyle = "text-slate-200";
            var iconStyle = "text-mattel-red";
                            
            var title = Lang.T("ทำรายการ", "Scan Transaction");

            var locLabel = Lang.T("สแกนป้ายระบุตำแหน่ง *", "Scan Locator ID / Zone *");
            var locHint  = Lang.T("สแกนสถานที่ก่อนตามด้วยจิ๊ก", "Scan Location first, then Jig");
                           
            var btnStyle = "bg-mattel-red hover:bg-mattel-hover focus:ring-red-500";
            var btnText = Lang.T("ยืนยัน", "Confirm");

            var selId = _selectedLocatorId;
            var selLoc = _locators?.FirstOrDefault(l => l.Id == selId);
        }
        <div class="mb-6 w-full max-w-md @containerStyle p-6 rounded-xl border">
            <h3 class="font-bold @textStyle mb-4 text-lg flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 @iconStyle" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" />
                </svg>
                @title
            </h3>
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-300 mb-1">@locLabel</label>
                @if (_locators == null)
                {
                    <div class="text-xs text-slate-500 py-2">กำลังโหลด...</div>
                }
                else
                {
                    <div class="relative">
                        <input type="text"
                               @ref="_locationSearchRef"
                               @bind="_selectedLocatorId"
                               @bind:event="oninput"
                               @onkeyup="HandleLocationKeyUp"
                               placeholder="@Lang.T("🔍 พิมพ์หรือสแกนสถานที่...", "🔍 Search or Scan Location...")"
                               class="w-full rounded-lg bg-slate-800 border-slate-700 text-slate-100 shadow-sm focus:border-mattel-red focus:ring-mattel-red focus:ring-2 outline-none font-mono text-lg px-4 py-3 border transition-all disabled:bg-slate-800 disabled:cursor-not-allowed disabled:text-slate-500" />
                    </div>
                }
                <p class="text-xs text-slate-400 mt-1">@locHint</p>
            </div>

            <p class="@textStyle border-t border-slate-700 text-sm mb-2 font-semibold mt-4 pt-4">
                @Lang.T("สแกนคิวอาร์โค้ดจิ๊ก", "Scan Jig QR Code")
            </p>
            <div class="flex space-x-2">
                <input type="text" @ref="_jigInputRef" @bind="_manualJigId" @bind:event="oninput" @onkeyup="HandleKeyUp"
                       disabled="@IsInputDisabled"
                       placeholder="@InputPlaceholder"
                       class="flex-grow rounded-lg bg-slate-800 border-slate-700 text-slate-100 shadow-sm focus:border-mattel-red focus:ring-mattel-red focus:ring-2 outline-none font-mono text-lg px-4 py-3 border transition-all disabled:bg-slate-900 disabled:cursor-not-allowed" />
                <button @onclick="ProcessManualEntry"
                        disabled="@(_isProcessing || IsInputDisabled)"
                        class="@btnStyle text-white px-6 py-3 rounded-lg font-bold disabled:opacity-50 transition-colors shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 w-28">
                    @if (_isProcessing)
                    {
                        <span class="inline-block animate-spin h-5 w-5 border-2 border-white rounded-full border-t-transparent"></span>
                    }
                    else
                    {
                        <span>@btnText</span>
                    }
                </button>
            </div>
        </div>

        @* Session History Log *@
        <div class="w-full max-w-2xl mt-4 bg-slate-800 rounded-xl shadow-xl border border-slate-700 overflow-hidden animate-fade-in mb-10">
            <div class="px-4 py-3 bg-slate-900 border-b border-slate-700">
                <div class="flex items-center justify-between">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-slate-500">@Lang.T("ประวัติการทำรายการล่าสุด", "Recently Scanned / Activity")</h3>
                    <button @onclick="ClearSessionHistory" class="text-[10px] font-bold text-slate-500 hover:text-red-400 transition-colors uppercase tracking-widest">@Lang.T("ล้างประวัติ", "Clear")</button>
                </div>
            </div>
            <div class="max-h-80 overflow-y-auto">
                <table class="w-full text-sm text-left">
                    <thead class="bg-slate-800 sticky top-0 border-b border-slate-700 shadow-sm text-xs uppercase text-slate-400 z-10">
                        <tr>
                            <th class="px-4 py-2 font-semibold w-24">@Lang.T("เวลา", "Time")</th>
                            <th class="px-4 py-2 font-semibold">@Lang.T("รหัสจิก", "Jig ID")</th>
                            <th class="px-4 py-2 font-semibold">@Lang.T("ตำแหน่ง / สถานะ", "Location / Status")</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-700">
                        @if (!_sessionHistory.Any())
                        {
                            <tr>
                                <td colspan="3" class="px-4 py-8 text-center text-slate-500 italic">
                                    @Lang.T("ยังไม่มีรายการในขณะนี้", "No activity found.")
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in _sessionHistory.OrderByDescending(h => h.Timestamp))
                            {
                                <tr class="@(item.IsError ? "bg-red-900/20" : "hover:bg-slate-700 transition-colors")">
                                    <td class="px-4 py-2.5 text-slate-400 whitespace-nowrap text-xs">@item.Timestamp.ToString("HH:mm:ss")</td>
                                    <td class="px-4 py-2.5 font-mono font-semibold @(item.IsError ? "text-red-400" : "text-slate-100")">
                                        @item.JigId
                                    </td>
                                    <td class="px-4 py-2.5">
                                        @if (item.IsError)
                                        {
                                            <div class="flex items-center gap-1.5 text-xs text-red-600 font-medium">
                                                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                                @item.ErrorMessage
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-2 py-1 rounded-md text-xs font-medium 
                                                @(item.Action.Contains("Transfer") ? "bg-purple-900/40 text-purple-400 border border-purple-900/40" :
                                                  item.Action.Contains("Out") ? "bg-blue-900/40 text-blue-400 border border-blue-900/40" : 
                                                  item.Action.Contains("Clean") ? "bg-amber-900/40 text-amber-400 border border-amber-900/40" : 
                                                  "bg-emerald-900/40 text-emerald-400 border border-emerald-900/40")">
                                                @(item.Action.Contains("Transfer") ? Lang.T("โอนย้ายไปที่:", "Transferred to:") :
                                                  item.Action.Contains("Out") ? Lang.T("เบิกไปที่:", "Out to:") : 
                                                  item.Action.Contains("Clean") ? Lang.T("ส่งล้างที่:", "Cleaning at:") : 
                                                  Lang.T("เก็บที่:", "Stored at:")) @TranslateLocation(item.Location)
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="p-3 bg-slate-900 border-t border-slate-700 text-center">
                <a href="/history" class="text-[10px] font-bold text-mattel-red hover:text-mattel-hover transition-colors uppercase tracking-widest inline-flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    @Lang.T("ดูประวัติทั้งหมด", "View All Transactions")
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _isProcessing = false;
    private string _errorMessage = "";
    private string _successMessage = "";
    private string _manualJigId = "";
    private string _currentUser = "";

    private ElementReference _locationSearchRef;
    private ElementReference _jigInputRef;

    private string _selectedLocatorId = "";
    private List<Locator>? _locators;
    private List<ScanSessionItem> _sessionHistory = new();

    private bool IsInputDisabled => _isProcessing || string.IsNullOrEmpty(_selectedLocatorId);

    private string InputPlaceholder => string.IsNullOrEmpty(_selectedLocatorId) ? Lang.T("เลือกสถานที่ก่อน...", "Select Location first...") : Lang.T("สแกนคิวอาร์โค้ดที่นี่...", "Scan QR Code here...");

    public class ScanSessionItem
    {
        public string JigId { get; set; } = "";
        public string Action { get; set; } = "";
        public string Location { get; set; } = "";
        public DateTime Timestamp { get; set; }
        public bool IsError { get; set; }
        public string ErrorMessage { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        var authObj = await Auth.GetAuthAsync();
        var role = authObj.Role ?? "";
        
        if (role == "Engineer" || role == "Guest" || string.IsNullOrEmpty(role))
        {
            NavManager.NavigateTo("/");
            return;
        }

        _currentUser = authObj.Name ?? "Unknown";
        _locators = await Http.GetFromJsonAsync<List<Locator>>("api/locators");
        
        // Load recent transactions as initial history
        try 
        {
            var txnsTask = Http.GetFromJsonAsync<List<TransactionRow>>("api/transactions");
            var jigsTask = Http.GetFromJsonAsync<List<Jig>>("api/jigs");
            await Task.WhenAll(txnsTask, jigsTask);
            
            var txns = await txnsTask;
            var jigs = await jigsTask;
            
            if (txns != null)
            {
                _sessionHistory = txns.Take(10).Select(t => {
                    var jig = jigs?.FirstOrDefault(j => j.Uid == t.JigUid);
                    return new ScanSessionItem {
                        JigId = jig?.Id ?? t.JigUid,
                        Action = t.Action,
                        Location = t.Destination,
                        Timestamp = t.Timestamp,
                        IsError = false
                    };
                }).ToList();
            }
        }
        catch { /* Fallback if history fail */ }
    }

    protected override void OnInitialized()
    {
        Lang.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Lang.OnChange -= StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Set initial state
            await Task.Delay(100); 
            await SetFocusAsync();
            StateHasChanged();
        }
    }



    private void ClearSessionHistory()
    {
        _sessionHistory.Clear();
        StateHasChanged();
    }

    private async Task HandleLocationKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(_selectedLocatorId))
        {
            await SetFocusAsync(); // This will focus _jigInputRef since _selectedLocatorId is not empty
        }
    }

    private async Task SetFocusAsync()
    {
        try
        {
            if (string.IsNullOrEmpty(_selectedLocatorId))
            {
                if (_locationSearchRef.Context != null)
                {
                    await _locationSearchRef.FocusAsync();
                }
            }
            else
            {
                if (_jigInputRef.Context != null)
                {
                    await _jigInputRef.FocusAsync();
                }
            }
        }
        catch { /* Ignore if focus fails during rapid navigation */ }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await ProcessManualEntry();
    }

    private async Task ProcessManualEntry()
    {
        if (string.IsNullOrWhiteSpace(_manualJigId))
        {
            _errorMessage = "Please enter a Jig ID";
            return;
        }await ProcessScan(_manualJigId.Trim());
    }

    private async Task ProcessScan(string jigId)
    {
        jigId = CleanAllSpaces(jigId)?.ToUpperInvariant() ?? "";
        _selectedLocatorId = CleanAllSpaces(_selectedLocatorId) ?? "";
        try
        {
            _isProcessing = true;
            _errorMessage = "";
            _successMessage = "";

            HttpResponseMessage response;

            // Resolve the typed string (which could be an ID or a Name) to the actual Location ID
            var actualLocatorId = _selectedLocatorId;
            var destName = _selectedLocatorId;
            
            var matchedLoc = _locators?.FirstOrDefault(l => 
                string.Equals(CleanAllSpaces(l.Id), _selectedLocatorId, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(CleanAllSpaces(l.Name), _selectedLocatorId, StringComparison.OrdinalIgnoreCase));

            if (matchedLoc != null)
            {
                actualLocatorId = matchedLoc.Id;
                destName = matchedLoc.Name;
            }
            else
            {
                var errMsg = "ไม่พบข้อมูล Locator นี้ในระบบ โปรดตรวจสอบอีกครั้ง";
                _errorMessage = errMsg;
                
                // Log failed attempt to history so user sees it
                _sessionHistory.Insert(0, new ScanSessionItem {
                    JigId = jigId,
                    Action = "Invalid Loc",
                    Location = _selectedLocatorId,
                    Timestamp = DateTime.Now,
                    IsError = true,
                    ErrorMessage = errMsg
                });

                _isProcessing = false;
                StateHasChanged();
                return;
            }

            string modeString = "out";
            
            if (matchedLoc.Type == "Production")
            {
                modeString = "Out to";
                var request = new { JigId = jigId, User = _currentUser, Destination = destName, LocatorId = actualLocatorId };
                response = await Http.PostAsJsonAsync("api/transactions/checkout", request);
            }
            else if (matchedLoc.Type == "Cleaning")
            {
                modeString = "Clean";
                var request = new { JigId = jigId, User = _currentUser, LocatorId = actualLocatorId };
                response = await Http.PostAsJsonAsync("api/transactions/checkin", request);
            }
            else // Store
            {
                modeString = "Store";
                var request = new { JigId = jigId, User = _currentUser, LocatorId = actualLocatorId };
                response = await Http.PostAsJsonAsync("api/transactions/returntostore", request);
            }

            if (response.IsSuccessStatusCode)
            {
                var responseContent = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                string actionTypeReturned = "";
                if (responseContent.TryGetProperty("actionType", out var at)) {
                    actionTypeReturned = at.GetString() ?? "";
                }

                var actionText = "เบิกออกสำเร็จ";
                if (actionTypeReturned == "Transfer") actionText = "โอนย้ายสำเร็จ";
                else if (matchedLoc.Type == "Cleaning") actionText = "ส่งล้างสำเร็จ";
                else if (matchedLoc.Type != "Production") actionText = "เก็บเข้าตู้สำเร็จ";

                _successMessage = $"{actionText}: {jigId}";
                
                // Add to history
                _sessionHistory.Insert(0, new ScanSessionItem
                {
                    JigId = jigId,
                    Action = (actionTypeReturned == "Transfer") ? "Transfer" : modeString,
                    Location = destName,
                    Timestamp = DateTime.Now,
                    IsError = false
                });

                _manualJigId = "";
                _isProcessing = false;
                StateHasChanged();
                await Task.Delay(50);
                await SetFocusAsync();

                _ = JSRuntime.InvokeVoidAsync("Swal.fire", new
                {
                    title = "Success!",
                    text = $"{actionText}\nJig: {jigId}",
                    icon = "success",
                    timer = 2000,
                    showConfirmButton = false,
                    toast = true,
                    position = "top-end"
                });
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                _errorMessage = $"ไม่สำเร็จ: {error}";
                
                // Add error to history
                _sessionHistory.Insert(0, new ScanSessionItem
                {
                    JigId = jigId,
                    Action = modeString,
                    Location = destName,
                    Timestamp = DateTime.Now,
                    IsError = true,
                    ErrorMessage = error
                });

                _isProcessing = false;
                StateHasChanged();
                await Task.Delay(50);
                await SetFocusAsync();

                _ = JSRuntime.InvokeVoidAsync("Swal.fire", new
                {
                    title = "Error!",
                    text = error,
                    icon = "error",
                    confirmButtonColor = "#ef4444",
                    toast = true,
                    position = "top-end",
                    timer = 3000,
                    showConfirmButton = false
                });
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
            
            _sessionHistory.Insert(0, new ScanSessionItem
            {
                JigId = jigId,
                Action = "Error",
                Location = _selectedLocatorId,
                Timestamp = DateTime.Now,
                IsError = true,
                ErrorMessage = ex.Message
            });

            _isProcessing = false;
            StateHasChanged();
            await Task.Delay(50);
            await SetFocusAsync();
        }
    }

    private string TranslateLocation(string loc)
    {
        if (string.IsNullOrEmpty(loc)) return loc;

        if (loc.IndexOf("Zone", StringComparison.OrdinalIgnoreCase) >= 0)
        {
            var cleaned = loc.Replace("1 Cabinet Shelf", "").Replace("Cabinet Shelf", "")
                             .Replace("Cabinet", "").Replace("Shelf", "")
                             .Trim();
            if (cleaned.StartsWith("1 ")) cleaned = cleaned.Substring(2).Trim();
            return cleaned;
        }

        return loc switch {
            "Storage" => Lang.T("คลังสินค้า / ที่เก็บ (Storage)", "Storage"),
            "Production" => Lang.T("สายการผลิต (Production)", "Production"),
            "Cleaning" => Lang.T("สถานีล้าง (Cleaning)", "Cleaning Station"),
            _ when loc.Contains("Cabinet") => loc.Replace("Cabinet", Lang.T("ตู้", "Cabinet")).Replace("Shelf", Lang.T("ชั้น", "Shelf")),
            _ => loc
        };
    }

    private string? CleanAllSpaces(string? val)
    {
        if (string.IsNullOrWhiteSpace(val)) return val?.Trim();
        return new string(val.Where(c => !char.IsWhiteSpace(c)).ToArray());
    }

    public ValueTask DisposeAsync()
    {
        return ValueTask.CompletedTask;
    }
}

