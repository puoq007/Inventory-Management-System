@inherits LayoutComponentBase
@inject NavigationManager NavManager
@inject LanguageService Lang
@implements IDisposable
@using frontend.Services
@inject AuthService Auth
@inject HttpClient Http

<div class="min-h-[100dvh] bg-slate-900 text-slate-300 font-sans flex flex-col text-sm w-full max-w-full min-w-0 overflow-x-hidden">
    <!-- Top Navigation Bar -->
    <nav class="bg-slate-800 border-b border-slate-700 sticky top-0 z-50 shadow-md relative w-full">
        <div class="max-w-[1500px] mx-auto px-4 sm:px-6 lg:px-8 h-20">
            <div class="flex items-center justify-between h-full">
                
                <!-- Left: Logo & Links -->
                <div class="flex items-center h-full">
                    <!-- Logo -->
                    <div class="flex-shrink-0 flex items-center cursor-pointer mr-10 transition-transform hover:scale-105 active:scale-95 h-full" @onclick='() => NavManager.NavigateTo("/")'>
                        <img src="images/mattel.png" alt="Mattel" style="height: 60px; width: auto;" class="object-contain drop-shadow-[0_0_8px_rgba(238,0,36,0.3)]" />
                    </div>

                    <!-- Desktop Navigation Links -->
                    <div class="hidden md:flex items-center space-x-2 h-full">
                        <NavLink class="inline-flex items-center px-5 py-3 text-[20px] font-medium border-b-2 border-transparent text-slate-300 hover:text-white transition-colors h-full" ActiveClass="!border-mattel-red text-white bg-slate-900/50" href="/" Match="NavLinkMatch.All">@Lang.T("แดชบอร์ด", "Dashboard")</NavLink>
                        <NavLink class="inline-flex items-center px-5 py-3 text-[20px] font-medium border-b-2 border-transparent text-slate-300 hover:text-white transition-colors h-full" ActiveClass="!border-mattel-red text-white bg-slate-900/50" href="/current-status">@Lang.T("สถานะปัจจุบัน", "Current Status")</NavLink>
                        @if (_role == "Admin" || _role == "ProdLead" || _role == "Operator") {
                            <NavLink class="inline-flex items-center px-5 py-3 text-[20px] font-medium border-b-2 border-transparent text-slate-300 hover:text-white transition-colors h-full" ActiveClass="!border-mattel-red text-white bg-slate-900/50" href="/scan-out">@Lang.T("เบิก/คืนจิก", "Scan In/Out")</NavLink>
                        }
                        @if (_role != "Guest") {
                            <NavLink class="inline-flex items-center px-5 py-3 text-[20px] font-medium border-b-2 border-transparent text-slate-300 hover:text-white transition-colors h-full" ActiveClass="!border-mattel-red text-white bg-slate-900/50" href="/history">@Lang.T("ประวัติการใช้งาน", "History")</NavLink>
                        }

                        @if (_role == "Admin" || _role == "Engineer" || _role == "ProdLead")
                        {
                            <div class="relative h-full flex items-center" @onmouseenter="() => _isManagementMenuOpen = true" @onmouseleave="() => _isManagementMenuOpen = false">
                                <button class="inline-flex items-center px-5 py-3 text-[20px] font-medium border-b-2 border-transparent text-slate-300 hover:text-white transition-colors h-full @(_isManagementMenuOpen ? "text-white !border-mattel-red bg-slate-900/50" : "")">
                                    @Lang.T("การจัดการ", "Management")
                                    <svg class="ml-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                                </button>
                                @if (_isManagementMenuOpen)
                                {
                                    <div class="absolute top-full left-0 w-56 bg-slate-800 border-x border-b border-slate-700 rounded-b-lg shadow-xl py-2 z-50">
                                        @if (_role == "Admin")
                                        {
                                            <NavLink class="block px-5 py-2.5 text-[20px] text-slate-300 hover:bg-slate-700 hover:text-white transition-colors" ActiveClass="font-bold text-mattel-red bg-slate-900/50" href="/admin/users">@Lang.T("จัดการผู้ใช้งาน", "User Management")</NavLink>
                                        }
                                        @if (_role == "Admin" || _role == "Engineer" || _role == "ProdLead")
                                        {
                                            <NavLink class="block px-5 py-2.5 text-[20px] text-slate-300 hover:bg-slate-700 hover:text-white transition-colors" ActiveClass="font-bold text-mattel-red bg-slate-900/50" href="/admin/register-jig">@Lang.T("จัดการจิก", "Jigs Management")</NavLink>
                                            <NavLink class="block px-5 py-2.5 text-[20px] text-slate-300 hover:bg-slate-700 hover:text-white transition-colors" ActiveClass="font-bold text-mattel-red bg-slate-900/50" href="/admin/locators">@Lang.T("ตำแหน่งจัดเก็บ", "Locators")</NavLink>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Right: Icons, Profile, Language -->
                <div class="hidden md:flex items-center space-x-6 h-full">
                    
                    <div class="flex items-center space-x-2 text-[13px] uppercase tracking-wider font-bold">
                        <button @onclick='() => Lang.SetLanguage("EN")' 
                                class='transition-colors px-1 @(Lang.Current == "EN" ? "text-mattel-red" : "text-slate-500 hover:text-slate-300")'>
                            EN
                        </button>
                        <span class="text-slate-700 select-none pb-[1px]">|</span>
                        <button @onclick='() => Lang.SetLanguage("TH")' 
                                class='transition-colors px-1 @(Lang.Current == "TH" ? "text-mattel-red" : "text-slate-500 hover:text-slate-300")'>
                            TH
                        </button>
                    </div>

                    <!-- Profile Dropdown -->
                    <div class="relative flex items-center h-full" @onmouseenter="() => _isProfileOpen = true" @onmouseleave="() => _isProfileOpen = false">
                        <button class="flex items-center focus:outline-none hover:text-white transition-colors gap-3 cursor-pointer outline-none group">
                            <div class="bg-mattel-red text-white w-10 h-10 rounded-full flex items-center justify-center text-[14px] font-black shadow-[0_0_8px_rgba(238,0,36,0.3)] select-none">@(_name?.Length > 0 ? _name[0].ToString().ToUpper() : "?")</div>
                            <span class="text-[20px] font-semibold text-slate-200 group-hover:text-white">@(string.IsNullOrEmpty(_name) ? "Guest" : _name)</span>
                            <svg class="h-6 w-6 text-slate-500 group-hover:text-slate-300 -ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </button>

                        @if (_isProfileOpen)
                        {
                            <div class="absolute right-0 top-full w-64 bg-slate-800 border-x border-b border-slate-700 rounded-b-xl shadow-2xl py-2 z-50">
                                <div class="px-5 py-3 border-b border-slate-700/50 mb-2 bg-slate-800/50">
                                    <p class="text-[20px] font-bold text-slate-100 truncate" title="@_name">@_name</p>
                                    <p class="text-sm text-slate-400 font-medium">@GetRoleDisplay(_role)</p>
                                </div>
                                <button @onclick='() => NavManager.NavigateTo("/profile")' class="w-full text-left px-5 py-2.5 text-[20px] whitespace-nowrap text-slate-300 hover:bg-slate-700 hover:text-white transition-colors flex items-center gap-2">
                                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                    @Lang.T("โปรไฟล์", "My Profile")
                                </button>
                                <div class="border-t border-slate-700/50 my-1"></div>
                                <button @onclick="Logout" class="w-full text-left px-5 py-2.5 text-[20px] whitespace-nowrap text-mattel-red font-bold hover:bg-slate-700 transition-colors flex items-center gap-2">
                                    <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                                    <span class="whitespace-nowrap">@Lang.T("ออกจากระบบ", "Logout")</span>
                                </button>
                            </div>
                        }
                    </div>
                </div>
                <!-- Mobile: Language Toggle + Hamburger -->
                <div class="md:hidden flex items-center gap-3">
                    <div class="flex items-center space-x-1 text-[13px] uppercase tracking-wider font-bold">
                        <button type="button" @onclick='() => Lang.SetLanguage("EN")'
                                class='transition-colors px-1.5 py-1 @(Lang.Current == "EN" ? "text-mattel-red" : "text-slate-500 hover:text-slate-300")'>
                            EN
                        </button>
                        <span class="text-slate-700 select-none">|</span>
                        <button type="button" @onclick='() => Lang.SetLanguage("TH")'
                                class='transition-colors px-1.5 py-1 @(Lang.Current == "TH" ? "text-mattel-red" : "text-slate-500 hover:text-slate-300")'>
                            TH
                        </button>
                    </div>
                    <button @onclick="ToggleMenu" class="p-2 text-slate-300 focus:outline-none hover:bg-slate-700 rounded transition duration-200">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            @if (_isMenuOpen) {
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            } else {
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                            }
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile Menu Overlay (กดนอก sidebar เพื่อปิด) -->
        @if (_isMenuOpen)
        {
            <div class="md:hidden fixed inset-0 z-40 bg-black/50" @onclick="CloseMenu"></div>
            <div class="md:hidden border-t border-slate-700 bg-slate-800 shadow-xl absolute w-full left-0 z-50">
                <div class="px-2 pt-2 pb-3 space-y-1">
                    <NavLink @onclick="CloseMenu" class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:bg-slate-700 hover:text-white" ActiveClass="!text-mattel-red bg-slate-900 font-bold" href="/" Match="NavLinkMatch.All">@Lang.T("แดชบอร์ด", "Dashboard")</NavLink>
                    <NavLink @onclick="CloseMenu" class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:bg-slate-700 hover:text-white" ActiveClass="!text-mattel-red bg-slate-900 font-bold" href="/current-status">@Lang.T("สถานะปัจจุบัน", "Current Status")</NavLink>
                    @if (_role == "Admin" || _role == "ProdLead" || _role == "Operator") {
                        <NavLink @onclick="CloseMenu" class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:bg-slate-700 hover:text-white" ActiveClass="!text-mattel-red bg-slate-900 font-bold" href="/scan-out">@Lang.T("เบิก/คืนจิก", "Scan In/Out")</NavLink>
                    }
                    @if (_role != "Guest") {
                        <NavLink @onclick="CloseMenu" class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:bg-slate-700 hover:text-white" ActiveClass="!text-mattel-red bg-slate-900 font-bold" href="/history">@Lang.T("ประวัติการใช้งาน", "History")</NavLink>
                    }
                    <div class="border-t border-slate-700 my-2"></div>
                    
                    @if (_role == "Admin" || _role == "Engineer" || _role == "ProdLead") {
                        <div class="px-3 py-2 text-xs font-bold text-slate-500 uppercase tracking-widest">@Lang.T("การจัดการ", "Management")</div>
                        
                        @if (_role == "Admin") {
                            <NavLink @onclick="CloseMenu" class="block px-6 py-2 rounded-md text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white" ActiveClass="!text-mattel-red font-bold" href="/admin/users">@Lang.T("จัดการผู้ใช้งาน", "User Management")</NavLink>
                        }
                        <NavLink @onclick="CloseMenu" class="block px-6 py-2 rounded-md text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white" ActiveClass="!text-mattel-red font-bold" href="/admin/register-jig">@Lang.T("จัดการจิก", "Jig Management")</NavLink>
                        <NavLink @onclick="CloseMenu" class="block px-6 py-2 rounded-md text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white" ActiveClass="!text-mattel-red font-bold" href="/admin/locators">@Lang.T("ตำแหน่งจัดเก็บ", "Locators")</NavLink>
                        <div class="border-t border-slate-700 my-2"></div>
                    }

                    <!-- Profile Card -->
                    <button type="button" @onclick="GoToProfile" class="flex w-full cursor-pointer select-none items-center gap-3 rounded-xl border border-slate-700 bg-slate-900/40 px-4 py-3 text-left transition-colors hover:border-slate-500 hover:bg-slate-700">
                        <div class="bg-mattel-red text-white w-8 h-8 rounded-full flex items-center justify-center text-[13px] font-black shadow-sm select-none">@(_name?.Length > 0 ? _name[0].ToString().ToUpper() : "?")</div>
                        <div class="min-w-0 flex-1">
                            <div class="text-sm font-bold text-slate-200 truncate">@_name</div>
                            <div class="text-xs text-slate-400 truncate">@GetRoleDisplay(_role)</div>
                        </div>
                        <svg class="h-4 w-4 flex-shrink-0 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </button>

                    <button type="button" @onclick="Logout" class="block w-full cursor-pointer rounded-md px-3 py-2 text-left text-base font-bold text-mattel-red hover:bg-slate-700">@Lang.T("ออกจากระบบ", "Logout")</button>
                </div>
            </div>
        }
    </nav>

    <!-- Main Content -->
    <main class="flex-grow p-4 md:p-8 w-full max-w-[1500px] mx-auto min-w-0">
        <RoleGate AllowedRoles="@(_allRoles)">
            @Body
        </RoleGate>
    </main>
</div>

@code {
    private string _role = "";
    private string _name = "";
    private readonly string[] _allRoles = new[] { "Admin", "Engineer", "ProdLead", "Operator", "Guest" };
    private bool _isMenuOpen = false;
    private bool _isProfileOpen = false;
    private bool _isManagementMenuOpen = false;

    private void ToggleMenu() => _isMenuOpen = !_isMenuOpen;

    protected override void OnInitialized()
    {
        Lang.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Lang.OnChange -= StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            var auth = await Auth.GetAuthAsync();
            _role = auth.Role ?? "";
            _name = auth.Name ?? "";

            var token = await Auth.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }

            await Lang.InitializeAsync();
        }
        catch
        {
            /* JS/localStorage may be unavailable in rare cases; keep shell visible */
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task Logout()
    {
        _isMenuOpen = false;
        await Auth.ClearAuthAsync();
        NavManager.NavigateTo("/login");
    }

    private void GoToProfile()
    {
        _isMenuOpen = false;
        NavManager.NavigateTo("/profile");
    }

    private void CloseMenu()
    {
        _isMenuOpen = false;
    }

    private string GetRoleDisplay(string role) => role switch
    {
        "Admin" => Lang.T("ผู้ดูแลระบบ", "Administrator"),
        "Engineer" => Lang.T("วิศวกร", "Engineer"),
        "ProdLead" => Lang.T("หัวหน้าฝ่ายผลิต", "Production Lead"),
        "Operator" => Lang.T("พนักงานปฏิบัติการ", "Operator"),
        _ => role
    };
}
