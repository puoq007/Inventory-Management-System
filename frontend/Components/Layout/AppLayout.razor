@inherits LayoutComponentBase
@inject NavigationManager NavManager
@inject LanguageService Lang
@implements IDisposable
@using frontend.Services
@inject AuthService Auth
@inject HttpClient Http

<div class="min-h-[100dvh] bg-slate-50 text-slate-900 font-sans flex text-sm flex-col md:flex-row">
    <!-- Mobile header -->
    <div class="md:hidden flex items-center justify-between bg-slate-900 text-slate-100 p-4 sticky top-0 z-50 shadow-md">
        <div class="text-xl font-bold tracking-tight">
            <span class="text-blue-400">Jig</span> Inventory
        </div>
        <button @onclick="ToggleMenu" class="p-2 focus:outline-none hover:bg-slate-800 rounded transition duration-200">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                @if (_isMenuOpen) {
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                } else {
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                }
            </svg>
        </button>
    </div>

    <!-- Sidebar / Nav -->
    <nav class="@(_isMenuOpen ? "flex" : "hidden") md:flex w-full md:w-64 bg-slate-900 text-slate-100 flex-col items-center py-6 shadow-xl shrink-0 md:h-[100dvh] md:sticky md:top-0 overflow-y-auto z-40">
        <div class="hidden md:block text-2xl font-bold tracking-tight mb-8 px-4 text-center w-full">
            <span class="text-blue-400">Jig</span> Inventory
        </div>

        <div class="flex-grow w-full px-4 space-y-2">
            <NavLink class="block px-4 py-2 rounded-lg hover:bg-slate-800 transition-colors font-medium" href="/" Match="NavLinkMatch.All">@Lang.T("แผงควบคุม", "Dashboard")</NavLink>
            <NavLink class="block px-4 py-2 rounded-lg hover:bg-slate-800 transition-colors" href="/current-status">@Lang.T("สถานะปัจจุบัน", "Current Status")</NavLink>
            @if (_role == "Admin" || _role == "ProdLead" || _role == "Operator") {
                <NavLink class="block px-4 py-2 rounded-lg hover:bg-slate-800 transition-colors" href="/scan-out">@Lang.T("เบิก/คืน จิก", "Scan In / Out")</NavLink>
            }
            @if (_role != "Guest") {
                <NavLink class="block px-4 py-2 rounded-lg hover:bg-slate-800 transition-colors" href="/history">@Lang.T("ประวัติการใช้งาน", "History")</NavLink>
            }

            @if (_role == "Admin" || _role == "Engineer" || _role == "ProdLead" || _role == "Operator")
            {
                <div class="mt-4 pt-4 border-t border-slate-700">
                    <p class="text-[10px] text-slate-500 uppercase font-bold px-4 mb-2 tracking-widest">@Lang.T("การจัดการระบบ", "Management")</p>
                    @if (_role == "Admin")
                    {
                        <NavLink class="block px-4 py-2 rounded-lg hover:bg-slate-800 transition-colors" href="/admin/users">@Lang.T("ผู้ใช้งาน", "Users")</NavLink>
                    }
                    @if (_role == "Admin" || _role == "Engineer" || _role == "ProdLead")
                    {
                        <NavLink class="block px-4 py-2 rounded-lg hover:bg-slate-800 transition-colors" href="/admin/register-jig">@Lang.T("การจัดการ Jig", "Jig Management")</NavLink>
                        <NavLink class="block px-4 py-2 rounded-lg hover:bg-slate-800 transition-colors" href="/admin/locators">@Lang.T("ตำแหน่งเก็บ", "Locators")</NavLink>
                    }
                </div>
            }
        </div>
        
        <div class="mt-auto px-4 w-full pt-4">
            <div class="flex items-center justify-center space-x-1 mb-3 bg-slate-800/50 p-1 rounded-lg border border-slate-700/50">
                <button @onclick='() => Lang.SetLanguage("TH")' 
                        class='flex-1 text-[10px] font-bold py-1.5 rounded-md transition-all duration-200 @(Lang.Current == "TH" ? "bg-blue-600 text-white shadow-lg" : "text-slate-500 hover:text-slate-300 hover:bg-slate-800")'>
                    TH
                </button>
                <button @onclick='() => Lang.SetLanguage("EN")' 
                        class='flex-1 text-[10px] font-bold py-1.5 rounded-md transition-all duration-200 @(Lang.Current == "EN" ? "bg-blue-600 text-white shadow-lg" : "text-slate-500 hover:text-slate-300 hover:bg-slate-800")'>
                    EN
                </button>
            </div>
            <div class="bg-slate-800 rounded-lg p-3 text-center">
                <p class="text-sm font-semibold truncate" title="@_name">@_name</p>
                <p class="text-xs text-slate-400 mb-2">@_role</p>
                <button @onclick="Logout" class="text-xs font-bold bg-slate-700 hover:bg-red-600 w-full py-1.5 rounded transition-colors duration-200">@Lang.T("ออกจากระบบ", "Logout")</button>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow p-4 md:p-8">
        <RoleGate AllowedRoles="@(_allRoles)">
            @Body
        </RoleGate>
    </main>
</div>

@code {
    private string _role = "";
    private string _name = "";
    private readonly string[] _allRoles = new[] { "Admin", "Engineer", "ProdLead", "Operator", "Guest" };
    private bool _isMenuOpen = false;

    private void ToggleMenu() => _isMenuOpen = !_isMenuOpen;

    protected override void OnInitialized()
    {
        Lang.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Lang.OnChange -= StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var auth = await Auth.GetAuthAsync();
            _role = auth.Role ?? "";
            _name = auth.Name ?? "";

            var token = await Auth.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }

            await Lang.InitializeAsync();
            StateHasChanged();
        }
    }

    private async Task Logout()
    {
        await Auth.ClearAuthAsync();
        NavManager.NavigateTo("/login");
    }
}
