<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["css/app.css"]" />
    <link rel="stylesheet" href="@Assets["Inventory.styles.css"]" />
    <ImportMap />
    <HeadOutlet @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
</head>

<body>
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <script src="_framework/blazor.web.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        window.confirmAction = function(title, text, confirmBtnStr, icon) {
            return Swal.fire({
                title: title || 'Are you sure?',
                text: text || "You won't be able to revert this!",
                icon: icon || 'warning',
                showCancelButton: true,
                confirmButtonColor: '#2563eb',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: confirmBtnStr || 'Yes'
            }).then((result) => {
                return result.isConfirmed;
            });
        }

        window.downloadTextFile = function(fileName, content) {
            const blob = new Blob(["\ufeff" + content], { type: "text/csv;charset=utf-8;" });
            const link = document.createElement("a");
            if (link.download !== undefined) {
                const url = URL.createObjectURL(blob);
                link.setAttribute("href", url);
                link.setAttribute("download", fileName);
                link.style.visibility = 'hidden';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            }
        }

        window.printQR = function(svgHtml, jigId) {
            const printWnd = window.open('', '_blank', 'width=400,height=400');
            printWnd.document.write(`
                <html>
                <head><title>Print QR - ${jigId}</title></head>
                <body style="text-align:center; padding: 20px; font-family: sans-serif;">
                    <div style="width:150px; height:150px; margin: 0 auto;">${svgHtml}</div>
                    <h2>${jigId}</h2>
                    <p style="color:#666; font-size:12px;">Inventory System</p>
                    <script>
                        window.onload = function() { setTimeout(function(){ window.print(); window.close(); }, 200); }
                    <\/script>
                </body>
                </html>
            `);
            printWnd.document.close();
        }

        window.printQRs = function(qrDataList) {
            const printWnd = window.open('', '_blank', 'width=800,height=800');
            
            let content = '';
            qrDataList.forEach(data => {
                content += `
                    <div style="display:inline-block; text-align:center; padding: 20px; font-family: sans-serif; margin: 10px; border: 1px dashed #ccc; page-break-inside: avoid;">
                        <div style="width:150px; height:150px; margin: 0 auto;">${data.svg}</div>
                        <h2 style="margin: 10px 0 5px 0;">${data.id}</h2>
                        <p style="color:#666; font-size:12px; margin: 0;">Inventory System</p>
                    </div>
                `;
            });

            printWnd.document.write(`
                <html>
                <head><title>Print Multiple QRs</title></head>
                <body style="padding: 20px;">
                    ${content}
                    <script>
                        window.onload = function() { setTimeout(function(){ window.print(); window.close(); }, 500); }
                    <\/script>
                </body>
                </html>
            `);
            printWnd.document.close();
        }

        window.qrScannerInstance = null;
        window.startQrScan = function(dotNetHelper, elementId) {
            if (window.qrScannerInstance) return;
            window.qrScannerInstance = new window.Html5QrcodeScanner(elementId, { 
                fps: 10, 
                qrbox: {width: 250, height: 250}
            }, false);
            
            window.qrScannerInstance.render(
                (decodedText) => {
                    dotNetHelper.invokeMethodAsync('OnQrScanned', decodedText);
                },
                (error) => {}
            );
        };

        window.stopQrScan = function() {
            if (window.qrScannerInstance) {
                window.qrScannerInstance.clear();
                window.qrScannerInstance = null;
            }
        };
    </script>
</body>

</html>
