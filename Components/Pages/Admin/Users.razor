@page "/admin/users"
@inject Inventory.Services.AuthService Auth
@inject Microsoft.EntityFrameworkCore.IDbContextFactory<Inventory.Data.AppDbContext> DbFactory
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@using Inventory.Models

<PageTitle>Admin - Users | Inventory</PageTitle>

<div class="mb-6 flex justify-between items-end">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 mb-2">User Management</h1>
        <p class="text-slate-500">Add, edit, and manage user accounts and access roles.</p>
    </div>
    
    <button @onclick="OpenAddModal" class="px-5 py-2.5 bg-blue-600 text-white font-medium text-sm rounded-lg hover:bg-blue-700 shadow-sm transition-colors flex items-center">
        <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        New User
    </button>
</div>

@if (_isLoading)
{
    <div class="flex justify-center items-center py-12">
        <div class="text-slate-500 font-medium">Loading users...</div>
    </div>
}
else
{
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 mb-8">
        <div class="flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <label for="search" class="block text-sm font-medium text-slate-700 mb-1">Search Employee ID, Name, or Role</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                    <input type="text" id="search" @bind="_searchQuery" @bind:event="oninput" @onkeyup="FilterData"
                           class="block w-full pl-10 pr-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="e.g. 9005, John, Admin" />
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden mb-8">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Employee ID</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Name</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Role</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Password</th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-200">
                    @foreach (var user in _displayUsers ?? Enumerable.Empty<UserAccount>())
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">
                                @user.EmployeeId
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                @user.Name
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-semibold rounded-full border 
                                    @(user.Role == "Admin" ? "bg-purple-100 text-purple-800 border-purple-200" :
                                      user.Role == "Engineer" ? "bg-blue-100 text-blue-800 border-blue-200" :
                                      user.Role == "ProdLead" ? "bg-emerald-100 text-emerald-800 border-emerald-200" :
                                      "bg-slate-100 text-slate-800 border-slate-200")">
                                    @user.Role
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 font-mono tracking-widest text-lg">
                                ••••
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <button @onclick="() => OpenEditModal(user)" class="text-indigo-600 hover:text-indigo-900 mr-4 font-semibold px-2 py-1 rounded hover:bg-indigo-50 transition-colors">Edit</button>
                                <button @onclick="() => DeleteUser(user)" class="text-red-600 hover:text-red-900 font-semibold px-2 py-1 rounded hover:bg-red-50 transition-colors">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_showModal)
{
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center">
        <div class="relative w-full max-w-md bg-white rounded-2xl shadow-xl p-6 border border-slate-100 text-left">
            <h3 class="text-2xl font-bold text-slate-900 mb-6">@(_isEditMode ? "Edit User" : "Add New User")</h3>

            <div class="space-y-4 mb-6">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Employee ID</label>
                    <input type="text" @bind="_editingUser.EmployeeId" disabled="@_isEditMode" class="block w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm disabled:bg-slate-100 disabled:text-slate-500" placeholder="e.g. 9005" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
                    <input type="text" @bind="_editingUser.Name" class="block w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="e.g. John Doe" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Role</label>
                    <select @bind="_editingUser.Role" class="block w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                        @if (_currentRole == "Admin")
                        {
                            <option value="Admin">Admin</option>
                        }
                        @if (_currentRole == "Admin" || _currentRole == "Engineer")
                        {
                            <option value="Engineer">Engineer</option>
                        }
                        @if (_currentRole == "Admin" || _currentRole == "Engineer" || _currentRole == "ProdLead")
                        {
                            <option value="ProdLead">Production Lead</option>
                            <option value="Operator">Operator</option>
                            <option value="Guest">Guest</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Password</label>
                    <input type="text" @bind="_editingUser.Password" class="block w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="Any default password" />
                </div>
                
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="text-red-500 text-sm font-medium mt-2">@_errorMessage</div>
                }
            </div>

            <div class="flex justify-end space-x-3 pt-4 border-t border-slate-100">
                <button @onclick="CloseModal" class="px-4 py-2 bg-white text-slate-700 border border-slate-300 font-medium rounded-lg hover:bg-slate-50 transition-colors text-sm">Cancel</button>
                <button @onclick="SaveUser" class="px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors text-sm">Save Changes</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private bool _showModal = false;
    private bool _isEditMode = false;
    private UserAccount _editingUser = new();
    private string _errorMessage = "";
    private string _currentRole = "";
    private string _searchQuery = "";
    private IEnumerable<UserAccount>? _displayUsers;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var auth = await Auth.GetAuthAsync();
            var role = auth.Role ?? "";
            _currentRole = role;

            // Admin area validation
            if (string.IsNullOrEmpty(role) || (role != "Admin" && role != "Engineer" && role != "ProdLead"))
            {
                NavManager.NavigateTo("/");
                return;
            }

            FilterData();
            _isLoading = false;
            StateHasChanged();
        }
    }

    private IEnumerable<UserAccount> GetManageableUsers()
    {
        using var context = DbFactory.CreateDbContext();
        if (_currentRole == "Admin")
            return context.Users.ToList();
        else if (_currentRole == "Engineer")
            return context.Users.Where(u => u.Role != "Admin").ToList();
        else if (_currentRole == "ProdLead")
            return context.Users.Where(u => u.Role != "Admin" && u.Role != "Engineer").ToList();
            
        return Enumerable.Empty<UserAccount>();
    }

    private void FilterData()
    {
        var users = GetManageableUsers();

        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _displayUsers = users.ToList();
            return;
        }

        var lowerQuery = _searchQuery.ToLowerInvariant();
        _displayUsers = users.Where(u => 
            u.EmployeeId.ToLowerInvariant().Contains(lowerQuery) ||
            u.Name.ToLowerInvariant().Contains(lowerQuery) ||
            u.Role.ToLowerInvariant().Contains(lowerQuery)
        ).ToList();
    }

    private void OpenAddModal()
    {
        _editingUser = new UserAccount { Role = "Operator" };
        _isEditMode = false;
        _errorMessage = "";
        _showModal = true;
    }

    private void OpenEditModal(UserAccount user)
    {
        // Clone object to avoid live editing before Save
        _editingUser = new UserAccount 
        { 
            EmployeeId = user.EmployeeId, 
            Name = user.Name, 
            Role = user.Role, 
            Password = user.Password 
        };
        _isEditMode = true;
        _errorMessage = "";
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
    }

    private async Task SaveUser()
    {
        var actionName = _isEditMode ? "Edit User" : "Add User";
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", actionName, "Are you sure you want to save this user?", "Yes, save", "question");
        if (!confirmed) return;

        if (string.IsNullOrWhiteSpace(_editingUser.EmployeeId) || string.IsNullOrWhiteSpace(_editingUser.Name))
        {
            _errorMessage = "Employee ID and Name are required.";
            return;
        }

        using var context = DbFactory.CreateDbContext();
        if (_isEditMode)
        {
            var existing = context.Users.FirstOrDefault(u => u.EmployeeId == _editingUser.EmployeeId);
            if (existing != null)
            {
                existing.Name = _editingUser.Name;
                existing.Role = _editingUser.Role;
                existing.Password = _editingUser.Password;
                context.SaveChanges();
            }
        }
        else
        {
            if (context.Users.Any(u => u.EmployeeId == _editingUser.EmployeeId))
            {
                _errorMessage = "Employee ID already exists!";
                return;
            }
            context.Users.Add(_editingUser);
            context.SaveChanges();
        }

        FilterData();
        _showModal = false;
        StateHasChanged();
    }

    private async Task DeleteUser(UserAccount user)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Delete User", $"Are you sure you want to remove user {user.Name}?", "Yes, delete", "error");
        if (!confirmed) return;

        // Should not delete oneself normally, simple check for mock
        using var context = DbFactory.CreateDbContext();
        var toDelete = context.Users.FirstOrDefault(u => u.EmployeeId == user.EmployeeId);
        if (toDelete != null)
        {
            context.Users.Remove(toDelete);
            context.SaveChanges();
        }
        FilterData();
        StateHasChanged();
    }
}
