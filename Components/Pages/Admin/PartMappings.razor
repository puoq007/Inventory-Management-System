@page "/admin/part-mappings"
@inject Inventory.Services.AuthService Auth
@inject Microsoft.EntityFrameworkCore.IDbContextFactory<Inventory.Data.AppDbContext> DbFactory
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject Inventory.Services.ExcelImportService ExcelImport
@using Inventory.Models

<PageTitle>Admin - Part BOM Mappings | Inventory</PageTitle>

<div class="mb-6 flex justify-between items-end">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 mb-2">Part BOM Mappings</h1>
        <p class="text-slate-500">Link Part Numbers to required Jig Specifications.</p>
    </div>
    <div class="flex gap-2">
        <label class="px-5 py-2.5 bg-green-600 text-white font-medium text-sm rounded-lg hover:bg-green-700 shadow-sm transition-colors cursor-pointer flex items-center mb-0">
            <InputFile OnChange="ImportExcel" class="hidden" accept=".xlsx,.xls" />
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
            @if(_isImporting) { <span>Importing...</span> } else { <span>Import Excel</span> }
        </label>
        
        <label class="px-5 py-2.5 bg-teal-600 text-white font-medium text-sm rounded-lg hover:bg-teal-700 shadow-sm transition-colors cursor-pointer flex items-center mb-0">
            <InputFile OnChange="ImportExcel" class="hidden" accept=".csv" />
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v12m0 0l-4-4m4 4l4-4M9 3v8m0 0H5m4 0h4"></path></svg>
            @if(_isImporting) { <span>Importing...</span> } else { <span>Import CSV</span> }
        </label>
        
        <button @onclick="OpenAddModal" class="px-5 py-2.5 bg-blue-600 text-white font-medium text-sm rounded-lg hover:bg-blue-700 shadow-sm transition-colors flex items-center">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            New Mapping
        </button>
    </div>
</div>

@if (_isLoading)
{
    <div class="flex justify-center items-center py-12">
        <div class="text-slate-500 font-medium">Loading mappings...</div>
    </div>
}
else
{
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 mb-8">
        <div class="flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <label for="search" class="block text-sm font-medium text-slate-700 mb-1">Search Part Number or Spec</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                    <input type="text" id="search" @bind="_searchQuery" @bind:event="oninput" @onkeyup="FilterData"
                           class="block w-full pl-10 pr-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="e.g. PN-1005, S4" />
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden mb-8">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Part Number</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Required Specification</th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-200">
                    @foreach (var mapping in _displayMappings ?? Enumerable.Empty<PartJigMapping>())
                    {
                        var spec = _allSpecs.FirstOrDefault(s => s.Id == mapping.SpecId);
                        
                        <tr class="hover:bg-slate-50">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900 font-mono">
                                @mapping.PartNumber
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="text-sm font-medium text-slate-800">@(spec?.Name ?? "Unknown Spec")</span>
                                <span class="text-xs text-slate-500 ml-2">(ID: @mapping.SpecId)</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <button @onclick="() => OpenEditModal(mapping)" class="text-indigo-600 hover:text-indigo-900 mr-4 font-semibold px-2 py-1 rounded hover:bg-indigo-50 transition-colors">Edit</button>
                                <button @onclick="() => DeleteMapping(mapping)" class="text-red-600 hover:text-red-900 font-semibold px-2 py-1 rounded hover:bg-red-50 transition-colors">Delete</button>
                            </td>
                        </tr>
                    }
                    
                    @if (_displayMappings == null || !_displayMappings.Any())
                    {
                        <tr>
                            <td colspan="3" class="px-6 py-12 text-center text-slate-500 italic">No part mappings defined yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_showModal)
{
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center">
        <div class="relative w-full max-w-md bg-white rounded-2xl shadow-xl p-6 border border-slate-100 text-left">
            <h3 class="text-xl font-bold text-slate-900 mb-6">@(_originalPartNumber == null ? "Add New Mapping" : "Edit Mapping")</h3>

            <div class="space-y-4 mb-6">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Part Number</label>
                    <input type="text" @bind="_editingMapping.PartNumber" class="block w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="e.g. PN-1005" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Jig Specification</label>
                    <select @bind="_editingMapping.SpecId" class="block w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                        <option value="">-- Select Required Spec --</option>
                        @foreach (var spec in _allSpecs)
                        {
                            <option value="@spec.Id">@spec.Name (@spec.Id)</option>
                        }
                    </select>
                </div>
                
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="text-red-500 text-sm font-medium mt-2">@_errorMessage</div>
                }
            </div>

            <div class="flex justify-end space-x-3 pt-4 border-t border-slate-100">
                <button @onclick="CloseModal" class="px-4 py-2 bg-white text-slate-700 border border-slate-300 font-medium rounded-lg hover:bg-slate-50 transition-colors text-sm">Cancel</button>
                <button @onclick="SaveMapping" class="px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors text-sm">Save</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private bool _isImporting = false;
    private bool _showModal = false;
    private PartJigMapping _editingMapping = new();
    private string? _originalPartNumber = null;
    private string _errorMessage = "";
    private string _searchQuery = "";
    private IEnumerable<PartJigMapping>? _displayMappings;
    private List<JigSpec> _allSpecs = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var auth = await Auth.GetAuthAsync();
            var role = auth.Role ?? "";

            if (string.IsNullOrEmpty(role) || (role != "Admin" && role != "Engineer" && role != "ProdLead"))
            {
                NavManager.NavigateTo("/");
                return;
            }

            FilterData();
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void FilterData()
    {
        using var context = DbFactory.CreateDbContext();
        _allSpecs = context.JigSpecs.ToList();

        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _displayMappings = context.PartJigMappings.ToList();
            return;
        }

        var lowerQuery = _searchQuery.ToLowerInvariant();
        _displayMappings = context.PartJigMappings.ToList().Where(m => 
            m.PartNumber.ToLowerInvariant().Contains(lowerQuery) ||
            m.SpecId.ToLowerInvariant().Contains(lowerQuery) ||
            (_allSpecs.FirstOrDefault(s => s.Id == m.SpecId)?.Name ?? "").ToLowerInvariant().Contains(lowerQuery)
        ).ToList();
    }

    private void OpenAddModal()
    {
        _editingMapping = new PartJigMapping();
        _originalPartNumber = null;
        _errorMessage = "";
        _showModal = true;
    }

    private void OpenEditModal(PartJigMapping mapping)
    {
        _editingMapping = new PartJigMapping 
        { 
            PartNumber = mapping.PartNumber, 
            SpecId = mapping.SpecId 
        };
        _originalPartNumber = mapping.PartNumber;
        _errorMessage = "";
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
    }

    private async Task SaveMapping()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Save Mapping", "Are you sure you want to save this BOM mapping?", "Yes, save", "question");
        if (!confirmed) return;

        if (string.IsNullOrWhiteSpace(_editingMapping.PartNumber) || string.IsNullOrWhiteSpace(_editingMapping.SpecId))
        {
            _errorMessage = "Both Part Number and Specification are required.";
            return;
        }

        using var context = DbFactory.CreateDbContext();
        if (_originalPartNumber != null) // Edit Mode
        {
            // If changing part number, check if new one exists
            if (_originalPartNumber != _editingMapping.PartNumber && context.PartJigMappings.Any(m => m.PartNumber == _editingMapping.PartNumber))
            {
                _errorMessage = "A mapping for this new Part Number already exists.";
                return;
            }

            var existing = context.PartJigMappings.FirstOrDefault(m => m.PartNumber == _originalPartNumber);
            if (existing != null)
            {
                // In EF Core, if changing the key, we have to copy, remove old, add new
                if (existing.PartNumber != _editingMapping.PartNumber || existing.SpecId != _editingMapping.SpecId)
                {
                    context.PartJigMappings.Remove(existing);
                    context.SaveChanges();
                    context.PartJigMappings.Add(new PartJigMapping { PartNumber = _editingMapping.PartNumber, SpecId = _editingMapping.SpecId });
                    context.SaveChanges();
                }
            }
        }
        else // Add Mode
        {
            if (context.PartJigMappings.Any(m => m.PartNumber == _editingMapping.PartNumber))
            {
                _errorMessage = "A mapping for this Part Number already exists.";
                return;
            }
            context.PartJigMappings.Add(_editingMapping);
            context.SaveChanges();
        }

        FilterData();
        _showModal = false;
        StateHasChanged();
    }

    private async Task DeleteMapping(PartJigMapping mapping)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Delete Mapping", $"Are you sure you want to remove the link for Part {mapping.PartNumber}?", "Yes, delete", "warning");
        if (!confirmed) return;

        using var context = DbFactory.CreateDbContext();
        var toDelete = context.PartJigMappings.FirstOrDefault(m => m.PartNumber == mapping.PartNumber && m.SpecId == mapping.SpecId);
        if (toDelete != null)
        {
            context.PartJigMappings.Remove(toDelete);
            context.SaveChanges();
        }
        FilterData();
        StateHasChanged();
    }

    private async Task ImportExcel(InputFileChangeEventArgs e)
    {
        _isImporting = true;
        StateHasChanged();
        
        try
        {
            using var stream = e.File.OpenReadStream(10_000_000);
            var result = await ExcelImport.ImportPartMappingsAsync(stream, e.File.Name);
            
            var msg = $"Import complete: {result.inserted} added (duplicates ignored).";
            if (result.errors.Any())
            {
                msg += $"\nErrors:\n{string.Join("\n", result.errors)}";
                await JSRuntime.InvokeVoidAsync("alert", msg);
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", msg);
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Import failed: {ex.Message}");
        }
        finally
        {
            _isImporting = false;
            FilterData();
            StateHasChanged();
        }
    }
}
