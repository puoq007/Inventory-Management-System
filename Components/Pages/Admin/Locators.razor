@page "/admin/locators"
@inject Inventory.Services.AuthService Auth
@inject Microsoft.EntityFrameworkCore.IDbContextFactory<Inventory.Data.AppDbContext> DbFactory
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject Inventory.Services.ExcelImportService ExcelImport
@using Inventory.Models
@using Net.Codecrete.QrCodeGenerator

<PageTitle>Admin - Locations | Inventory</PageTitle>

<div class="mb-6 flex justify-between items-end">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 mb-2">Locations (Locators)</h1>
        <p class="text-slate-500">Manage storage locations for physical jigs.</p>
    </div>
    <div class="flex gap-2">
        <label class="px-5 py-2.5 bg-green-600 text-white font-medium text-sm rounded-lg hover:bg-green-700 shadow-sm transition-colors cursor-pointer flex items-center mb-0">
            <InputFile OnChange="ImportExcel" class="hidden" accept=".xlsx,.xls,.csv" />
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
            @if(_isImporting) { <span>Importing...</span> } else { <span>Import Excel</span> }
        </label>
        
        <button @onclick="OpenAddModal" class="px-5 py-2.5 bg-blue-600 text-white font-medium text-sm rounded-lg hover:bg-blue-700 shadow-sm transition-colors flex items-center">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            New Location
        </button>
    </div>
</div>

@if (_isLoading)
{
    <div class="flex justify-center items-center py-12">
        <div class="text-slate-500 font-medium">Loading locations...</div>
    </div>
}
else
{
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 mb-8">
        <div class="flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <label for="search" class="block text-sm font-medium text-slate-700 mb-1">Search Keyword</label>
                <form class="relative" @onsubmit="FilterData" @onsubmit:preventDefault="true">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                    <input type="text" id="search" @bind="_searchQuery" @bind:event="oninput" @onkeyup="FilterData"
                           class="block w-full pl-10 pr-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="Search ID, Site, Cabinet, etc." />
                </form>
            </div>
            @if (_selectedLocatorIds.Any())
            {
                <div class="flex items-end mb-[2px]">
                    <button @onclick="PrintSelectedQRs" class="px-5 py-2.5 bg-slate-800 text-white font-medium text-sm rounded-lg hover:bg-slate-900 shadow-sm transition-colors flex items-center">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                        Print Selected QR (@_selectedLocatorIds.Count)
                    </button>
                </div>
            }
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider w-16">
                            <div class="flex items-center">
                                <input type="checkbox" class="h-4 w-4 text-blue-600 rounded border-slate-300 focus:ring-blue-500 cursor-pointer" @onchange="ToggleSelectAll" checked="@(_displayLocators.Any() && _selectedLocatorIds.Count == _displayLocators.Count)" />
                            </div>
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">ID</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Site</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Cabinet / Shelf / Pos</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Name</th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-200">
                    @foreach (var loc in _displayLocators)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap w-16">
                                <div class="flex items-center">
                                    <input type="checkbox" class="h-4 w-4 text-blue-600 rounded border-slate-300 focus:ring-blue-500 cursor-pointer" 
                                           checked="@_selectedLocatorIds.Contains(loc.Id)" 
                                           @onchange="@((e) => ToggleSelection(loc.Id, e.Value))" />
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">@loc.Id</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600">@loc.Site</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600">@loc.Cabinet / @loc.Shelf / @loc.Position</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600">@loc.Name</td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <button @onclick="() => PrintQR(loc)" class="text-slate-600 hover:text-slate-900 mr-4 font-semibold px-2 py-1 rounded hover:bg-slate-100 transition-colors" title="Print QR Code">
                                    <svg class="w-4 h-4 inline-block -mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" /></svg>
                                    QR
                                </button>
                                <button @onclick="() => OpenEditModal(loc)" class="text-blue-600 hover:text-blue-900 mr-4 font-semibold px-2 py-1 rounded hover:bg-blue-50 transition-colors">Edit</button>
                                <button @onclick="() => DeleteLocator(loc)" class="text-red-600 hover:text-red-900 font-semibold px-2 py-1 rounded hover:bg-red-50 transition-colors">Delete</button>
                            </td>
                        </tr>
                    }
                    @if (!_displayLocators.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-slate-500">
                                <svg class="mx-auto h-12 w-12 text-slate-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                No locations found matching your criteria.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_showModal)
{
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center p-4">
        <div class="relative w-full max-w-lg bg-white rounded-2xl shadow-xl overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50">
                <h3 class="text-lg font-bold text-slate-900">@(_isEditMode ? "Edit Location" : "New Location")</h3>
                <button @onclick="CloseModal" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div class="p-6">
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="mb-4 p-3 bg-red-50 text-red-700 rounded-lg text-sm border border-red-100">
                        @_errorMessage
                    </div>
                }
                
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Locator ID *</label>
                        <input type="text" @bind="_editingLocator.Id" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Site</label>
                        <input type="text" @bind="_editingLocator.Site" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Cabinet</label>
                        <input type="text" @bind="_editingLocator.Cabinet" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Shelf</label>
                        <input type="text" @bind="_editingLocator.Shelf" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Position</label>
                        <input type="text" @bind="_editingLocator.Position" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 bg-slate-50 border-t border-slate-100 flex justify-end gap-3">
                <button @onclick="CloseModal" class="px-4 py-2 bg-white border border-slate-300 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50">Cancel</button>
                <button @onclick="SaveLocator" class="px-4 py-2 bg-blue-600 rounded-lg text-sm font-medium text-white hover:bg-blue-700 shadow-sm">Save</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private bool _isImporting = false;
    private bool _showModal = false;
    private bool _isEditMode = false;
    private Locator _editingLocator = new();
    private string? _originalLocatorId = null;
    private string _errorMessage = "";
    private string _searchQuery = "";
    private HashSet<string> _selectedLocatorIds = new();

    private List<Locator> _allLocators = new();
    private List<Locator> _displayLocators = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await Auth.GetAuthAsync();
        if (auth.Role != "Admin" && auth.Role != "Engineer" && auth.Role != "ProdLead")
        {
            NavManager.NavigateTo("/");
            return;
        }

        using var context = await DbFactory.CreateDbContextAsync();
        _allLocators = context.Locators.ToList();
        
        FilterData();
        _isLoading = false;
    }

    private void FilterData()
    {
        using var context = DbFactory.CreateDbContext();
        _allLocators = context.Locators.ToList();

        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _displayLocators = _allLocators;
            return;
        }

        var lowerQuery = _searchQuery.ToLowerInvariant();
        _displayLocators = _allLocators.Where(l => 
            (l.Id ?? "").ToLowerInvariant().Contains(lowerQuery) ||
            (l.Site ?? "").ToLowerInvariant().Contains(lowerQuery) ||
            (l.Cabinet ?? "").ToLowerInvariant().Contains(lowerQuery) ||
            (l.Shelf ?? "").ToLowerInvariant().Contains(lowerQuery) ||
            (l.Position ?? "").ToLowerInvariant().Contains(lowerQuery)
        ).ToList();
    }

    private void OpenAddModal()
    {
        _isEditMode = false;
        _originalLocatorId = null;
        _editingLocator = new Locator();
        _errorMessage = "";
        _showModal = true;
    }

    private void OpenEditModal(Locator loc)
    {
        _isEditMode = true;
        _originalLocatorId = loc.Id;
        _editingLocator = new Locator
        {
            Id = loc.Id,
            Site = loc.Site,
            Cabinet = loc.Cabinet,
            Shelf = loc.Shelf,
            Position = loc.Position
        };
        _errorMessage = "";
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
    }

    private void SaveLocator()
    {
        if (string.IsNullOrWhiteSpace(_editingLocator.Id))
        {
            _errorMessage = "Locator ID is required.";
            return;
        }

        using var context = DbFactory.CreateDbContext();

        if (_isEditMode)
        {
            if (_originalLocatorId != _editingLocator.Id && context.Locators.Any(l => l.Id == _editingLocator.Id))
            {
                _errorMessage = "A location with this new ID already exists.";
                return;
            }

            var existing = context.Locators.FirstOrDefault(l => l.Id == _originalLocatorId);
            if (existing != null)
            {
                if (existing.Id != _editingLocator.Id)
                {
                    // To change Primary Key in EF Core: Remove old, Add new.
                    context.Locators.Remove(existing);
                    context.SaveChanges();

                    var newLoc = new Locator
                    {
                        Id = _editingLocator.Id,
                        Site = _editingLocator.Site,
                        Cabinet = _editingLocator.Cabinet,
                        Shelf = _editingLocator.Shelf,
                        Position = _editingLocator.Position
                    };
                    context.Locators.Add(newLoc);

                    // Update corresponding PhysicalJigs that reference the old Locator ID
                    var linkedJigs = context.PhysicalJigs.Where(j => j.LocatorId == _originalLocatorId).ToList();
                    foreach(var jig in linkedJigs)
                    {
                        jig.LocatorId = newLoc.Id;
                    }
                    context.SaveChanges();
                }
                else
                {
                    existing.Site = _editingLocator.Site;
                    existing.Cabinet = _editingLocator.Cabinet;
                    existing.Shelf = _editingLocator.Shelf;
                    existing.Position = _editingLocator.Position;
                    context.SaveChanges();
                }
            }
        }
        else
        {
            if (context.Locators.Any(l => l.Id == _editingLocator.Id))
            {
                _errorMessage = "A location with this ID already exists.";
                return;
            }
            context.Locators.Add(_editingLocator);
            context.SaveChanges();
        }

        FilterData();
        _showModal = false;
        StateHasChanged();
    }

    private async Task DeleteLocator(Locator loc)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmAction", "Delete Location", $"Are you sure you want to delete {loc.Id}?", "Yes, delete", "error");
        if (!confirmed) return;

        using var context = DbFactory.CreateDbContext();
        var toDelete = context.Locators.FirstOrDefault(l => l.Id == loc.Id);
        if (toDelete != null)
        {
            context.Locators.Remove(toDelete);
            context.SaveChanges();
        }
        _selectedLocatorIds.Remove(loc.Id);
        FilterData();
        StateHasChanged();
    }

    private async Task PrintQR(Locator loc)
    {
        var qr = QrCode.EncodeText(loc.Id, QrCode.Ecc.Medium);
        var svgStr = qr.ToSvgString(4, "#000000", "#ffffff");
        await JSRuntime.InvokeVoidAsync("printQR", svgStr, loc.Id);
    }

    private void ToggleSelection(string locId, object? isChecked)
    {
        bool checkedState = isChecked as bool? ?? false;
        if (checkedState)
        {
            _selectedLocatorIds.Add(locId);
        }
        else
        {
            _selectedLocatorIds.Remove(locId);
        }
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        bool selectAll = (bool)(e.Value ?? false);
        _selectedLocatorIds.Clear();
        if (selectAll && _displayLocators != null)
        {
            foreach (var loc in _displayLocators)
            {
                _selectedLocatorIds.Add(loc.Id);
            }
        }
    }

    private async Task PrintSelectedQRs()
    {
        if (!_selectedLocatorIds.Any()) return;

        var qrList = new List<object>();
        foreach (var id in _selectedLocatorIds)
        {
            var qr = QrCode.EncodeText(id, QrCode.Ecc.Medium);
            var svgStr = qr.ToSvgString(4, "#000000", "#ffffff");
            qrList.Add(new { svg = svgStr, id = id });
        }

        await JSRuntime.InvokeVoidAsync("printQRs", qrList);
        _selectedLocatorIds.Clear();
    }

    private async Task ImportExcel(InputFileChangeEventArgs e)
    {
        _isImporting = true;
        StateHasChanged();
        
        try
        {
            using var stream = e.File.OpenReadStream(10_000_000);
            var result = await ExcelImport.ImportLocatorsAsync(stream, e.File.Name);
            
            var msg = $"Import complete: {result.inserted} added, {result.updated} updated.";
            if (result.errors.Any())
            {
                msg += $"\nErrors:\n{string.Join("\n", result.errors)}";
                await JSRuntime.InvokeVoidAsync("alert", msg);
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", msg);
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Import failed: {ex.Message}");
        }
        finally
        {
            _isImporting = false;
            FilterData();
            StateHasChanged();
        }
    }
}
